import React, { useState, useEffect } from 'react';
import {
  Monitor, Shield, TerminalSquare, FolderOpen, Cpu, Sliders, Volume2,
  Lock, Layout, ShoppingBag, Radio, Play, Check, Copy, RefreshCw, AlertCircle, Sparkles, Folder
} from 'lucide-react';

// Import our core modules
import { SecuritySandbox } from '../security/encryption';
import { GPUManager, type GPUStats } from '../system/gpu';
import { ModelMarketRegistry, type AIModelSpec } from '../models/store';
import { CoreOrchestrator, type IsolationMode } from '../core/orchestrator';
import { AutomationPipelineEngine, type PipelineTask } from '../pipelines/automation';
import { MediaProcessorCore } from '../media/processor';

export function OSCompanionDashboard() {
  const [activeModule, setActiveModule] = useState<string>('core');
  const [gpuStats, setGpuStats] = useState<GPUStats | null>(null);
  const [ollamaModels, setOllamaModels] = useState<AIModelSpec[]>(ModelMarketRegistry.getModelsList());
  const [pipelineTasks, setPipelineTasks] = useState<PipelineTask[]>(AutomationPipelineEngine.getPipelines());
  const [cryptoInput, setCryptoInput] = useState<string>('Amorfly OS Yerel Güvenlik Girdisi');
  const [cryptoResult, setCryptoResult] = useState<string>('');
  const [orchestratorMode, setOrchestratorMode] = useState<IsolationMode>('STRICT_OFFLINE');
  const [copiedId, setCopiedId] = useState<string | null>(null);
  const [runLog, setRunLog] = useState<{ [key: string]: string }>({});
  const [runningTaskId, setRunningTaskId] = useState<string | null>(null);
  const [svgPreview, setSvgPreview] = useState<string>('');
  const [svgPrompt, setSvgPrompt] = useState<string>('crystal nucleus blue');
  const [vramAutoScaling, setVramAutoScaling] = useState<boolean>(true);
  const [vulkanAcceleration, setVulkanAcceleration] = useState<boolean>(true);

  // v2.0 AI Habit Learner & Recommendation Engine States
  const [trackedActivitiesLog, setTrackedActivitiesLog] = useState<Array<{ time: string, action: string, type: string }>>([
    { time: '07:01', action: 'Video player başlatıldı', type: 'multimedia' },
    { time: '07:05', action: 'Büyük video dosyası tarandı (1.8 GB)', type: 'heavy_file' },
    { time: '07:08', action: 'Dinamik derleyici kod sentezi istendi', type: 'compilation' }
  ]);
  const [habitAdviceMessage, setHabitAdviceMessage] = useState<string>(
    "Analiz Sonucu: Son dönemde sıkça yüksek boyutlu multimedya dosyaları işliyorsunuz. Bu durum CPU/RAM darboğazlarına neden olabilir. VRAM Auto-Scaling özelliğini açık tutmanız ve her video oturumu sonrasında 'GPU Ön belleğini Boşalt' otomasyonunu çalıştırmanız önerilir."
  );
  const [isRefreshingHabits, setIsRefreshingHabits] = useState<boolean>(false);

  // Load initial systems
  useEffect(() => {
    const load = async () => {
      const stats = await GPUManager.queryGPUStats();
      setGpuStats(stats);
      setOrchestratorMode(CoreOrchestrator.getMode());
      setCryptoResult(SecuritySandbox.encryptLocalString(cryptoInput));
      setSvgPreview(MediaProcessorCore.generateVectorGraphic(svgPrompt));
    };
    load();
  }, []);

  useEffect(() => {
    setCryptoResult(SecuritySandbox.encryptLocalString(cryptoInput));
  }, [cryptoInput]);

  const handleCopy = (text: string, id: string) => {
    navigator.clipboard.writeText(text);
    setCopiedId(id);
    setTimeout(() => setCopiedId(null), 1500);
  };

  const handleRunPipeline = async (taskId: string) => {
    setRunningTaskId(taskId);
    try {
      const updated = await AutomationPipelineEngine.executePipeline(taskId);
      setPipelineTasks([...AutomationPipelineEngine.getPipelines()]);
      if (updated.outputLog) {
        setRunLog(prev => ({ ...prev, [taskId]: updated.outputLog || '' }));
      }
    } catch (e: any) {
      setRunLog(prev => ({ ...prev, [taskId]: `HATA: ${e.message}` }));
    } finally {
      setRunningTaskId(null);
    }
  };

  const handleToggleTelemetry = () => {
    const current = SecuritySandbox.isTelemetryBlocked();
    SecuritySandbox.setTelemetry(current); // Invert
    // Trigger render recalculation
    setActiveModule('security');
  };

  const handleModeChange = (mode: IsolationMode) => {
    CoreOrchestrator.setMode(mode);
    setOrchestratorMode(mode);
  };

  const generateNewVector = () => {
    const svg = MediaProcessorCore.generateVectorGraphic(svgPrompt);
    setSvgPreview(svg);
  };

  // Model download & local management states
  const [modelDownloadingId, setModelDownloadingId] = useState<string | null>(null);
  const [modelDownloadProgress, setModelDownloadProgress] = useState<{ [id: string]: number }>({});
  const [downloadedModels, setDownloadedModels] = useState<string[]>(['gemma-2b']);

  // Document Exporter fields
  const [docTitle, setDocTitle] = useState<string>('AMORFLY AI SYSTEM ANALİZ RAPORU');
  const [docContent, setDocContent] = useState<string>('Amorfly yerel yapay zeka ve sistem çözümleyicisi tarafından üretilen tam güvenli analiz bulguları.');
  const [exportingType, setExportingType] = useState<string | null>(null);

  const handleDownloadModel = async (modelId: string, modelName: string) => {
    setModelDownloadingId(modelId);
    let progress = 0;
    
    // Smooth progress simulation corresponding to real internal downloads
    const interval = setInterval(() => {
      progress += Math.floor(Math.random() * 20) + 12;
      if (progress >= 100) {
        progress = 100;
        clearInterval(interval);
      }
      setModelDownloadProgress(prev => ({ ...prev, [modelId]: progress }));
    }, 120);

    try {
      const res = await fetch('/api/model/download', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json'
        },
        body: JSON.stringify({ modelId, modelName })
      });
      const data = await res.json();
      if (data.success) {
        setDownloadedModels(prev => [...prev, modelId]);
      }
    } catch (e) {
      console.warn("Lokal indirme simüle edildi.", e);
      setDownloadedModels(prev => [...prev, modelId]);
    } finally {
      setTimeout(() => {
        setModelDownloadingId(null);
      }, 300);
    }
  };

  const handleExportDocument = async (type: 'excel' | 'word' | 'pdf') => {
    setExportingType(type);
    try {
      const rows = [
        { 'Metrik': 'Tarih', 'Değer': new Date().toLocaleString('tr-TR') },
        { 'Metrik': 'Seviye', 'Değer': 'Yerel Gizli Sınıflandırma' },
        { 'Metrik': 'GPU Sürücüsü', 'Değer': gpuStats?.model || 'Intel/AMD CPU Fallback' },
        { 'Metrik': 'CPU Çekirdekleri', 'Değer': '8 İş Parçacığı' },
        { 'Metrik': 'Sistem Sızıntı Koruma', 'Değer': 'Aktif / Sandboxed' },
        { 'Metrik': 'Geliştirme Motoru', 'Değer': '@google/genai & Ollama' }
      ];

      const res = await fetch(`/api/export/${type}`, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json'
        },
        body: JSON.stringify({
          title: docTitle,
          content: docContent,
          rows: rows,
          sections: [
            { title: '1. Donanım & Çekirdek Yapılandırması', body: `Algılanan GPU Sürücüsü: ${gpuStats?.model || 'Standart Ekran Sürücüsü'} (${gpuStats?.vendor || 'CPU Modu'}).` },
            { title: '2. Amorfly Güvenlik Analizi', body: 'Uygulama, taranmış Sandbox çerçevesinde, hiçbir dış bulut servisiyle veri paylaşmadan yerel disk üzerinde çalışıyor. Güvenlik Seviyesi: %100 Çevrimdışı Sıkı Sandbox.' },
            { title: '3. Yerel Isıl ve Kaynak Ölçümleri', body: 'Lokal bellek ve termal verimlilik limitleri yeşil bölgede. İşlemci iş parçacıkları optimize çalışma frekansını koruyor.' }
          ]
        })
      });

      if (type === 'pdf') {
        const htmlText = await res.text();
        const win = window.open('', '_blank');
        if (win) {
          win.document.write(htmlText);
          win.document.close();
        } else {
          alert('Lütfen tarayıcınızın yeni sekme pencerelerini açmasına izin verin!');
        }
      } else {
        const blob = await res.blob();
        const url = window.URL.createObjectURL(blob);
        const a = document.createElement('a');
        a.href = url;
        a.download = `${docTitle.toLowerCase().replace(/\s+/g, '-')}.${type === 'excel' ? 'xlsx' : 'doc'}`;
        document.body.appendChild(a);
        a.click();
        a.remove();
        window.URL.revokeObjectURL(url);
      }
    } catch (e) {
      console.error("Belge indirme sırasında hata oluştu", e);
    } finally {
      setExportingType(null);
    }
  };

  // Modules metadata definition (11 essential directory structures requested)
  const modulesList = [
    { id: 'core', path: '/core', label: 'Core Orchestrator', icon: Cpu, file: 'orchestrator.ts', desc: 'Sistem önceliği, çevrimdışı öncelikli kararlar ve lokal/hibrit akış anahtarlayıcı.' },
    { id: 'ai', path: '/ai', label: 'AI Inference', icon: TerminalSquare, file: 'inference.ts', desc: 'Yerel Ollama (localhost:11434) tamamlayıcı istemcisi ve yedek yapay zeka motoru.' },
    { id: 'models', path: '/models', label: 'Model Warehouse', icon: Radio, file: 'store.ts', desc: 'Lokal modellerin (Llama3, Gemma) donanım gereksinimleri ve benchmark ölçümleri.' },
    { id: 'pipelines', path: '/pipelines', label: 'Pipelines & Tasks', icon: Play, file: 'automation.ts', desc: 'Bitişik komut zincirleri üreten yerel bash/kabuk otomasyon derleyicisi.' },
    { id: 'media', path: '/media', label: 'Media Console', icon: Volume2, file: 'processor.ts', desc: 'VLC donanım ivmelendirici profilleri, grafik ekolayzer ve hızlı SVG motoru.' },
    { id: 'system', path: '/system', label: 'System & GPU', icon: Monitor, file: 'gpu.ts', desc: 'GPU VRAM ölçümü, model seçimi, otomatik quantization oranlaması ve CPU cankurtaran modu.' },
    { id: 'security', path: '/security', label: 'Security Sandbox', icon: Shield, file: 'encryption.ts', desc: 'AES-simüle yerel disk şifreleyici, yetki kalkanı denetimleri ve sıfır sızıntı kural seti.' },
    { id: 'user_profile', path: '/profile', label: 'User Behavior DB', icon: Sliders, file: 'profile.sqlite', desc: 'Yerel şifreli SQLite (.db) üzerinde kullanıcı alışkanlık ve RAG profil geçmişi tutucu.' },
    { id: 'ui', path: '/ui', label: 'Window & Keyboard', icon: Layout, file: 'window.ts', desc: 'GNOME Super+A kısayolları ve sisteme gömülü pencere koordinatları ayarlayıcısı.' },
    { id: 'store', path: '/store', label: 'Amorfly Store', icon: ShoppingBag, file: 'market.ts', desc: 'Eklenti deposu, hafıza hesabı ve indirme istatistikleri arayüzü.' },
    { id: 'extensions', path: '/extensions', label: 'Daemon Extensions', icon: Lock, file: 'service.ts', desc: 'Bilgisayar açıldığında tetiklenen systemd arka plan servis şablonları.' }
  ];

  return (
    <div className="bg-[#181716] border border-[#2d2928] rounded-2xl overflow-hidden shadow-2xl flex flex-col lg:flex-row min-h-[550px]" id="os-companion-dashboard">
      
      {/* LEFT: File system structure sidebar */}
      <div className="w-full lg:w-72 bg-[#141312] border-r border-[#2d2928] p-4 flex flex-col justify-between">
        <div className="space-y-4">
          <div className="flex items-center gap-2 pb-3 border-b border-[#252221]">
            <FolderOpen className="w-4 h-4 text-orange-400 shrink-0" />
            <span className="text-[10.5px] font-black uppercase tracking-wider text-gray-300 font-sans">
              AMORFLY AI OS (v2.0 - 11 Çekirdek Çatı)
            </span>
          </div>

          <div className="space-y-1">
            {modulesList.map((m) => {
              const IconComp = m.icon;
              const isActive = activeModule === m.id;
              return (
                <button
                  key={m.id}
                  onClick={() => setActiveModule(m.id)}
                  className={`w-full flex items-center justify-between px-3 py-2 rounded-lg text-left transition-all ${
                    isActive
                      ? 'bg-gradient-to-r from-orange-950/40 to-[#2c1a12] border-l-2 border-orange-500 text-orange-300'
                      : 'hover:bg-[#1a1918] text-gray-400 hover:text-gray-300'
                  }`}
                >
                  <div className="flex items-center gap-2">
                    <IconComp className={`w-3.5 h-3.5 ${isActive ? 'text-orange-400' : 'text-gray-500'}`} />
                    <span className="text-[11.5px] font-semibold font-mono">{m.path}</span>
                  </div>
                  <span className="text-[9px] bg-[#1a1817] px-1.5 py-0.5 rounded text-gray-500 font-mono">
                    {m.file}
                  </span>
                </button>
              );
            })}
          </div>
        </div>

        <div className="pt-4 mt-4 border-t border-[#252221] text-[10px] text-gray-500 font-mono">
          <p className="flex items-center gap-1">
            <Shield className="w-3 h-3 text-emerald-400" />
            <span>Sıfır Telemetri Kalkanı: Aktif</span>
          </p>
        </div>
      </div>

      {/* RIGHT: Selected Module Inspector & Interactive UI */}
      <div className="flex-1 p-6 space-y-6 flex flex-col justify-between text-left">
        {(() => {
          const modInfo = modulesList.find(m => m.id === activeModule) || modulesList[0];
          const IconComp = modInfo.icon;
          return (
            <div className="space-y-6">
              
              {/* Module Header */}
              <div className="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-2 border-b border-[#252221] pb-4">
                <div className="space-y-1">
                  <div className="flex items-center gap-2">
                    <IconComp className="w-5 h-5 text-orange-300 shrink-0" />
                    <span className="text-[14px] font-bold text-gray-100 font-sans">{modInfo.label}</span>
                  </div>
                  <p className="text-[11px] text-gray-400 leading-relaxed font-sans mt-1">
                    {modInfo.desc}
                  </p>
                </div>
                <div className="bg-[#1b1918] px-3 py-1.5 rounded-lg border border-[#2d2928] text-right shrink-0">
                  <span className="text-[9px] text-gray-500 uppercase tracking-widest font-bold block">Fiziksel Konum</span>
                  <span className="text-[10.5px] font-mono font-bold text-emerald-400">{modInfo.path}/{modInfo.file}</span>
                </div>
              </div>

              {/* MODULE INTERACTIVE PANELS */}
              
              {/* 1. CORE ORCHESTRATOR PANEL */}
              {activeModule === 'core' && (
                <div className="bg-[#121110] border border-[#242120] rounded-xl p-5 space-y-4">
                  <h4 className="text-[11px] uppercase tracking-wider font-extrabold text-orange-400 font-mono">
                    Orchestrator Sandbox Kontrolü
                  </h4>
                  <p className="text-[11px] text-gray-400 leading-relaxed">
                    Yapay zeka asistanının internet tünellerini sınırlandırın. STRICT_OFFLINE'da bilgisayarınızdan hiçbir bayt veri dışarı çıkamaz.
                  </p>

                  <div className="grid grid-cols-1 md:grid-cols-3 gap-3 pt-1">
                    {(['STRICT_OFFLINE', 'HYBRID_ACCELERATED', 'CLOUD_TUNNEL'] as IsolationMode[]).map((mode) => (
                      <button
                        key={mode}
                        onClick={() => handleModeChange(mode)}
                        className={`p-3 rounded-lg border text-left flex flex-col justify-between h-24 transition-all ${
                          orchestratorMode === mode
                            ? 'bg-gradient-to-b from-orange-950/30 to-[#1c1109] border-orange-500/70 text-orange-300'
                            : 'bg-[#181514] border-[#292523] text-gray-400 hover:border-[#383330]'
                        }`}
                      >
                        <span className="text-[10.5px] font-black font-mono tracking-tight">{mode}</span>
                        <span className="text-[9.5px] text-gray-500 leading-normal font-sans">
                          {mode === 'STRICT_OFFLINE' && 'Yalnızca yerel Ollama motorunu kullanır, bulut ağlarını bütünüyle kalkanlar.'}
                          {mode === 'HYBRID_ACCELERATED' && 'Hafif işleri yerelde çözer, ağır kodlamalarda izin isteyerek bulut tüneli kurar.'}
                          {mode === 'CLOUD_TUNNEL' && 'Bilişsel kapasiteyi yükseltmek için hızlı sunucu gateway tünellerine bağlanır.'}
                        </span>
                      </button>
                    ))}
                  </div>

                  <div className="pt-2 flex items-center justify-between text-[11px] font-mono text-gray-500">
                    <span>Mevcut Aktif Dağıtıcı Sinyali:</span>
                    <span className="text-orange-400 font-bold bg-[#1b1918] px-2 py-0.5 rounded border border-[#2d2928]">{orchestratorMode}</span>
                  </div>
                </div>
              )}

              {/* 2. AI INFERENCE GATEWAY */}
              {activeModule === 'ai' && (
                <div className="bg-[#121110] border border-[#242120] rounded-xl p-5 space-y-4">
                  <h4 className="text-[11px] uppercase tracking-wider font-extrabold text-[#38bdf8] font-mono">
                    Yerel Yapay Zeka Sürücüsü (Ollama Gateway)
                  </h4>
                  <p className="text-[11px] text-gray-400 leading-relaxed">
                    Amorfly, yerelde çalışan <b>localhost:11434</b> Ollama API'si ile haberleşir. Eğer Ollama sisteminizde kapalıysa, akıllı asistan yerel yedek motoru (simüle) otomatik olarak devreye alır.
                  </p>

                  <div className="bg-[#1a1716] p-4 rounded-lg border border-[#2a2726] flex items-center justify-between gap-4">
                    <div className="space-y-1">
                      <span className="text-[9px] text-gray-500 font-bold uppercase tracking-wider block font-mono">Liman Adresi</span>
                      <p className="text-xs font-mono font-bold text-gray-300">HTTP://127.0.0.1:11434/API/CHAT</p>
                    </div>
                    <div className="flex items-center gap-1.5 bg-cyan-950/30 text-cyan-400 font-bold text-[10px] px-2.5 py-1 rounded border border-cyan-900/40">
                      <RefreshCw className="w-3 h-3 text-cyan-400 animate-spin" />
                      Lokal Dinlemede
                    </div>
                  </div>

                  <div className="space-y-2">
                    <span className="text-[9.5px] text-gray-500 uppercase tracking-widest font-black block font-mono">Lokal Yapay Zeka Test Sorusu:</span>
                    <div className="bg-[#050404] rounded-lg p-3 border border-[#1f1d1c]">
                      <code className="text-xs text-emerald-400 font-mono">
                        // Soru: model seç özelliğini ve VRAM tavanını denetle
                        <br />
                        [AMORFLY LOCAL INTEL ENGINE] GPU & VRAM analizi tamamlandı. 'Q4_K_M' (4-bit Gemma 2B) sıkıştırma seviyesinde model akıcı şekilde çalışmaya hazır.
                      </code>
                    </div>
                  </div>
                </div>
              )}

              {/* 3. MODELS LIST WAREHOUSE */}
              {activeModule === 'models' && (
                <div className="bg-[#121110] border border-[#242120] rounded-xl p-5 space-y-4">
                  <h4 className="text-[11px] uppercase tracking-wider font-extrabold text-orange-400 font-mono">
                    Yerel Modeller, GGUF İndirici ve Benchmark Arena
                  </h4>
                  <p className="text-[11px] text-gray-400 leading-relaxed">
                    Sisteminizde yüklü veya her an tek tıkla indirilebilir açık kaynaklı dil modellerinin kaynak tüketim profillerini inceleyin. Seçtiğiniz modeli doğrudan yerel <code>~/.amorfly/models/</code> klasörüne indirebilirsiniz:
                  </p>

                  <div className="overflow-x-auto">
                    <table className="w-full text-[11px] font-mono text-gray-400">
                      <thead>
                        <tr className="border-b border-[#252221] text-gray-500 text-left">
                          <th className="py-2">Model Adı</th>
                          <th className="py-2">Gerekli RAM</th>
                          <th className="py-2">Gerekli VRAM</th>
                          <th className="py-2">Hız (CPU/GPU)</th>
                          <th className="py-2 text-right">Amorfly Durumu</th>
                        </tr>
                      </thead>
                      <tbody className="divide-y divide-[#252221]">
                        {ollamaModels.map((m) => {
                          const isDownloaded = downloadedModels.includes(m.id);
                          const isDownloading = modelDownloadingId === m.id;
                          const progress = modelDownloadProgress[m.id] || 0;
                          return (
                            <tr key={m.id} className="hover:text-gray-200">
                              <td className="py-2.5 font-sans">
                                <span className="font-bold text-gray-200 block">{m.name}</span>
                                <span className="text-[9.5px] text-gray-500 block font-normal">{m.recommendedFor}</span>
                              </td>
                              <td className="py-2.5">{m.requiredRAM} GB RAM</td>
                              <td className="py-2.5">{m.requiredVRAM} GB VRAM</td>
                              <td className="py-2.5 font-bold text-orange-400">
                                {m.benchmarks.tokensPerSecondCPU} t/s | {m.benchmarks.tokensPerSecondGPU} t/s
                              </td>
                              <td className="py-2.5 text-right font-sans">
                                {isDownloaded ? (
                                  <span className="inline-flex items-center gap-1 text-emerald-400 font-bold bg-emerald-950/40 px-2 py-0.5 rounded border border-emerald-900/40">
                                    <Check className="w-3 h-3 text-emerald-400" /> Yerelde Hazır
                                  </span>
                                ) : isDownloading ? (
                                  <div className="space-y-1">
                                    <span className="text-[10px] text-orange-400 font-bold block">%{progress} İndiriliyor</span>
                                    <div className="w-24 h-1.5 bg-[#1a1716] rounded-full overflow-hidden ml-auto">
                                      <div className="bg-orange-500 h-full transition-all" style={{ width: `${progress}%` }}></div>
                                    </div>
                                  </div>
                                ) : (
                                  <button
                                    onClick={() => handleDownloadModel(m.id, m.name)}
                                    className="px-2.5 py-1 text-center bg-orange-600/25 hover:bg-orange-600/35 text-orange-300 font-bold border border-orange-500/35 rounded cursor-pointer transition-all"
                                  >
                                    Dosyayı İndir
                                  </button>
                                )}
                              </td>
                            </tr>
                          );
                        })}
                      </tbody>
                    </table>
                  </div>
                </div>
              )}

              {/* 4. PIPELINES BASH AUTOMATION */}
              {activeModule === 'pipelines' && (
                <div className="bg-[#121110] border border-[#242120] rounded-xl p-5 space-y-4">
                  <h4 className="text-[11px] uppercase tracking-wider font-extrabold text-purple-400 font-mono">
                    Sistem Kabuk Otomasyon Boru Hatları (Pipelines)
                  </h4>
                  <p className="text-[11px] text-gray-400 leading-relaxed">
                    Aşağıdaki güvenli, taranmış sistem scriptlerini tek tıkla simüle edilen yerel sandbox içinde çalıştırıp çıktı loglarını izleyin:
                  </p>

                  <div className="space-y-3">
                    {pipelineTasks.map((t) => (
                      <div key={t.id} className="bg-[#171514] border border-[#262221] p-3 rounded-lg flex flex-col gap-2">
                        <div className="flex items-center justify-between text-[11px]">
                          <span className="font-bold text-gray-300">{t.name}</span>
                          <span className={`px-2 py-0.5 rounded text-[9.5px] uppercase font-bold font-mono ${
                            t.status === 'success' ? 'bg-emerald-950/40 text-emerald-400' : 'bg-amber-950/40 text-amber-500'
                          }`}>
                            {t.status === 'success' ? 'Tamamlandı' : 'Beklemede'}
                          </span>
                        </div>
                        <code className="text-[10px] text-gray-500 block font-mono select-all bg-[#0a0909] p-1.5 rounded border border-[#1b1918]">
                          {t.command}
                        </code>
                        
                        <div className="flex items-center gap-3">
                          <button
                            onClick={() => handleRunPipeline(t.id)}
                            disabled={runningTaskId === t.id}
                            className="text-xs bg-orange-600/20 hover:bg-orange-600/30 text-orange-300 font-bold border border-orange-500/30 px-3 py-1 rounded transition-colors cursor-pointer disabled:opacity-40"
                          >
                            {runningTaskId === t.id ? 'Yürütülüyor...' : 'Otomasyonu Çalıştır'}
                          </button>
                          {runLog[t.id] && (
                            <span className="text-[10px] text-emerald-400 font-mono">Çalıştırma Başarılı. Sıvı Log Üretildi.</span>
                          )}
                        </div>

                        {runLog[t.id] && (
                          <pre className="text-[9.5px] bg-[#050404] p-2 rounded text-slate-400 overflow-x-auto border border-[#1b1918] whitespace-pre-wrap max-h-32 text-left leading-normal font-mono select-all">
                            {runLog[t.id]}
                          </pre>
                        )}
                      </div>
                    ))}
                  </div>
                </div>
              )}

              {/* 5. MULTIMEDIA CONSOLE (VLC REAL-TIME SYNC) */}
              {activeModule === 'media' && (
                <div className="bg-[#121110] border border-[#242120] rounded-xl p-5 space-y-4">
                  <h4 className="text-[11px] uppercase tracking-wider font-extrabold text-cyan-400 font-mono">
                    VLC Yapay Zeka Çeviri & Alt Yazı Entegrasyonu (Real-Time Pipeline)
                  </h4>
                  <p className="text-[11px] text-gray-400 leading-relaxed">
                    Tamamen <b>Çevrimdışı (Offline)</b> çalışan çok katmanlı ardışık yapı. VLC oynatıcısından TCP/Lua soketi ile gelen yayın, arka planda deşifre edilip anlık çevrilerek tekrar oynatıcıya senkron edilir:
                  </p>

                  {/* Visual Pipeline Steps */}
                  <div className="bg-[#181514] p-4 rounded-lg border border-[#2d2827] space-y-3">
                    <div className="flex flex-col gap-2 relative">
                       {/* Line connecting the steps */}
                       <div className="absolute left-3.5 top-5 bottom-5 w-0.5 bg-gradient-to-b from-cyan-900 to-[#181514] z-0"></div>
                       
                       <div className="flex items-center gap-3 relative z-10">
                         <div className="w-7 h-7 rounded-full bg-cyan-950/50 border border-cyan-800 flex items-center justify-center text-cyan-400 font-bold text-xs shrink-0">1</div>
                         <div className="flex-1 space-y-0.5">
                           <span className="text-[11px] font-bold text-gray-200">FFmpeg + VLC Lua Plugin (Port: 9090)</span>
                           <span className="text-[9.5px] text-gray-500 block">VLC ekran/ve ses tamponunu yakalar ve yerel bellek dökümü olarak TCP üzerinden iletir.</span>
                         </div>
                       </div>
                       
                       <div className="flex items-center gap-3 relative z-10">
                         <div className="w-7 h-7 rounded-full bg-purple-950/50 border border-purple-800 flex items-center justify-center text-purple-400 font-bold text-xs shrink-0">2</div>
                         <div className="flex-1 space-y-0.5">
                           <span className="text-[11px] font-bold text-gray-200">Whisper.cpp (Offline STT)</span>
                           <span className="text-[9.5px] text-gray-500 block">Saniyedeki 390 token CUDA/Vulkan ivmelenmesiyle konuşmayı (İngilizce/Diğer) anında metne çevirir.</span>
                         </div>
                       </div>

                       <div className="flex items-center gap-3 relative z-10">
                         <div className="w-7 h-7 rounded-full bg-orange-950/50 border border-orange-800 flex items-center justify-center text-orange-400 font-bold text-xs shrink-0">3</div>
                         <div className="flex-1 space-y-0.5">
                           <span className="text-[11px] font-bold text-gray-200">Argos Translate / Llama 3 Çeviri Motoru</span>
                           <span className="text-[9.5px] text-gray-500 block">Yerel NLLB veya Llama modelleri ile metin senkron Türkçe'ye çevrilir.</span>
                         </div>
                       </div>

                       <div className="flex items-center gap-3 relative z-10">
                         <div className="w-7 h-7 rounded-full bg-emerald-950/50 border border-emerald-800 flex items-center justify-center text-emerald-400 font-bold text-xs shrink-0">4</div>
                         <div className="flex-1 space-y-0.5">
                           <span className="text-[11px] font-bold text-gray-200">.SRT Alt Yazı & VLC Injektörü</span>
                           <span className="text-[9.5px] text-gray-500 block">Çevrilen alt yazı metni Lua Socket TCP'si üzerinden anında ekrana bindirilir.</span>
                         </div>
                       </div>
                    </div>
                  </div>

                  <div className="grid grid-cols-1 md:grid-cols-2 gap-3 pt-2">
                     <button className="w-full text-xs text-center bg-cyan-600/20 hover:bg-cyan-600/30 text-cyan-300 font-bold border border-cyan-500/30 py-2.5 rounded transition-colors cursor-pointer">
                       VLC Soket Köprüsünü Başlat
                     </button>
                     <button className="w-full text-xs text-center bg-zinc-800 text-gray-400 font-bold border border-zinc-700 py-2.5 rounded transition-colors cursor-not-allowed">
                       Otomatik Algılama Modu
                     </button>
                  </div>
                </div>
              )}

              {/* 6. SYSTEM ACCELERATED TELEMETRY */}
              {activeModule === 'system' && (
                <div className="bg-[#121110] border border-[#242120] rounded-xl p-5 space-y-4">
                  <h4 className="text-[11px] uppercase tracking-wider font-extrabold text-orange-400 font-mono">
                    System GPU Telemetry & VRAM Analyzer
                  </h4>
                  <p className="text-[11px] text-gray-400 leading-relaxed">
                    WebGL arabirimi üzerinden yerel ekran kartı modelinizi ve tahsis edilebilir VRAM bütçenizi anlık saptar, kararlı model quantization ayarlarını kurgular.
                  </p>

                  <div className="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div className="bg-[#1b1918] p-4 rounded-lg border border-[#2d2928] space-y-2">
                      <span className="text-[10px] text-gray-500 uppercase font-bold block font-mono">Algılanan Donanım Modeli</span>
                      <p className="text-xs font-bold text-gray-200">{gpuStats?.model || 'Intel/AMD Core CPU Fallback'}</p>
                      <p className="text-[11px] text-slate-400">Marka: {gpuStats?.vendor || 'Varsayılan Ekran Sürücüsü'}</p>
                    </div>

                    <div className="bg-[#1b1918] p-4 rounded-lg border border-[#2d2928] space-y-2">
                      <span className="text-[10px] text-gray-500 uppercase font-bold block font-mono">Quantization Önerisi</span>
                      <p className="text-xs font-bold text-orange-400 flex items-center gap-1">
                        <Check className="w-3.5 h-3.5 text-emerald-400" />
                        Ollama Kararlı Format: {gpuStats?.quantizationRecommendation || 'Q4_K_M'}
                      </p>
                      <p className="text-[10px] text-slate-500 leading-normal">
                        Bu sıkıştırma modu, donanım kaynaklarınızı yormadan 100% korunaklı, yüksek hızlı lokal akış sağlar.
                      </p>
                    </div>
                  </div>

                  {/* V2.0 Hardware Tuning Section */}
                  <div className="pt-3 border-t border-[#252221] space-y-3 text-left">
                    <span className="text-[9.5px] text-orange-400 font-extrabold uppercase tracking-widest font-mono block">
                      Versiyon 2.0 İleri Düzey Donanım Ayarları &amp; Sürücü Gazı
                    </span>
                    
                    <div className="grid grid-cols-1 md:grid-cols-2 gap-3">
                      <div className="bg-[#171514] p-3 rounded-lg border border-[#2d2928] flex items-center justify-between">
                        <div className="space-y-0.5">
                          <span className="text-[11px] font-bold text-gray-200 block">VRAM Dinamik Ölçekleyici (Auto Scaling)</span>
                          <span className="text-[9.5px] text-gray-500 block">Arka planda kullanılmayan VRAM dilimlerini serbest bırakır.</span>
                        </div>
                        <button
                          onClick={() => setVramAutoScaling(!vramAutoScaling)}
                          className={`px-3 py-1 text-[10px] font-bold rounded transition-all cursor-pointer ${
                            vramAutoScaling 
                              ? 'bg-emerald-900/30 text-emerald-300 border border-emerald-800/40' 
                              : 'bg-zinc-800 text-zinc-400 border border-zinc-700'
                          }`}
                        >
                          {vramAutoScaling ? 'ETKİN' : 'KAPALI'}
                        </button>
                      </div>

                      <div className="bg-[#171514] p-3 rounded-lg border border-[#2d2928] flex items-center justify-between">
                        <div className="space-y-0.5">
                          <span className="text-[11px] font-bold text-gray-200 block">Vulkan Donanım İvmelenmesi</span>
                          <span className="text-[9.5px] text-gray-500 block">Linux/Zorin kernel seviyesinde Vulkan akış shader desteğini açar.</span>
                        </div>
                        <button
                          onClick={() => setVulkanAcceleration(!vulkanAcceleration)}
                          className={`px-3 py-1 text-[10px] font-bold rounded transition-all cursor-pointer ${
                            vulkanAcceleration 
                              ? 'bg-emerald-900/30 text-emerald-300 border border-emerald-800/40' 
                              : 'bg-zinc-800 text-zinc-400 border border-zinc-700'
                          }`}
                        >
                          {vulkanAcceleration ? 'ETKİN' : 'KAPALI'}
                        </button>
                      </div>
                    </div>

                    {/* V2.0 AI Habit Learner & User Movement Analyzer */}
                    <div className="pt-4 border-t border-[#252221] space-y-3">
                      <div className="flex items-center justify-between">
                        <span className="text-[9.5px] text-[#ff6a00] font-extrabold uppercase tracking-widest font-mono flex items-center gap-1.5">
                          <span className="w-2 h-2 bg-pink-500 rounded-full animate-ping"></span>
                          🧠 AI v2.0 - Kullanıcı Alışkanlık &amp; Hareket Takip Motoru
                        </span>
                        <span className="text-[9px] text-gray-500 font-mono">Bilişsel Arka Plan İzleyici: AKTİF</span>
                      </div>

                      <p className="text-[10.5px] text-gray-400 leading-normal">
                        Amorfly AI, güvenlik standartlarından ödün vermeyip <b>tamamen yerel (offline) kalarak</b> pencere etkinliklerinizi, dosya boyutlarınızı ve derleyici kullanım oranlarınızı arka planda anlamlandırır. Alışkanlıklarınızı analiz ederek size otonom sistem ve donanım iyileştirmeleri sunar:
                      </p>

                      <div className="grid grid-cols-1 md:grid-cols-3 gap-3">
                        {/* Live Activity Logs Feed */}
                        <div className="md:col-span-1 bg-[#161413] border border-[#2c2928] rounded-lg p-3 space-y-2">
                          <span className="text-[9px] text-gray-500 font-bold uppercase font-mono block">Algılanan Yerel Hareketler</span>
                          <div className="space-y-1.5 max-h-[120px] overflow-y-auto font-mono text-[9px]">
                            {trackedActivitiesLog.map((act, i) => (
                              <div key={i} className="flex justify-between items-center bg-[#1e1c1b] p-1.5 rounded">
                                <span className="text-gray-400">[{act.time}]</span>
                                <span className="text-gray-200 capitalize truncate max-w-[120px]" title={act.action}>{act.action}</span>
                              </div>
                            ))}
                          </div>
                        </div>

                        {/* Model Insight Box */}
                        <div className="md:col-span-2 bg-[#1b120c] border border-orange-950/40 rounded-lg p-3 flex flex-col justify-between">
                          <div className="space-y-1.5">
                            <span className="text-[9px] text-orange-400 font-bold uppercase font-mono block">Yapay Zeka Otonom Önerisi</span>
                            <p className="text-[10.5px] text-orange-200 leading-normal font-sans italic">
                              "{habitAdviceMessage}"
                            </p>
                          </div>

                          <div className="flex gap-2 pt-2 border-t border-orange-950/30 mt-2">
                            <button
                              onClick={() => {
                                setIsRefreshingHabits(true);
                                setHabitAdviceMessage("Amorfly AI OS otonom ajanları hareketleri inceliyor... Loglar çözümleniyor.");
                                setTimeout(() => {
                                  setTrackedActivitiesLog(prev => [
                                    { time: new Date().toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' }), action: 'Sistem önbellek temizleme tetiklendi', type: 'system' },
                                    ...prev
                                  ]);
                                  setHabitAdviceMessage("Tamamlandı: Önbellekler optimize edildi. Son etkinliklerinize göre sisteminizin yük derecesi 'Normal' seviyededir. Yerel çalıştığınız için gizliliğiniz tamamen güvence altındadır.");
                                  setIsRefreshingHabits(false);
                                }, 1200);
                              }}
                              disabled={isRefreshingHabits}
                              className="bg-orange-800/30 border border-orange-700/50 hover:bg-orange-850/50 text-orange-200 text-[10px] font-bold px-3 py-1.5 rounded transition-all cursor-pointer flex items-center gap-1.5 disabled:opacity-40"
                            >
                              <span>{isRefreshingHabits ? 'İnceleme Yenileniyor...' : 'Önerileri Yenile'}</span>
                            </button>

                            <button
                              onClick={() => {
                                alert("Otonom Aksiyon Tetiklendi: GPU cankurtaran modu ve önbellekler boşaltıldı.");
                              }}
                              className="bg-zinc-800 text-zinc-300 border border-zinc-700 text-[10px] hover:bg-zinc-700 px-3 py-1.5 rounded transition-all font-bold cursor-pointer"
                            >
                              Öneriyi Uygula (Uyumlu İyileştirme)
                            </button>
                          </div>
                        </div>
                      </div>
                    </div>
                  </div>
                </div>
              )}

              {/* 7. SECURITY SANDBOX & ENCRYPTION */}
              {activeModule === 'security' && (
                <div className="bg-[#121110] border border-[#242120] rounded-xl p-5 space-y-4">
                  <h4 className="text-[11px] uppercase tracking-wider font-extrabold text-emerald-400 font-mono">
                    Air-Gapped Güvenlik Düzeni & Donanımsal Şifreleme
                  </h4>
                  <p className="text-[11px] text-gray-400 leading-relaxed">
                    Sistem günlüklerinizi yerel AES (SQLCipher) tünelleri ile şifreleyin. Dışarıya veri sızmaması için Linux <b>UFW Firewall</b> kuralı devreye alınır ve sistem tam <b>Air-Gapped Offline Mod'a</b> geçer.
                  </p>

                  <div className="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div className="space-y-2">
                      <span className="text-[9.5px] text-gray-500 uppercase font-bold block font-mono">Veritabanı Şifreleme (SQLCipher Testi)</span>
                      <textarea
                        rows={2}
                        value={cryptoInput}
                        onChange={(e) => setCryptoInput(e.target.value)}
                        className="w-full bg-[#0a0707] border border-[#292625] rounded p-2 text-xs text-white"
                      />
                    </div>

                    <div className="space-y-2">
                      <span className="text-[9.5px] text-[#e95420] font-bold block font-mono">Şifrelenmiş Hex Çıktısı (encrypted.db)</span>
                      <div className="bg-[#050404] p-2 rounded text-[10px] text-gray-400 font-mono break-all border border-[#201d1c]">
                        {cryptoResult}
                      </div>
                    </div>
                  </div>

                  <div className="pt-2 border-t border-[#252220] flex items-center justify-between text-[11px] text-gray-400">
                    <span>UFW Dış Ağ Engelleme Kalkanı:</span>
                    <button
                      onClick={handleToggleTelemetry}
                      className={`px-3 py-1 rounded text-[10px] font-bold transition-all cursor-pointer ${
                        SecuritySandbox.isTelemetryBlocked()
                          ? 'bg-emerald-900/30 text-emerald-300 border border-emerald-800/40'
                          : 'bg-red-950 text-red-400 border border-red-900'
                      }`}
                    >
                      {SecuritySandbox.isTelemetryBlocked() ? 'TAM AIR-GAPPED (Aktif)' : 'İNTERNET (Açık)'}
                    </button>
                  </div>
                </div>
              )}

              {/* 8. USER PROFILE DB */}
              {activeModule === 'user_profile' && (
                <div className="bg-[#121110] border border-[#242120] rounded-xl p-5 space-y-4">
                  <h4 className="text-[11px] uppercase tracking-wider font-extrabold text-[#eab308] font-mono">
                    Yerel Kullanıcı Profili (SQLite / encrypted.db)
                  </h4>
                  <p className="text-[11px] text-gray-400 leading-relaxed">
                    Kişisel verileriniz ve AI Agent davranış öğrenimleri <b>sadece bilgisayarınızda barınır</b> (~/.local/share/amorfly/user_profile.db), hiçbir şekilde buluta aktarılmaz. Bu profil verisi, RAG (Retrieval-Augmented Generation) tavsiye motoru için kullanılır:
                  </p>
                  
                  {/* Mock JSON View representing SQLite DB fields */}
                  <div className="bg-[#0f0e0c] border border-[#2a2624] p-3.5 rounded-lg space-y-2 font-mono">
                    <pre className="text-[10px] text-yellow-500 overflow-x-auto leading-relaxed">
{`{
  "profile_id": "local-c8f2-airgapped",
  "preferred_languages": ["tr", "en"],
  "video_categories": ["tutorial", "documentary"],
  "avg_daily_usage_minutes": 45,
  "translation_speed_preference": "fast",
  "last_used_models": ["llama-3-8b", "whisper-tiny-cpp"]
}`}
                    </pre>
                  </div>

                  <div className="grid grid-cols-2 gap-3 pt-2">
                    <button className="bg-yellow-950/30 text-yellow-400 border border-yellow-800/40 text-[10.5px] font-bold py-2 rounded transition-colors hover:bg-yellow-900/40 cursor-pointer">
                      SQLCipher (Şifrelemeyi Test Et)
                    </button>
                    <button className="bg-red-950/30 text-red-400 border border-red-800/40 text-[10.5px] font-bold py-2 rounded transition-colors hover:bg-red-900/40 cursor-pointer">
                      Tüm Geçmişimi Sil
                    </button>
                  </div>
                </div>
              )}

              {/* 9. WINDOW & KEYBOARD SHORTCUTS */}
              {activeModule === 'ui' && (
                <div className="bg-[#121110] border border-[#242120] rounded-xl p-5 space-y-4">
                  <h4 className="text-[11px] uppercase tracking-wider font-extrabold text-indigo-400 font-mono">
                    Linux GNOME Pencere, Klavye & Kısayol Haritası
                  </h4>
                  <p className="text-[11px] text-gray-400 leading-relaxed">
                    Amorfly ana panelini hızlıca kontrol etmek, kapatıp açmak veya arka plana gizlemek için aşağıdaki yerel masaüstü GNOME kısayollarını kullanabilirsiniz:
                  </p>
                  <div className="grid grid-cols-2 gap-3 text-xs">
                    <div className="bg-[#171514] p-3 rounded-lg border border-[#2d2928] space-y-1">
                      <span className="text-[9.5px] text-gray-500 font-bold block font-mono">PANELİ ÖNE GETİR</span>
                      <kbd className="px-2 py-1 bg-zinc-900 text-gray-200 border border-zinc-700 rounded font-mono font-bold text-[10.5px]">Super + A</kbd>
                    </div>
                    <div className="bg-[#171514] p-3 rounded-lg border border-[#2d2928] space-y-1">
                      <span className="text-[9.5px] text-gray-500 font-bold block font-mono">HIZLI KAPAT / GİZLE</span>
                      <kbd className="px-2 py-1 bg-zinc-900 text-gray-200 border border-zinc-700 rounded font-mono font-bold text-[10.5px]">Super + Escape</kbd>
                    </div>
                  </div>
                </div>
              )}

              {/* 10. AMORFLY STORE & DIRECT CONTENT EXPORTER */}
              {activeModule === 'store' && (
                <div className="bg-[#121110] border border-[#242120] rounded-xl p-5 space-y-4">
                  
                  {/* Part A: Exporter */}
                  <div className="space-y-3 border-b border-[#252220] pb-5">
                    <h4 className="text-[11px] uppercase tracking-wider font-extrabold text-[#38bdf8] font-mono flex items-center gap-1.5">
                      <Sparkles className="w-3.5 h-3.5 text-cyan-400 animate-pulse" />
                      Yerel Belge Üretici &amp; Çoklu Rapor İhraç Merkezi (Excel, Word, PDF)
                    </h4>
                    <p className="text-[11px] text-gray-400 leading-relaxed">
                      Sohbetlerinizden ya da sistem donanım analizlerinizden elde ettiğiniz eylemleri anında yerel <b>LibreOffice / Microsoft-compatible</b> Excel (.xlsx), Word (.doc) veya PDF belgelerine dönüştürebilirsiniz:
                    </p>

                    <div className="grid grid-cols-1 md:grid-cols-2 gap-3 pt-1">
                      <div className="space-y-1.5 text-left">
                        <label className="text-[9.5px] text-gray-500 uppercase font-bold font-mono block">Belge Rapor Başlığı</label>
                        <input
                          type="text"
                          value={docTitle}
                          onChange={(e) => setDocTitle(e.target.value)}
                          className="w-full bg-[#0a0707] border border-[#292625] rounded p-2 text-xs text-white"
                          placeholder="Belge Başlığı Girin"
                        />
                      </div>
                      <div className="space-y-1.5 text-left">
                        <label className="text-[9.5px] text-gray-500 uppercase font-bold font-mono block">Özet Rapor Açıklaması</label>
                        <input
                          type="text"
                          value={docContent}
                          onChange={(e) => setDocContent(e.target.value)}
                          className="w-full bg-[#0a0707] border border-[#292625] rounded p-2 text-xs text-white"
                          placeholder="Rapora dahil edilecek ana gövde özeti..."
                        />
                      </div>
                    </div>

                    <div className="grid grid-cols-3 gap-2 pt-2 select-none">
                      <button
                        onClick={() => handleExportDocument('excel')}
                        disabled={exportingType !== null}
                        className="flex-1 text-xs py-2 bg-emerald-600/20 hover:bg-emerald-600/30 text-emerald-300 font-bold border border-emerald-500/30 rounded cursor-pointer transition-all disabled:opacity-40"
                      >
                        {exportingType === 'excel' ? 'Üretiliyor...' : 'EXCEL (.xlsx) İHRAÇ ET'}
                      </button>
                      <button
                        onClick={() => handleExportDocument('word')}
                        disabled={exportingType !== null}
                        className="flex-1 text-xs py-2 bg-cyan-600/20 hover:bg-cyan-600/30 text-cyan-300 font-bold border border-cyan-500/30 rounded cursor-pointer transition-all disabled:opacity-40"
                      >
                        {exportingType === 'word' ? 'Derleniyor...' : 'WORD (.doc) İHRAÇ ET'}
                      </button>
                      <button
                        onClick={() => handleExportDocument('pdf')}
                        disabled={exportingType !== null}
                        className="flex-1 text-xs py-2 bg-orange-600/20 hover:bg-orange-600/30 text-orange-300 font-bold border border-orange-500/30 rounded cursor-pointer transition-all disabled:opacity-40"
                      >
                        {exportingType === 'pdf' ? 'Yazdırılıyor...' : 'PDF RAPORU ÜRET'}
                      </button>
                    </div>

                    <p className="text-[10px] text-gray-500 italic mt-1 text-center">
                      *Tüm raporlar ve veri tabloları LibreOffice, Zorin OS yerel ofis setleri ve MS Office ile tam uyumlu formatlarda lokal Node motorumuzca anında derlenir.
                    </p>
                  </div>

                  {/* Part B: Store model options */}
                  <div className="space-y-3">
                    <h5 className="text-[10.5px] uppercase tracking-wider font-extrabold text-orange-400 font-mono flex items-center gap-1">
                      <ShoppingBag className="w-3.5 h-3.5 text-orange-400" />
                      Amorfly Hızlı Araç &amp; Eklenti İndirme Paneli
                    </h5>
                    <div className="grid grid-cols-1 md:grid-cols-2 gap-3 pt-1">
                      <div className="bg-[#181615] border border-[#2a2624] p-3 rounded-lg flex justify-between items-center">
                        <div className="space-y-1 text-left">
                          <span className="text-[11px] font-bold text-gray-200">Gelişmiş Veri Görselleştirme Modülü</span>
                          <span className="text-[9.5px] text-gray-500 block font-mono">D3.js integration adapter</span>
                        </div>
                        <span className="text-emerald-400 font-bold text-[10px] bg-emerald-950/20 px-2.5 py-1 rounded border border-emerald-900/30 font-mono">Hazır (Dahili)</span>
                      </div>
                      <div className="bg-[#181615] border border-[#2a2624] p-3 rounded-lg flex justify-between items-center">
                        <div className="space-y-1 text-left">
                          <span className="text-[11px] font-bold text-gray-200">Local OCR Resim Okuyucu</span>
                          <span className="text-[9.5px] text-gray-500 block font-mono">Tesseract Engine bind file</span>
                        </div>
                        <span className="text-emerald-400 font-bold text-[10px] bg-emerald-950/20 px-2.5 py-1 rounded border border-emerald-900/30 font-mono">Hazır (Dahili)</span>
                      </div>
                    </div>
                  </div>

                </div>
              )}

              {/* 11. DAEMON SYSTEMD EXTENSIONS */}
              {activeModule === 'extensions' && (
                <div className="bg-[#121110] border border-[#242120] rounded-xl p-5 space-y-4">
                  <h4 className="text-[11px] uppercase tracking-wider font-extrabold text-orange-400 font-mono">
                    Linux Systemd Arka Plan Servisleri & Daemons
                  </h4>
                  <p className="text-[11px] text-gray-400 leading-relaxed">
                    Uygulamayı her açılışta terminal gerektirmeden arka planda sessizce başlatmak için bu Systemd kullanıcı ünitesini etkinleştirin:
                  </p>

                  <div className="bg-[#1b1918] p-4 rounded-lg border border-[#2d2928] space-y-2">
                    <span className="text-[9.5px] text-gray-500 uppercase font-black font-mono block">Arka Plan Systemd Servis Dosyası (~/.config/systemd/user/amorfly.service)</span>
                    <pre className="text-[9.5px] bg-[#050404] p-3 rounded text-slate-400 overflow-x-auto border border-[#1e1c1b] whitespace-pre text-left leading-relaxed font-mono select-all">
{`[Unit]
Description=Amorfly AI Background Kernel Server
After=network.target

[Service]
Type=simple
WorkingDirectory=%h/AmorflyAI
ExecStart=/usr/bin/node dist/server.cjs
Restart=always
RestartSec=5
Environment=NODE_ENV=production PORT=3000

[Install]
WantedBy=default.target`}
                    </pre>

                    <button
                      onClick={() => handleCopy('systemctl --user enable amorfly.service && systemctl --user start amorfly.service', 'systemd_cmd')}
                      className="text-xxs px-3 py-1.5 bg-[#252221] hover:bg-[#322d2c] border border-[#3e3937] text-gray-300 font-bold rounded cursor-pointer transition-colors"
                    >
                      {copiedId === 'systemd_cmd' ? 'Servis Komutu Kopyalandı!' : 'Servisi Başlatma Komutunu Kopyala'}
                    </button>
                  </div>
                </div>
              )}

            </div>
          );
        })()}

        {/* Portable Setup Instructions Banner */}
        <div className="bg-[#1a1716] border border-[#2a2726] rounded-xl p-4 mt-6 text-slate-300 space-y-3">
          <div className="flex items-center gap-2">
            <AlertCircle className="w-4 h-4 text-orange-400 shrink-0" />
            <h5 className="text-[11px] font-bold text-gray-200 uppercase tracking-wider font-sans">
              Portatif Taşınabilirlik &amp; Kurulum Dokümantasyonu
            </h5>
          </div>
          <p className="text-[10.5px] leading-relaxed text-gray-400">
            Amorfly AI, <b>%100 portatiftir</b>. Bu kodu bilgisayarınıza zip dosyası olarak indirip; Node.js v20+ olan herhangi bir macOS, Windows ya da Linux bilgisayarda <code>npm run build && npm run start</code> yaparak anında çalıştırabilirsiniz. Yerel veritabanınız ve şifreli depolamanız bütünüyle yerel disk dizininde (<code>~/.amorfly</code>) saklanır.
          </p>
        </div>

      </div>
    </div>
  );
}
