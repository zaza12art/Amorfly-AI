interface FileContext {
  fileName: string;
  fileType: string;
  isImage: boolean;
  text: string;
  base64?: string;
  mimeType?: string;
  xlsxData?: { [key: string]: any[][] };
}

interface Message {
  id: string;
  role: 'user' | 'assistant';
  content: string;
  timestamp: string;
  attachedFile?: {
    fileName: string;
    fileType: string;
    isImage: boolean;
  };
}

interface SystemStatus {
  os: string;
  hostname: string;
  uptime: number;
  ram: {
    rss: string;
    heapUsed: string;
    heapTotal: string;
  };
  securityMode: string;
  activeLogs: Array<{
    timestamp: string;
    type: string;
    details: string;
    status: 'SUCCESS' | 'WARNING' | 'SECURE';
  }>;
}

interface ChatSession {
  id: string;
  title: string;
  timestamp: string;
  messages: Message[];
}

export default function App() {
  // Chat History & Sessions
  const [messages, setMessages] = useState<Message[]>([]);
  const [inputValue, setInputValue] = useState('');
  const [isGenerating, setIsGenerating] = useState(false);
  const [sessions, setSessions] = useState<ChatSession[]>([]);
  const [activeSessionId, setActiveSessionId] = useState<string>('session_default');
  const [showSessions, setShowSessions] = useState<boolean>(false);
  const [isDrawerOpen, setIsDrawerOpen] = useState<boolean>(true);

  // Configuration Switches
  const [onlineMode, setOnlineMode] = useState<boolean>(true);
  const [selectedModel, setSelectedModel] = useState<string>('gemini-3.5-flash');
  const [deepseekApiKey, setDeepseekApiKey] = useState<string>(() => localStorage.getItem('amorfly_deepseek_api_key') || '');

  // File Upload State
  const [uploadedFile, setUploadedFile] = useState<FileContext | null>(null);
  const [isUploading, setIsUploading] = useState(false);
  const [dragActive, setDragActive] = useState(false);
  const [activeExcelSheet, setActiveExcelSheet] = useState<string>('');
  
  // Voice Command Voice-to-Text Speech state
  const [isListeningSpeech, setIsListeningSpeech] = useState<boolean>(false);

  // VLC Multimedia Player states
  const [playerIsPlaying, setPlayerIsPlaying] = useState<boolean>(false);
  const [playerPlaybackRate, setPlayerPlaybackRate] = useState<number>(1.0);
  const [playerVolume, setPlayerVolume] = useState<number>(0.8);
  const [playerIsMuted, setPlayerIsMuted] = useState<boolean>(false);
  const [playerCurrentTime, setPlayerCurrentTime] = useState<number>(0);
  const [playerDuration, setPlayerDuration] = useState<number>(0);
  const [playerAspectRatio, setPlayerAspectRatio] = useState<string>('aspect-video');
  const [playerVisualFilter, setPlayerVisualFilter] = useState<string>('none');
  const [playerTrack, setPlayerTrack] = useState<{title: string, url: string, type: 'video' | 'audio', category?: string}>({
    title: "Sintel Açık Sinema Fragmanı (Action Animation)",
    url: "https://commondatastorage.googleapis.com/gtv-videos-bucket/sample/Sintel.mp4",
    type: "video",
    category: "Video"
  });
  const [playerSubtitleText, setPlayerSubtitleText] = useState<string | null>(null);
  const [playerEqBass, setPlayerEqBass] = useState<number>(65);
  const [playerEqMid, setPlayerEqMid] = useState<number>(45);
  const [playerEqTreble, setPlayerEqTreble] = useState<number>(55);
  const [playerCustomMediaList, setPlayerCustomMediaList] = useState<Array<{title: string, url: string, type: 'video' | 'audio', category: string}>>([]);

  // VLC Integration and up to 2 GB scanning/dubbing properties (v2.0)
  const [vlcLaunchingLocal, setVlcLaunchingLocal] = useState<boolean>(false);
  const [vlcLaunchDetails, setVlcLaunchDetails] = useState<string>('');
  const [selectedScanSizeGB, setSelectedScanSizeGB] = useState<number>(2.0); // Maximum 2 GB limit slider or preset
  const [isMediaProcessing2GB, setIsMediaProcessing2GB] = useState<boolean>(false);
  const [mediaProcessingProgress, setMediaProcessingProgress] = useState<number>(0);
  const [mediaProcessingStep, setMediaProcessingStep] = useState<string>('');
  const [selectedDubLang, setSelectedDubLang] = useState<string>('tr'); // 'tr' | 'en' | 'de' | 'es'
  const [selectedVoiceClone, setSelectedVoiceClone] = useState<boolean>(true);
  const [subtitleTranslationStyle, setSubtitleTranslationStyle] = useState<string>('dual'); // 'dual' | 'only-tr' | 'only-target'

  // User OS Behavioral Habit Analytics state
  const [osHabitSuggestion, setOsHabitSuggestion] = useState<{title: string, desc: string, actionLabel: string, cmd: string} | null>({
    title: "Yapay Zeka Isıl Algılayıcı Uyarısı (Yüksek CPU Yükü)",
    desc: "Yerel diskte video taraması ve render işlemi başlatılıyor. RAM şişmesini önlemek için VRAM Auto-Scaling özelliğini ve Vulkan donanım ivmesini açmanızı öneririz.",
    actionLabel: "Dinamik Modları Etkinleştir",
    cmd: "sysctl -w vm.drop_caches=3"
  });

  // VLC Player Dynamic AI Compilation States
  const [vlcCompilerPrompt, setVlcCompilerPrompt] = useState<string>('Bana cyberneon pembesi renklerinde, akıllı altyazı desteği olan, %200 ses artırma özellikli bir VLC alternatifi oynatıcı tasarla ve derle.');
  const [vlcCompiledTheme, setVlcCompiledTheme] = useState<string>('vlc-amber'); // 'vlc-amber' | 'cyber-pink' | 'matrix-green' | 'neon-blue'
  const [vlcCompiledEq, setVlcCompiledEq] = useState<boolean>(true);
  const [vlcCompiledSub, setVlcCompiledSub] = useState<boolean>(true);
  const [vlcCompiledEffect, setVlcCompiledEffect] = useState<boolean>(true);
  const [vlcIsCompiling, setVlcIsCompiling] = useState<boolean>(false);
  const [vlcCompilationLogs, setVlcCompilationLogs] = useState<string[]>([]);
  const [vlcHasCompiledBefore, setVlcHasCompiledBefore] = useState<boolean>(false);
  const [vlcCurrentStep, setVlcCurrentStep] = useState<number>(0);

  // UI Tabs / Screens
  const [activeTab, setActiveTab ] = useState<'chat' | 'terminal' | 'storage' | 'inspect' | 'distribution' | 'pipelines' | 'player'>('chat');
  
  // Advanced Integrated Orchestration Pipelines State (Multimedia & Engineering)
  const [pipelineMode, setPipelineMode] = useState<'multimedia' | 'engineering' | 'desktop'>('multimedia');
  
  // Multimedia pipeline states
  const [mediaFileName, setMediaFileName] = useState('film_kesiti_ingilizce.mp4');
  const [mediaSourceLang, setMediaSourceLang] = useState('en');
  const [mediaTargetLang, setMediaTargetLang] = useState('tr');
  const [mediaVoiceCloning, setMediaVoiceCloning] = useState(true);
  const [mediaEnhanceAudio, setMediaEnhanceAudio] = useState(true);
  const [mediaExecuting, setMediaExecuting] = useState(false);
  const [mediaCurrentStep, setMediaCurrentStep] = useState(0);
  const [mediaResultUrl, setMediaResultUrl] = useState('');
  const [mediaLogs, setMediaLogs] = useState<any[]>([]);

  // Engineering pipeline states
  const [engFileName, setEngFileName] = useState('zemin_kat_mimari_proje.dxf');
  const [engHeight, setEngHeight] = useState(3.00);
  const [engPriceCatalog, setEngPriceCatalog] = useState('csb');
  const [engExecuting, setEngExecuting] = useState(false);
  const [engCurrentStep, setEngCurrentStep] = useState(0);
  const [engLayers, setEngLayers] = useState<any[]>([]);
  const [engGrandTotal, setEngGrandTotal] = useState(0);
  const [engFinished, setEngFinished] = useState(false);
  const [engLogs, setEngLogs] = useState<string[]>([]);

  // Desktop Builder pipeline states
  const [desktopAppName, setDesktopAppName] = useState('Amorfly Desktop Suite Pro');
  const [desktopAppType, setDesktopAppType] = useState('engineering'); // 'engineering' or 'multimedia'
  const [desktopTargetOS, setDesktopTargetOS] = useState('linux'); // 'windows' or 'linux'
  const [desktopExecuting, setDesktopExecuting] = useState(false);
  const [desktopCurrentStep, setDesktopCurrentStep] = useState(0);
  const [desktopLogs, setDesktopLogs] = useState<string[]>([]);
  const [desktopPythonSource, setDesktopPythonSource] = useState('');
  const [desktopBashScript, setDesktopBashScript] = useState('');
  const [desktopDownloadUrl, setDesktopDownloadUrl] = useState('');
  const [desktopFinished, setDesktopFinished] = useState(false);
  const [distOS, setDistOS] = useState<'windows' | 'linux'>('windows');

  const [systemStatus, setSystemStatus] = useState<SystemStatus | null>(null);
  const [terminalCommand, setTerminalCommand] = useState('');
  const [terminalHistory, setTerminalHistory] = useState<Array<{ cmd: string; out: string; type: 'success' | 'system' | 'err' }>>([
    { cmd: 'system_init', out: 'Amorfly AI Core Sandbox v1.0.0 initialized on Ubuntu 24.04 Kernel 6.8.0-generic.', type: 'system' }
  ]);

  // Local OS Companion Integration & Smart Recommendations states
  interface CompanionStatus {
    success: boolean;
    habits: {
      timestamp: string;
      actionsCount: {
        automation: number;
        multimedia: number;
        document: number;
        ai_agent: number;
      };
      optimizationsApplied: number;
      lastOptimization: string | null;
    };
    totalActions: number;
    profile: {
      category: 'automation' | 'multimedia' | 'document' | 'ai_agent';
      label: string;
      description: string;
      distributionPercent: {
        automation: number;
        multimedia: number;
        document: number;
        ai_agent: number;
      };
    };
    system: {
      os: string;
      cores: number;
      totalRam: string;
      freeRam: string;
      ramLoadPercent: number;
      cpuPercent: number;
      dirSize: string;
      uptime: number;
      sandboxCompliance: string;
      isLocalServer: boolean;
    };
    recommendations: Array<{
      id: string;
      title: string;
      desc: string;
      difficulty: string;
      benefit: string;
      script: string;
    }>;
  }

  const [companionStatus, setCompanionStatus] = useState<CompanionStatus | null>(null);
  const [companionLoading, setCompanionLoading] = useState<boolean>(false);
  const [appliedRecommendations, setAppliedRecommendations] = useState<string[]>([]);

  const fetchCompanionStatus = async () => {
    setCompanionLoading(true);
    try {
      const res = await fetch('/api/companion-status');
      const data = await res.json();
      if (data.success) {
        setCompanionStatus(data);
      }
    } catch (e) {
      console.error('Error fetching companion status', e);
    } finally {
      setCompanionLoading(false);
    }
  };

  const trackAction = async (category: 'automation' | 'multimedia' | 'document' | 'ai_agent') => {
    try {
      const res = await fetch('/api/companion-track', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ category })
      });
      const data = await res.json();
      if (data.success) {
        // Fetch fresh metrics upon category increment
        const resFresh = await fetch('/api/companion-status');
        const dataFresh = await resFresh.json();
        if (dataFresh.success) {
          setCompanionStatus(dataFresh);
        }
      }
    } catch (e) {
      // Quiet ignore in offline modes
    }
  };

  // Immersive AI Desktop Environment state variables (11 Core Systems)
  const [activeCoreModule, setActiveCoreModule] = useState<string>('core');
  const [gpuStats, setGpuStats] = useState<GPUStats | null>(null);
  const [ollamaModels, setOllamaModels] = useState<AIModelSpec[]>(ModelMarketRegistry.getModelsList());
  const [pipelineTasks, setPipelineTasks] = useState<PipelineTask[]>(AutomationPipelineEngine.getPipelines());
  const [cryptoTestSecret, setCryptoTestSecret] = useState<string>('Amorfly Yerel Güvenli Siyah Kutu Veritabanı Girdisi');
  const [cryptoEncryptedText, setCryptoEncryptedText] = useState<string>('');
  const [cryptoSuccessMessage, setCryptoSuccessMessage] = useState<string>('');
  const [sandboxLogConsole, setSandboxLogConsole] = useState<string[]>([
    'Amorfly L3 Operating Kernel: Ready.',
    'No tracking flags: Ensured.',
    'Secure storage bound: ~/.amorfly encrypted block initialized.'
  ]);
  const [orchestratorModeState, setOrchestratorModeState] = useState<IsolationMode>('STRICT_OFFLINE');

  // Triggering background GPU query and core initialization on tab change
  useEffect(() => {
    const initOSModules = async () => {
      const stats = await GPUManager.queryGPUStats();
      setGpuStats(stats);
      setOrchestratorModeState(CoreOrchestrator.getMode());
      
      // Perform initial crypto dry run
      const crypted = SecuritySandbox.encryptLocalString(cryptoTestSecret);
      setCryptoEncryptedText(crypted);
    };
    initOSModules();
  }, []);

  // Recalculating crypto when test string changes
  useEffect(() => {
    if (cryptoTestSecret) {
      const encrypted = SecuritySandbox.encryptLocalString(cryptoTestSecret);
      setCryptoEncryptedText(encrypted);
    }
  }, [cryptoTestSecret]);

  // UI Feedback
  const [copiedId, setCopiedId] = useState<string | null>(null);
  const chatBottomRef = useRef<HTMLDivElement>(null);
  const terminalBottomRef = useRef<HTMLDivElement>(null);
  const playerVideoRef = useRef<HTMLVideoElement>(null);

  // Load chat sessions from localStorage on startup & always initialize with a clean fresh session
  useEffect(() => {
    const savedSessions = localStorage.getItem('amorfly_chat_sessions');
    let loadedSessions: ChatSession[] = [];
    if (savedSessions) {
      try {
        loadedSessions = JSON.parse(savedSessions);
      } catch (e) {
        console.error('Failed to parse chat sessions', e);
      }
    }

    // Always start with a BRAND NEW clean session on fresh load as requested:
    // "her açıldığında yeni chat sayfası halinde neden açılmıyor"
    const newId = 'session_' + Date.now();
    const welcome: Message[] = [
      {
        id: 'welcome_' + Date.now(),
        role: 'assistant',
        content: '### Merhaba, Ben Amorfly AI! 👋\n\nUbuntu işletim sisteminiz için özel olarak geliştirilmiş, yüksek korumalı ve çevrimdışı çalışabilen yapay zeka asistanıyım. \n\nYüklediğiniz **Excel**, **Word (docx)**, **PDF** ve **Resim** dosyalarını harici bir buluta aktarmadan kendi yerel arabelleğimde analiz eder, kod yazar ve sistem yönetim komutları üretebilirim.\n\n#### Neler Yapabiliriz?\n- 📄 **PDF / Word Okuma:** Dokümanlarınızı yükleyin, anında analiz yapalım.\n- 📊 **Excel Analizi:** Veri satırlarını filtreleyin, formüller hesaplayıp grafiksel çıktılar sorabilirsiniz.\n- 💻 **Güvenli Kodlama:** Bash, Python veya TypeScript kod şablonları geliştirebiliriz.\n- 🔒 **Sıfır Veri Aktarımı (Sıfır Sızıntı):** Çevrimdışı modu aktifleştirerek tüm işlemleri internet olmadan tamamen lokal yapabilirsiniz.\n\n*Sorunuzu aşağıdaki kutuya yazarak veya sol panelden bir dosya sürükleyerek hemen başlayabilirsiniz!*',
        timestamp: new Date().toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' })
      }
    ];

    const newSess: ChatSession = {
      id: newId,
      title: 'Karşılama Sohbeti',
      timestamp: new Date().toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' }),
      messages: welcome
    };

    // Filter out any other empty 'Karşılama Sohbeti' or 'Yeni Sohbet' sessions that have no user messages to avoid cluttering history
    const filteredLoadedSessions = loadedSessions.filter(s => {
      return s.messages && s.messages.some(m => m.role === 'user');
    });

    const finalSessions = [newSess, ...filteredLoadedSessions];
    setSessions(finalSessions);
    setActiveSessionId(newId);
    setMessages(welcome);

    localStorage.setItem('amorfly_active_session_id', newId);
    localStorage.setItem('amorfly_chat_sessions', JSON.stringify(finalSessions));
    localStorage.setItem('amorfly_chat_history', JSON.stringify(welcome));

    fetchSystemStatus();
    const interval = setInterval(fetchSystemStatus, 6000);
    return () => clearInterval(interval);
  }, []);

  // Save changes to localStorage whenever messages or active session changes
  useEffect(() => {
    if (messages.length > 0) {
      localStorage.setItem('amorfly_chat_history', JSON.stringify(messages));
      
      // Update the correct active session
      setSessions(prev => {
        const userMsg = messages.find(m => m.role === 'user');
        const firstMsg = userMsg ? userMsg.content : messages[0].content;
        const sessionTitle = firstMsg.slice(0, 35) + (firstMsg.length > 35 ? '...' : '');
        const cleanTitle = sessionTitle.replace(/[#*`\n]/g, ' ').trim() || 'Sohbet';

        const exists = prev.some(s => s.id === activeSessionId);
        let updated: ChatSession[];
        if (exists) {
          updated = prev.map(s => {
            if (s.id === activeSessionId) {
              return { ...s, messages, title: s.title === 'Karşılama Sohbeti' || s.title === 'Yeni Sohbet' ? cleanTitle : s.title };
            }
            return s;
          });
        } else {
          updated = [
            {
              id: activeSessionId,
              title: cleanTitle,
              timestamp: new Date().toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' }),
              messages
            },
            ...prev
          ];
        }
        localStorage.setItem('amorfly_chat_sessions', JSON.stringify(updated));
        return updated;
      });
    }
  }, [messages, activeSessionId]);

  // Automatic tracking of user habits depending on the active tab of Amorfly
  useEffect(() => {
    if (activeTab === 'player') {
      trackAction('multimedia');
    } else if (activeTab === 'terminal' || activeTab === 'pipelines') {
      trackAction('automation');
    } else if (activeTab === 'inspect' || activeTab === 'storage') {
      trackAction('document');
    } else if (activeTab === 'chat') {
      trackAction('ai_agent');
    } else if (activeTab === 'distribution') {
      fetchCompanionStatus();
      trackAction('automation');
    }
  }, [activeTab]);

  const selectSession = (id: string) => {
    const sess = sessions.find(s => s.id === id);
    if (sess) {
      setActiveSessionId(id);
      localStorage.setItem('amorfly_active_session_id', id);
      setMessages(sess.messages);
    }
  };

  const startNewSession = () => {
    const newId = 'session_' + Date.now();
    const newWelcome: Message[] = [
      {
        id: 'welcome_' + Date.now(),
        role: 'assistant',
        content: '### Yeni Sohbet Başlatıldı 🌟\n\nUbuntu çevrimdışı işlem haznesi sıfırlandı. Yeni konu veya projenizi sorarak başlayın.',
        timestamp: new Date().toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' })
      }
    ];
    
    const newSess: ChatSession = {
      id: newId,
      title: 'Yeni Sohbet',
      timestamp: new Date().toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' }),
      messages: newWelcome
    };

    setSessions(prev => {
      const updated = [newSess, ...prev];
      localStorage.setItem('amorfly_chat_sessions', JSON.stringify(updated));
      return updated;
    });

    setActiveSessionId(newId);
    localStorage.setItem('amorfly_active_session_id', newId);
    setMessages(newWelcome);
  };

  const deleteSession = (id: string, e: React.MouseEvent) => {
    e.stopPropagation();
    e.preventDefault();
    
    const updated = sessions.filter(s => s.id !== id);
    setSessions(updated);
    localStorage.setItem('amorfly_chat_sessions', JSON.stringify(updated));

    if (id === activeSessionId) {
      if (updated.length > 0) {
        selectSession(updated[0].id);
      } else {
        const newId = 'session_fresh';
        const freshWelcome: Message[] = [
          {
            id: 'welcome_fresh',
            role: 'assistant',
            content: '### Merhaba, Sorunuz Nedir? 👋\nTüm geçmiş silindi, yeni sorunuzu yöneltebilirsiniz.',
            timestamp: new Date().toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' })
          }
        ];
        const freshSess: ChatSession = {
          id: newId,
          title: 'Yeni Sohbet',
          timestamp: new Date().toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' }),
          messages: freshWelcome
        };
        setSessions([freshSess]);
        setActiveSessionId(newId);
        localStorage.setItem('amorfly_active_session_id', newId);
        setMessages(freshWelcome);
      }
    }
  };

  // Automatic scroll to bottom for chat and terminal
  useEffect(() => {
    chatBottomRef.current?.scrollIntoView({ behavior: 'smooth' });
  }, [messages, isGenerating]);

  useEffect(() => {
    terminalBottomRef.current?.scrollIntoView({ behavior: 'smooth' });
  }, [terminalHistory]);

  // Sync VLC Multimedia Player state (volume, playback rate, muted status) with the actual media element ref
  useEffect(() => {
    const media = playerVideoRef.current;
    if (media) {
      try {
        media.volume = playerIsMuted ? 0 : playerVolume;
        media.playbackRate = playerPlaybackRate;
        media.muted = playerIsMuted;
      } catch (e) {
        console.error("Failed to sync media control states", e);
      }
    }
  }, [playerVolume, playerPlaybackRate, playerIsMuted, playerTrack]);

  const fetchSystemStatus = async () => {
    try {
      const res = await fetch('/api/system-status');
      if (res.ok) {
        const data = await res.json();
        setSystemStatus(data);
      }
    } catch (e) {
      console.error('System API status fetch error', e);
    }
  };

  const handleCopy = (text: string, id: string) => {
    navigator.clipboard.writeText(text);
    setCopiedId(id);
    setTimeout(() => setCopiedId(null), 1800);
  };

  const exportMessageToExcel = async (content: string, title = "Amorfly-Analiz") => {
    try {
      const lines = content.split('\n');
      let headers: string[] = [];
      const rows: any[] = [];
      let parsingTable = false;

      for (const line of lines) {
        const trimmed = line.trim();
        if (trimmed.startsWith('|') && trimmed.endsWith('|')) {
          const columns = trimmed.split('|').map(c => c.trim()).filter((_, i, arr) => i > 0 && i < arr.length - 1);
          if (!parsingTable) {
            headers = columns;
            parsingTable = true;
          } else {
            if (columns.every(col => col.startsWith('---') || col.startsWith(':---') || col.endsWith('---'))) {
              continue;
            }
            const item: any = {};
            headers.forEach((header, colIdx) => {
              item[header || `Sütun ${colIdx + 1}`] = columns[colIdx] || "";
            });
            rows.push(item);
          }
        }
      }

      if (rows.length === 0) {
        lines.forEach((l, idx) => {
          const text = l.trim();
          if (text) {
            if (text.startsWith('- ') || text.startsWith('* ')) {
              rows.push({ "Açıklama": text.replace(/^[\-\*]\s+/, '') });
            } else if (/^\d+\.\s/.test(text)) {
              rows.push({ "No": text.match(/^\d+/)?.[0] || String(idx), "Açıklama": text.replace(/^\d+\.\s+/, '') });
            } else if (!text.startsWith('|')) {
              rows.push({ "İçerik": text });
            }
          }
        });
      }

      const response = await fetch('/api/export/excel', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ title, rows })
      });

      if (response.ok) {
        const blob = await response.blob();
        const url = window.URL.createObjectURL(blob);
        const a = document.createElement('a');
        a.href = url;
        a.download = `${title.toLowerCase().replace(/\s+/g, '-')}-${Date.now()}.xlsx`;
        document.body.appendChild(a);
        a.click();
        document.body.removeChild(a);
        window.URL.revokeObjectURL(url);
      }
    } catch (err) {
      console.error("Excel dışarı aktarma hatası:", err);
    }
  };

  const exportMessageToWord = async (content: string, title = "Amorfly-Rapor") => {
    try {
      const escapeHtmlHelper = (text: string) => {
        return text
          .replace(/&/g, "&amp;")
          .replace(/</g, "&lt;")
          .replace(/>/g, "&gt;")
          .replace(/"/g, "&quot;")
          .replace(/'/g, "&#039;");
      };

      let htmlContent = "";
      const lines = content.split('\n');
      let insideList = false;

      lines.forEach(line => {
        const trimmed = line.trim();
        if (!trimmed) {
          if (insideList) {
            htmlContent += "</ul>";
            insideList = false;
          }
          return;
        }

        if (trimmed.startsWith('### ')) {
          if (insideList) { htmlContent += "</ul>"; insideList = false; }
          htmlContent += `<h3 style="color:#0ea5e9; font-size:16px; margin-top:15px; margin-bottom:5px; font-family:sans-serif;">${escapeHtmlHelper(trimmed.replace('### ', ''))}</h3>`;
        } else if (trimmed.startsWith('## ')) {
          if (insideList) { htmlContent += "</ul>"; insideList = false; }
          htmlContent += `<h2 style="color:#1d4ed8; font-size:18px; margin-top:20px; margin-bottom:8px; font-family:sans-serif; border-bottom:1px solid #ddd; padding-bottom:3px;">${escapeHtmlHelper(trimmed.replace('## ', ''))}</h2>`;
        } else if (trimmed.startsWith('# ')) {
          if (insideList) { htmlContent += "</ul>"; insideList = false; }
          htmlContent += `<h1 style="color:#e95420; font-size:22px; margin-top:25px; margin-bottom:10px; font-family:sans-serif;">${escapeHtmlHelper(trimmed.replace('# ', ''))}</h1>`;
        } else if (trimmed.startsWith('- ') || trimmed.startsWith('* ')) {
          if (!insideList) {
            htmlContent += `<ul style="margin: 5px 0 10px 20px; padding:0;">`;
            insideList = true;
          }
          htmlContent += `<li style="font-size:12px; font-family:sans-serif; color:#374151; margin-bottom:3px;">${escapeHtmlHelper(trimmed.replace(/^[\-\*]\s+/, ''))}</li>`;
        } else if (/^\d+\.\s/.test(trimmed)) {
          if (insideList) { htmlContent += "</ul>"; insideList = false; }
          htmlContent += `<p style="font-size:12px; font-family:sans-serif; color:#374151; margin-left:15px; margin-top:4px; margin-bottom:4px;"><b>${trimmed.match(/^\d+\./)?.[0] || ""}</b> ${escapeHtmlHelper(trimmed.replace(/^\d+\.\s+/, ''))}</p>`;
        } else if (trimmed.startsWith('|') && trimmed.endsWith('|')) {
          if (insideList) { htmlContent += "</ul>"; insideList = false; }
          const isDivider = trimmed.split('|').map(c => c.trim()).filter((_, i, arr) => i > 0 && i < arr.length - 1).every(col => col.startsWith('---') || col.startsWith(':---') || col.endsWith('---'));
          if (!isDivider) {
            const cells = trimmed.split('|').map(c => c.trim()).filter((_, i, arr) => i > 0 && i < arr.length - 1);
            htmlContent += `<table border="1" cellpadding="5" cellspacing="0" style="border-collapse:collapse; font-size:11px; font-family:sans-serif; margin:10px 0; width:100%;"><tr>`;
            cells.forEach(cell => {
              htmlContent += `<td style="border:1px solid #ccc; background:#f3f4f6;">${escapeHtmlHelper(cell)}</td>`;
            });
            htmlContent += `</tr></table>`;
          }
        } else {
          if (insideList) { htmlContent += "</ul>"; insideList = false; }
          let formattedLine = escapeHtmlHelper(trimmed);
          formattedLine = formattedLine.replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>');
          formattedLine = formattedLine.replace(/\*(.*?)\*/g, '<em>$1</em>');
          htmlContent += `<p style="font-size:12px; font-family:sans-serif; color:#374151; line-height:1.5; margin-bottom:8px;">${formattedLine}</p>`;
        }
      });

      if (insideList) { htmlContent += "</ul>"; }

      const response = await fetch('/api/export/word', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ title, content: htmlContent })
      });

      if (response.ok) {
        const blob = await response.blob();
        const url = window.URL.createObjectURL(blob);
        const a = document.createElement('a');
        a.href = url;
        a.download = `${title.toLowerCase().replace(/\s+/g, '-')}-${Date.now()}.doc`;
        document.body.appendChild(a);
        a.click();
        document.body.removeChild(a);
        window.URL.revokeObjectURL(url);
      }
    } catch (err) {
      console.error("Word dışarı aktarma hatası:", err);
    }
  };

  const exportMessageToPdf = (content: string, title = "Amorfly-Rapor") => {
    try {
      const escapeHtmlHelper = (text: string) => {
        return text
          .replace(/&/g, "&amp;")
          .replace(/</g, "&lt;")
          .replace(/>/g, "&gt;")
          .replace(/"/g, "&quot;")
          .replace(/'/g, "&#039;");
      };

      let htmlContent = "";
      const lines = content.split('\n');
      let insideList = false;

      lines.forEach(line => {
        const trimmed = line.trim();
        if (!trimmed) {
          if (insideList) {
            htmlContent += "</ul>";
            insideList = false;
          }
          return;
        }

        if (trimmed.startsWith('### ')) {
          if (insideList) { htmlContent += "</ul>"; insideList = false; }
          htmlContent += `<h3 style="color:#0284c7; font-size:18px; margin-top:20px; margin-bottom:8px; font-family:-apple-system, sans-serif;">${escapeHtmlHelper(trimmed.replace('### ', ''))}</h3>`;
        } else if (trimmed.startsWith('## ')) {
          if (insideList) { htmlContent += "</ul>"; insideList = false; }
          htmlContent += `<h2 style="color:#0f172a; font-size:20px; margin-top:24px; margin-bottom:10px; font-family:-apple-system, sans-serif; border-bottom:1px solid #e2e8f0; padding-bottom:4px;">${escapeHtmlHelper(trimmed.replace('## ', ''))}</h2>`;
        } else if (trimmed.startsWith('# ')) {
          if (insideList) { htmlContent += "</ul>"; insideList = false; }
          htmlContent += `<h1 style="color:#ea580c; font-size:24px; margin-top:30px; margin-bottom:12px; font-family:-apple-system, sans-serif;">${escapeHtmlHelper(trimmed.replace('# ', ''))}</h1>`;
        } else if (trimmed.startsWith('- ') || trimmed.startsWith('* ')) {
          if (!insideList) {
            htmlContent += `<ul style="margin: 6px 0 12px 24px; padding:0; list-style-type:disc;">`;
            insideList = true;
          }
          htmlContent += `<li style="font-size:14px; font-family:-apple-system, sans-serif; color:#334155; margin-bottom:4px;">${escapeHtmlHelper(trimmed.replace(/^[\-\*]\s+/, ''))}</li>`;
        } else if (/^\d+\.\s/.test(trimmed)) {
          if (insideList) { htmlContent += "</ul>"; insideList = false; }
          htmlContent += `<p style="font-size:14px; font-family:-apple-system, sans-serif; color:#334155; margin-left:15px; margin-top:6px; margin-bottom:6px;"><b>${trimmed.match(/^\d+\./)?.[0] || ""}</b> ${escapeHtmlHelper(trimmed.replace(/^\d+\.\s+/, ''))}</p>`;
        } else if (trimmed.startsWith('|') && trimmed.endsWith('|')) {
          if (insideList) { htmlContent += "</ul>"; insideList = false; }
          const isDivider = trimmed.split('|').map(c => c.trim()).filter((_, i, arr) => i > 0 && i < arr.length - 1).every(col => col.startsWith('---') || col.startsWith(':---') || col.endsWith('---'));
          if (!isDivider) {
            const cells = trimmed.split('|').map(c => c.trim()).filter((_, i, arr) => i > 0 && i < arr.length - 1);
            htmlContent += `<table border="1" cellpadding="8" cellspacing="0" style="border-collapse:collapse; font-size:12.5px; font-family:-apple-system, sans-serif; margin:12px 0; width:100%; border:1px solid #cbd5e1;"><tr>`;
            cells.forEach(cell => {
              htmlContent += `<td style="border:1px solid #cbd5e1; background:#f8fafc; color:#1e293b;">${escapeHtmlHelper(cell)}</td>`;
            });
            htmlContent += `</tr></table>`;
          }
        } else {
          if (insideList) { htmlContent += "</ul>"; insideList = false; }
          let formattedLine = escapeHtmlHelper(trimmed);
          formattedLine = formattedLine.replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>');
          formattedLine = formattedLine.replace(/\*(.*?)\*/g, '<em>$1</em>');
          htmlContent += `<p style="font-size:14px; font-family:-apple-system, sans-serif; color:#334155; line-height:1.6; margin-bottom:10px;">${formattedLine}</p>`;
        }
      });

      if (insideList) { htmlContent += "</ul>"; }

      const form = document.createElement("form");
      form.setAttribute("method", "POST");
      form.setAttribute("action", "/api/export/pdf");
      form.setAttribute("target", "_blank");

      const inputTitle = document.createElement("input");
      inputTitle.type = "hidden";
      inputTitle.name = "title";
      inputTitle.value = title;
      form.appendChild(inputTitle);

      const inputContent = document.createElement("input");
      inputContent.type = "hidden";
      inputContent.name = "content";
      inputContent.value = htmlContent;
      form.appendChild(inputContent);

      document.body.appendChild(form);
      form.submit();
      document.body.removeChild(form);
    } catch (err) {
      console.error("PDF dışarı aktarma hatası:", err);
    }
  };

  // Drag handlings
  const handleDrag = (e: React.DragEvent) => {
    e.preventDefault();
    e.stopPropagation();
    if (e.type === "dragenter" || e.type === "dragover") {
      setDragActive(true);
    } else if (e.type === "dragleave") {
      setDragActive(false);
    }
  };

  const handleDrop = (e: React.DragEvent) => {
    e.preventDefault();
    e.stopPropagation();
    setDragActive(false);
    if (e.dataTransfer.files && e.dataTransfer.files[0]) {
      uploadFile(e.dataTransfer.files[0]);
    }
  };

  const handleFileChange = (e: React.ChangeEvent<HTMLInputElement>) => {
    if (e.target.files && e.target.files[0]) {
      uploadFile(e.target.files[0]);
    }
  };

  // Upload and parse documents server-side
  const uploadFile = async (file: File) => {
    setIsUploading(true);
    const formData = new FormData();
    formData.append('file', file);

    try {
      const res = await fetch('/api/parse-file', {
        method: 'POST',
        body: formData
      });

      if (!res.ok) throw new Error('File parse request failure');
      const data = await res.json();

      if (data.success) {
        setUploadedFile({
          fileName: data.fileName,
          fileType: data.fileType,
          isImage: !!data.isImage,
          text: data.text,
          base64: data.base64,
          mimeType: data.mimeType,
          xlsxData: data.xlsxData
        });

        // Set active sheet automatically if it is excel
        if (data.xlsxData) {
          const sheets = Object.keys(data.xlsxData);
          if (sheets.length > 0) {
            setActiveExcelSheet(sheets[0]);
          }
        }
        
        // Open file inspector tab automatically to display tables
        setActiveTab('inspect');

        // Append log to terminal history
        setTerminalHistory(prev => [
          ...prev,
          {
            cmd: `mount ${file.name}`,
            out: `Masaüstü dosya ayrıştırma başarılı. Format: ${data.fileType}. İndekslenen bellek: ${data.text ? data.text.length : 0} karakter.`,
            type: 'success'
          }
        ]);

        fetchSystemStatus();
      } else {
        alert('Dosya yükleme/ayrıştırma başarısız oldu: ' + data.error);
      }
    } catch (error: any) {
      console.error(error);
      alert('Hata olustu: ' + error.message);
    } finally {
      setIsUploading(false);
    }
  };

  const clearUploadedFile = () => {
    setUploadedFile(null);
    setActiveExcelSheet('');
    setTerminalHistory(prev => [
      ...prev,
      { cmd: 'unmount_file', out: 'Dosya sanal arabellekten kaldırıldı.', type: 'system' }
    ]);
  };

  // Toggle voice command assistant helper
  const handleToggleVoiceCommand = () => {
    const SpeechRecognition = (window as any).SpeechRecognition || (window as any).webkitSpeechRecognition;
    if (!SpeechRecognition) {
      alert("Tarayıcınızda Web Speech API (Ses Tanıma) yerel olarak desteklenmiyor. Demo modunda mikrofon simülasyonu başlatılıyor...");
      setIsListeningSpeech(true);
      setTimeout(() => {
        setInputValue(prev => prev ? prev + " Amorfly AI, otonom sistem ve donanım analizlerini yenile." : "Amorfly AI, otonom sistem ve donanım analizlerini yenile.");
        setIsListeningSpeech(false);
      }, 1800);
      return;
    }

    if (isListeningSpeech) {
      setIsListeningSpeech(false);
      return;
    }

    try {
      const recognition = new SpeechRecognition();
      recognition.lang = 'tr-TR';
      recognition.interimResults = false;
      recognition.maxAlternatives = 1;

      recognition.onstart = () => {
        setIsListeningSpeech(true);
      };

      recognition.onresult = (event: any) => {
        const speechToText = event.results[0][0].transcript;
        if (speechToText) {
          setInputValue(prev => prev ? prev + " " + speechToText : speechToText);
        }
      };

      recognition.onerror = (event: any) => {
        console.warn("Speech recognition error:", event.error);
        setIsListeningSpeech(false);
        let errorMsg = `Ses tanıma hatası: ${event.error}`;
        if (event.error === 'not-allowed') {
          errorMsg = "HATA: Mikrofon erişim izni verilmedi. Lütfen tarayıcınızın adres çubuğundaki kilit (güvenlik) simgesine tıklayarak mikrofon iznine izin verin, ardından sayfayı yenileyerek tekrar deneyin. Alternatif olarak, uygulamayı sağ üstteki 'Yeni Sekmede Aç' butonuyla tam ekran çalıştırabilirsiniz.";
        } else if (event.error === 'network') {
          errorMsg = "HATA: Çevrimiçi ses tanıma için internet bağlantısı kesildi veya sunucuya erişilemiyor.";
        } else if (event.error === 'no-speech') {
          errorMsg = "UYARI: Herhangi bir konuşma sesi algılanamadı. Lütfen mikrofonunuzu kontrol edin.";
        }
        setTerminalHistory(prev => [
          ...prev,
          { cmd: 'sys_microphone_error', out: errorMsg, type: 'err' }
        ]);
      };

      recognition.onend = () => {
        setIsListeningSpeech(false);
      };

      recognition.start();
    } catch (e) {
      console.error("Speech Recognition starting error:", e);
      setIsListeningSpeech(false);
    }
  };

  // Chat message send handler
  const handleSendMessage = async (e?: React.FormEvent) => {
    if (e) e.preventDefault();
    if (!inputValue.trim() && !uploadedFile) return;

    const messageContent = inputValue;
    setInputValue('');

    const userMsg: Message = {
      id: `usr_${Date.now()}`,
      role: 'user',
      content: messageContent || `Lütfen yüklenen belgeyi analiz et: ${uploadedFile?.fileName}`,
      timestamp: new Date().toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' }),
      attachedFile: uploadedFile ? {
        fileName: uploadedFile.fileName,
        fileType: uploadedFile.fileType,
        isImage: uploadedFile.isImage
      } : undefined
    };

    setMessages(prev => [...prev, userMsg]);
    setIsGenerating(true);

    try {
      // Gather active messages context to send
      const trace = messages.concat(userMsg).map(m => ({
        role: m.role,
        content: m.content,
        image: m.id === userMsg.id && uploadedFile?.isImage ? uploadedFile.base64 : undefined,
        mimeType: m.id === userMsg.id && uploadedFile?.isImage ? uploadedFile.mimeType : undefined
      }));

      const payload = {
        messages: trace,
        onlineMode: onlineMode,
        selectedModel: selectedModel,
        deepseekApiKey: deepseekApiKey,
        fileContext: uploadedFile && !uploadedFile.isImage ? {
          fileName: uploadedFile.fileName,
          fileType: uploadedFile.fileType,
          text: uploadedFile.text
        } : null
      };

      const res = await fetch('/api/chat', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload)
      });

      if (!res.ok) {
        throw new Error('Analiz motoru bir hata döndürdü.');
      }

      const data = await res.json();
      
      const assistantMsg: Message = {
        id: `asst_${Date.now()}`,
        role: 'assistant',
        content: data.text,
        timestamp: new Date().toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' })
      };

      setMessages(prev => [...prev, assistantMsg]);
      fetchSystemStatus();

    } catch (err: any) {
      setMessages(prev => [
        ...prev,
        {
          id: `err_${Date.now()}`,
          role: 'assistant',
          content: `⚠️ **Bağlantı Hatası:** ${err.message || 'Lokal yapay zeka servisine erişilemedi.'}\n\nLütfen sağ üstteki online/offline durumunu veya ağ yapılandırmanızı kontrol edip tekrar deneyin.`,
          timestamp: new Date().toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' })
        }
      ]);
    } finally {
      setIsGenerating(false);
    }
  };

  // Simulated Terminal Shell executor
  const handleTerminalSubmit = (e: React.FormEvent) => {
    e.preventDefault();
    if (!terminalCommand.trim()) return;

    const cmd = terminalCommand.trim();
    let out = '';
    let type: 'success' | 'err' | 'system' = 'success';

    if (cmd === 'clear') {
      setTerminalHistory([]);
      setTerminalCommand('');
      return;
    }

    if (cmd === 'help') {
      out = 'Kullanılabilir Komutlar:\n' +
        '  sys-info         - Ubuntu Kerneli ve bellek kullanımları\n' +
        '  file-status      - Yerel arabelleğe mount edilen dokümanın detayı\n' +
        '  security-check   - Ağ kalkanı ve sıfır sızıntı doğrulama testi\n' +
        '  clean-history    - Chat oturum belleğini tamamen kalıcı siler\n' +
        '  logs             - Çekirdek güvenlik loglarını anlık dökümler\n' +
        '  clear            - Konsolu temizler';
      type = 'system';
    } else if (cmd === 'sys-info') {
      out = `SİSTEM: Ubuntu 24.04 LTS (Hücresel Güvenli Enstrüman)\nMODEL: Amorfly AI Secure Kernel\nHOST: core-sandbox\nRAM RSS: ${systemStatus?.ram.rss || 'N/A'}\nUPTIME: ${Math.round(systemStatus?.uptime || 0)} saniye\nGÜVENLİK MODU: Sıkı Algoritma Denetimi (Zero-Leakage active)`;
    } else if (cmd === 'file-status') {
      if (uploadedFile) {
        out = `DOKÜMAN TANIMI: ${uploadedFile.fileName}\nUZANTI: ${uploadedFile.fileType}\nBoyut Karakter: ${uploadedFile.text.length} karakter\nExcel Verisi: ${uploadedFile.xlsxData ? 'MEVCUT (Okunabilir)' : 'Hayır'}\nGörsel Modu: ${uploadedFile.isImage ? 'AÇIK (Base64)' : 'KAPALI'}`;
      } else {
        out = 'Arabellekte mount edilmiş herhangi bir doküman bulunamadı. Lütfen sürükleyip bırakarak yükleyin.';
        type = 'err';
      }
    } else if (cmd === 'securityCheck' || cmd === 'security-check') {
      out = '🔒 AMORFLY SECUR-KERNEL SECURITY REPORT:\n' +
        '--------------------------------------------\n' +
        '[PASS] Harici API Sızıntısı: Engellendi (Zero external analytic trackers)\n' +
        '[PASS] Kılavuz Hücresi: Şifreli (LocalStorage limits validated)\n' +
        '[PASS] Doküman Ayrıştırma: İzole Bellek (Server Memory Sandbox active)\n' +
        '--------------------------------------------\n' +
        'YAPAY ZEKA VERİ GÜVENLİĞİ: MAKSİMUM SEVİYEDEKİ SIZDIRMAZ YAPI AKTİFTİR.';
    } else if (cmd === 'clean-history') {
      localStorage.removeItem('amorfly_chat_history');
      setMessages([
        {
          id: 'system_wipe',
          role: 'assistant',
          content: '🧹 Chat geçmişi yerel bellekten tamamen silindi.',
          timestamp: new Date().toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' })
        }
      ]);
      out = 'Sanal disk arabelleği ve sohbet logları localStorage üzerinden kalıcı şekilde sıfırlandı.';
    } else if (cmd === 'logs') {
      if (systemStatus?.activeLogs) {
        out = systemStatus.activeLogs.map(l => `[${l.timestamp.substring(11, 19)}] [${l.status}] ${l.type}: ${l.details}`).join('\n');
      } else {
        out = 'Log havuzu yükleniyor...';
      }
    } else {
      out = `bash: komut bulunamadı: ${cmd}. Yardım ve kullanılabilir komut listesi için 'help' yazın.`;
      type = 'err';
    }

    setTerminalHistory(prev => [...prev, { cmd, out, type }]);
    setTerminalCommand('');
  };

  // ==============================================================================
  //                 AMORFLY PIPELINE EXECUTIVE CONTROL ENGINES
  // ==============================================================================

  const handleRunMultimediaPipeline = async () => {
    if (mediaExecuting) return;
    setMediaExecuting(true);
    setMediaResultUrl('');
    setMediaCurrentStep(1);
    setMediaLogs([{ step: 1, text: 'Meta Demucs (v4) motoru yüklendi. Ses akışı ayrıştırılıyor...' }]);
    
    const steps = [
      { step: 1, text: 'Meta Demucs (v4) - [TAMAMLANDI]: vocal.wav (insan sesi) ve no_vocal.wav (arka plan müzik/efekt) başarıyla izole edildi.' },
      { step: 2, text: 'WhisperX - [TAMAMLANDI]: Fonetik dil hizalaması gerçekleştirildi. Zaman damgalı kelime indeksleri sentezlendi.' },
      { step: 3, text: 'Gemini 3.5 Core - [TAMAMLANDI]: Hedef dildeki dublaj metni, konuşma süresi (sn) adaptasyonuna göre ölçeklendi.' },
      { step: 4, text: 'F5-TTS Voice Cloner - [TAMAMLANDI]: 5 sn vocal.wav kesitinden ses karakteristiği klonlanarak yeni dilde seslendirildi.' },
      { step: 5, text: 'LatentSync HD - [TAMAMLANDI]: Dudak senkronizasyonu pikselsel olarak yeniden çizildi.' },
      { step: 6, text: 'FFmpeg Core - [TAMAMLANDI]: Klonlanmış dublaj, no_vocal.wav müziği ve revize dudak hareketli video senkronize birleştirildi.' }
    ];

    for (let i = 0; i < steps.length; i++) {
      await new Promise(resolve => setTimeout(resolve, 1200));
      setMediaCurrentStep(i + 2);
      setMediaLogs(prev => [...prev, { step: i + 1, text: steps[i].text }]);
      
      // Log to system statuses
      setSystemStatus(prev => {
        if (!prev) return prev;
        return {
          ...prev,
          activeLogs: [
            { timestamp: new Date().toISOString(), type: 'MULTIMEDIA_PIPELINE', details: steps[i].text, status: 'SUCCESS' },
            ...prev.activeLogs
          ]
        } as any;
      });
    }

    try {
      const response = await fetch('/api/pipeline/multimedia', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          fileName: mediaFileName,
          sourceLang: mediaSourceLang,
          targetLang: mediaTargetLang,
          voiceCloning: mediaVoiceCloning,
          enhanceAudio: mediaEnhanceAudio
        })
      });
      const data = await response.json();
      if (data.success) {
        setMediaResultUrl(data.resultUrl);
      }
    } catch (e) {
      console.error(e);
    }
    setMediaExecuting(false);
  };

  const handleRunEngineeringPipeline = async () => {
    if (engExecuting) return;
    setEngExecuting(true);
    setEngFinished(false);
    setEngCurrentStep(1);
    setEngLogs(['OdaFileConverter: DWG/DXF çevrimi başlatılıyor...']);
    
    const steps = [
      'OdaFileConverter: DWG formatı hızlıca açık kaynak .dxf formatına dönüştürüldü.',
      'ezdxf & OpenConstructionERP: layers, polylines ve geometrik uzunluk/alan verileri başarıyla indekslendi.',
      'QuantityTakeoff-Python: Çizimdeki "Duvar_30", "Beton_Temel_C25" geometrik verilerinden metraj çıkartıldı.',
      'Gemini 3.5: Ham metraj isimleri resmi ÇŞB poz kataloğu ve birim fiyatlarıyla semantik eşleştirildi.',
      'Pandas & OpenPyXL: Excel (.xlsx) Keşif Özeti formül yapısı ve hücresel şablonu başarıyla hazırlandı.'
    ];

    for (let i = 0; i < steps.length; i++) {
      await new Promise(resolve => setTimeout(resolve, 1100));
      setEngCurrentStep(i + 2);
      setEngLogs(prev => [...prev, steps[i]]);
      
      setSystemStatus(prev => {
        if (!prev) return prev;
        return {
          ...prev,
          activeLogs: [
            { timestamp: new Date().toISOString(), type: 'ENGINEERING_PIPELINE', details: steps[i], status: 'SUCCESS' },
            ...prev.activeLogs
          ]
        } as any;
      });
    }

    try {
      const response = await fetch('/api/pipeline/engineering', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          fileName: uploadedFile ? uploadedFile.fileName : engFileName,
          baseHeight: engHeight,
          priceCatalog: engPriceCatalog
        })
      });
      const data = await response.json();
      if (data.success) {
        setEngLayers(data.layers);
        setEngGrandTotal(data.grandTotal);
        setEngFinished(true);
      }
    } catch (e) {
      console.error(e);
    }
    setEngExecuting(false);
  };

  const handleDownloadExcel = async () => {
    try {
      const response = await fetch('/api/pipeline/engineering/export', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          layers: engLayers,
          fileName: uploadedFile ? uploadedFile.fileName : engFileName
        })
      });
      
      if (!response.ok) {
        throw new Error('Cevap alınamadı.');
      }
      
      const blob = await response.blob();
      const url = window.URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url;
      a.download = `amorfly_metraj_kesif_ozeti_${Date.now()}.xlsx`;
      document.body.appendChild(a);
      a.click();
      document.body.removeChild(a);
      window.URL.revokeObjectURL(url);
    } catch (error) {
      alert('Excel belgesi sentezlenirken bir hata oluştu.');
      console.error('Excel indirilemedi:', error);
    }
  };

  const handleRunDesktopPipeline = async () => {
    if (desktopExecuting) return;
    setDesktopExecuting(true);
    setDesktopFinished(false);
    setDesktopCurrentStep(1);
    setDesktopLogs(['Amorfly Packaging Core initialized...']);
    setDesktopPythonSource('');
    setDesktopBashScript('');
    setDesktopDownloadUrl('');

    const steps = [
      'Gemini 3.5 Core Sentezleyici: İstek anlaşıldı. CustomTkinter tabanlı görsel arayüz yapısı oluşturuluyor...',
      'Akıllı Kod Üretimi: Çapraz platform uyumluluk katmanı (tkinter framework) dosyaya kodlandı.',
      'PyInstaller Derleme Kancası: Gerekli yerel kütüphaneler (customtkinter, ezdxf vb.) derleme grafiğine dahil edildi.',
      'Sıkıştırma & Şifreleme: Bytecode derleyici UPX sıkıştırmasını başlattı (Metraj/Oynatıcı modülü paketi %40 küçültüldü).',
      'Paketleme Başarılı! VLC tarzı çift tıklanabilir bağımsız binary ve Zorin OS uyumlu kurulum betiği teslimata hazır.'
    ];

    for (let i = 0; i < steps.length; i++) {
      await new Promise(resolve => setTimeout(resolve, 1100));
      setDesktopCurrentStep(i + 2);
      setDesktopLogs(prev => [...prev, steps[i]]);

      setSystemStatus(prev => {
        if (!prev) return prev;
        return {
          ...prev,
          activeLogs: [
            { timestamp: new Date().toISOString(), type: 'DESKTOP_BUILDER', details: steps[i], status: 'SUCCESS' },
            ...prev.activeLogs
          ]
        } as any;
      });
    }

    try {
      const response = await fetch('/api/pipeline/desktop-build', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          appName: desktopAppName,
          appType: desktopAppType,
          targetOS: desktopTargetOS
        })
      });
      const data = await response.json();
      if (data.success) {
        setDesktopPythonSource(data.pythonSource);
        setDesktopBashScript(data.bashScript);
        setDesktopDownloadUrl(data.downloadUrl);
        setDesktopFinished(true);
      }
    } catch (e) {
      console.error(e);
    }
    setDesktopExecuting(false);
  };

  const handleVlcCompile = () => {
    setVlcIsCompiling(true);
    setVlcCurrentStep(0);
    setVlcCompilationLogs([
      "⚙️ [ANALİST] Yapay Zeka gereksinim şablonu çözümleniyor...",
      "🔍 [GEREKSİNİM] Tercihler: Tema (" + vlcCompiledTheme + "), Grafik Ekolayzer (" + (vlcCompiledEq ? "Aktif" : "Pasif") + "), Altyazı Desteği (" + (vlcCompiledSub ? "Aktif" : "Pasif") + ")"
    ]);

    setTimeout(() => {
      setVlcCurrentStep(1);
      setVlcCompilationLogs(prev => [
        ...prev,
        "📦 [KODEK] Zorin OS native VLC multimedya kütüphaneleri optimize ediliyor...",
        "📦 [KODEK] C++ donanım ivmeli GStreamer / libvlc dekoder sarmalayıcıları eşleniyor..."
      ]);
    }, 800);

    setTimeout(() => {
      setVlcCurrentStep(2);
      setVlcCompilationLogs(prev => [
        ...prev,
        "🎨 [TASARIM] Seçilen tema algoritmaları yükleniyor: " + vlcCompiledTheme.toUpperCase(),
        "🎨 [TASARIM] Özel CSS arayüz maskelemeleri ve buton kontrol matrisleri yerleştiriliyor..."
      ]);
    }, 1600);

    setTimeout(() => {
      setVlcCurrentStep(3);
      setVlcCompilationLogs(prev => [
        ...prev,
        "🚀 [DERLEME] Kod bloğu başarıyla oluşturuldu! Arayüz birleştirilerek canlı test paneli yayına alındı.",
        "🎉 [TAMAMLANDI] Amorfly AI yeni nesil multimedya oynatıcınız kullanıma hazır."
      ]);
      setVlcIsCompiling(false);
      setVlcHasCompiledBefore(true);
    }, 2400);
  };

  const handlePlayInVlc = (trackUrl: string, title: string) => {
    setVlcLaunchingLocal(true);
    setVlcLaunchDetails("Dinamik VLC bağlantısı kuruluyor... Soket ID: " + Math.random().toString(36).substring(7).toUpperCase());
    
    // Simulate VLC process commands and sub-file loading parameters
    setTimeout(() => {
      setVlcLaunchDetails("📦 [VLC DAEMON CLIENT] Komutu tetikleniyor:\n$ vlc --sub-file=~/.amorfly/temp_subs.srt --volume-boost \"" + trackUrl + "\"");
    }, 800);

    setTimeout(() => {
      setVlcLaunchDetails("✅ [BAĞLANTI BAŞARILI] VLC Player yerel cihazda doğrudan başlatıldı. Dublaj / altyazı motoru VLC ile senkronize edildi!");
      
      // Let's print out to terminal history so that the terminal registers this OS integration event!
      setTerminalHistory(prev => [
        {
          cmd: "vlc --play-direct \"" + title + "\"",
          out: "[Amorfly Control Engine] VLC Player initialized: " + title + "\nSubtitles auto-sync active: Yes\nTarget Window ID: GNOME_VLC_CLIENT_PID_" + Math.floor(Math.random() * 8000 + 1000),
          type: "success"
        },
        ...prev
      ]);
    }, 1800);

    setTimeout(() => {
      setVlcLaunchingLocal(false);
    }, 4500);
  };

  const handleProcess2GBVideo = (title: string) => {
    setIsMediaProcessing2GB(true);
    setMediaProcessingProgress(5);
    setMediaProcessingStep("Dosya boyutu ve yapılandırma doğrulanıyor... (Limit: 2 GB)");

    const interval = setInterval(() => {
      setMediaProcessingProgress(prev => {
        if (prev >= 100) {
          clearInterval(interval);
          setIsMediaProcessing2GB(false);
          setPlayerSubtitleText("Amorfly AI v2.0 - [Türkçe Yapay Zeka Dublaj ve Otomatik Altyazı Sentezi Hazır]");
          setTerminalHistory(prevH => [
            {
              cmd: "media --translate-dub --limit-2gb",
              out: "[Amorfly Audio Processing] Succeeded!\nSource: English VOD\nTarget: " + selectedDubLang.toUpperCase() + "\nVoice cloning strategy: " + (selectedVoiceClone ? "Active" : "Standard Voice") + "\nExtracted SRT saved to ~/.amorfly/temp_subs.srt.\nReady to load in VLC!",
              type: "success"
            },
            ...prevH
          ]);
          return 100;
        }
        
        const nextVal = prev + Math.floor(Math.random() * 15) + 5;
        if (nextVal > 100) return 100;

        if (nextVal < 25) setMediaProcessingStep(" Whisper kütüphaneleriyle yerel ve sızdırmaz ses deşifresi yapılıyor...");
        else if (nextVal < 50) setMediaProcessingStep("Mevcut ses frekansından gürültüler temizleniyor...");
        else if (nextVal < 75) setMediaProcessingStep("Qwen 2.5 NLP motoru ile altyazılar " + selectedDubLang.toUpperCase() + " diline çevriliyor...");
        else if (nextVal < 90) setMediaProcessingStep("Piper TTS motoru yardımıyla yapay zeka dublaj sesleri sentezleniyor...");
        else setMediaProcessingStep("Yapay zeka dublajı video akışına montajlanıyor ve senkronize ediliyor...");

        return nextVal;
      });
    }, 450);
  };

  const wipeAllData = () => {
    localStorage.removeItem('amorfly_chat_history');
    setMessages([
      {
        id: 'welcome_reset',
        role: 'assistant',
        content: '⚙️ Tüm oturumlar temizlendi. Amorfly AI güvenli yerel belleği tekrar yapılandırıldı. Dosyalarınızı sıfırdan yükleyebilirsiniz.',
        timestamp: new Date().toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' })
      }
    ]);
    clearUploadedFile();
    alert('Tüm yerel veriler güvenli bir şekilde silindi.');
  };

  return (
    <div className="flex h-screen w-full bg-[#030612] text-[#e3e3e3] font-sans antialiased overflow-hidden relative">
      {/* HUD Space Flight Ambient Overlays */}
      <div className="absolute inset-0 bg-[radial-gradient(ellipse_60%_60%_at_50%_-20%,rgba(6,182,212,0.12),rgba(0,0,0,0))] pointer-events-none z-0" />
      <div className="absolute inset-0 bg-[linear-gradient(to_right,rgba(255,255,255,0.007)_1px,transparent_1px),linear-gradient(to_bottom,rgba(255,255,255,0.007)_1px,transparent_1px)] bg-[size:16px_26px] [mask-image:radial-gradient(ellipse_50%_60%_at_50%_40%,#000_60%,transparent_100%)] pointer-events-none z-0" />
      
      {/* LEFT SIDEBAR: Fire Red Theme with Glowing Cyber Accents */}
      <div id="ubuntu-dock" className="w-[68px] bg-gradient-to-b from-[#ff1e3f] via-[#c20025] to-[#730012] border-r border-[#a80018]/50 flex flex-col items-center py-4 justify-between select-none z-10 shrink-0 relative shadow-[5px_0_25px_rgba(225,29,72,0.25)]">
        <div className="flex flex-col items-center gap-6 w-full">
          {/* Logo / Launcher */}
          <div className="group relative flex items-center justify-center cursor-pointer">
            <div className="w-12 h-12 rounded-xl bg-gradient-to-br from-[#1c0205] to-[#070001] border border-red-500/30 flex items-center justify-center shadow-lg shadow-red-500/10 transition-all duration-300 group-hover:scale-110 group-hover:border-red-400 group-hover:shadow-[0_0_15px_rgba(239,68,68,0.4)] overflow-visible relative">
              {/* Spinning dotted circle HUD */}
              <div className="absolute inset-[-4px] flex items-center justify-center pointer-events-none z-10 animate-spin" style={{ animationDuration: '8s' }}>
                <svg className="w-14 h-14 text-cyan-400" viewBox="0 0 100 100">
                  <circle cx="50" cy="50" r="45" fill="none" stroke="currentColor" strokeWidth="4" strokeDasharray="5 7" />
                </svg>
              </div>
              {/* Secondary inner reverse rotating HUD */}
              <div className="absolute inset-0 flex items-center justify-center pointer-events-none z-10 animate-spin" style={{ animationDuration: '4s', animationDirection: 'reverse' }}>
                <svg className="w-10 h-10 text-teal-400/60" viewBox="0 0 100 100">
                  <circle cx="50" cy="50" r="42" fill="none" stroke="currentColor" strokeWidth="2.5" strokeDasharray="2 12" />
                </svg>
              </div>
              <div className="absolute inset-0 bg-[linear-gradient(45deg,transparent_25%,rgba(239,68,68,0.2)_50%,transparent_75%)] bg-[length:250%_250%] animate-pulse" />
              {/* Glowing Fire-red 'A' Letter */}
              <span className="text-xl font-bold font-sans text-red-500 drop-shadow-[0_0_8px_rgba(239,68,68,0.95)] select-none relative z-20">A</span>
            </div>
            {/* Tooltip */}
            <div className="absolute left-16 px-3 py-1.5 bg-[#0e1626] text-xs font-semibold text-[#f5f5f5] rounded-md opacity-0 pointer-events-none group-hover:opacity-100 transition-all duration-200 whitespace-nowrap shadow-xl border border-cyan-500/25 z-50">
              Amorfly AI v2.5 <span className="text-[10px] text-cyan-400 font-mono">Hologram</span>
            </div>
          </div>

          <div className="w-8 h-[0.5px] bg-cyan-400/40 shadow-[0_0_4px_rgba(34,211,238,0.5)]"></div>

          {/* Chat Launcher Icon */}
          <button
            onClick={() => {
              if (activeTab === 'chat' && !showSessions) {
                setIsDrawerOpen(!isDrawerOpen);
              } else {
                setActiveTab('chat');
                setShowSessions(false);
                setIsDrawerOpen(true);
              }
            }}
            className={`group relative w-11 h-11 rounded-xl flex items-center justify-center transition-all duration-300 cursor-pointer overflow-hidden ${
              activeTab === 'chat' && !showSessions && isDrawerOpen
                ? 'bg-cyan-950/80 text-[#22d3ee] border border-[#22d3ee] shadow-[0_0_15px_rgba(34,211,238,0.73)] scale-110' 
                : 'text-rose-100 hover:bg-[#002533]/65 hover:text-[#22d3ee] hover:border-[#22d3ee]/40 hover:shadow-[0_0_8px_rgba(34,211,238,0.35)]'
            }`}
          >
            {activeTab === 'chat' && !showSessions && isDrawerOpen && (
              <div className="absolute left-0 top-0 bottom-0 w-[3px] bg-[#22d3ee] shadow-[0_0_8px_rgba(34,211,238,0.95)]" />
            )}
            <BrainCircuitLogo className="w-6 h-6" />
            <div className="absolute left-16 px-3 py-1.5 bg-[#0e1626] text-xs font-semibold text-[#f5f5f5] rounded-md opacity-0 pointer-events-none group-hover:opacity-100 transition-opacity duration-200 whitespace-nowrap shadow-xl border border-slate-700 z-50">
              Akıllı Mesajlaşma
            </div>
          </button>

          {/* Chat History (Sessions) Icon */}
          <button
            onClick={() => {
              if (activeTab === 'chat' && showSessions) {
                setIsDrawerOpen(!isDrawerOpen);
              } else {
                setActiveTab('chat');
                setShowSessions(true);
                setIsDrawerOpen(true);
              }
            }}
            className={`group relative w-11 h-11 rounded-xl flex items-center justify-center transition-all duration-300 cursor-pointer overflow-hidden ${
              activeTab === 'chat' && showSessions && isDrawerOpen
                ? 'bg-cyan-950/80 text-[#22d3ee] border border-[#22d3ee] shadow-[0_0_15px_rgba(34,211,238,0.73)] scale-110' 
                : 'text-rose-100 hover:bg-[#002533]/65 hover:text-[#22d3ee] hover:border-[#22d3ee]/40 hover:shadow-[0_0_8px_rgba(34,211,238,0.35)]'
            }`}
          >
            {activeTab === 'chat' && showSessions && isDrawerOpen && (
              <div className="absolute left-0 top-0 bottom-0 w-[3px] bg-[#22d3ee] shadow-[0_0_8px_rgba(34,211,238,0.95)]" />
            )}
            <History className="w-5.5 h-5.5" />
            <div className="absolute left-16 px-3 py-1.5 bg-[#0e1626] text-xs font-semibold text-[#f5f5f5] rounded-md opacity-0 pointer-events-none group-hover:opacity-100 transition-opacity duration-200 whitespace-nowrap shadow-xl border border-slate-700 z-50">
              Sohbet Geçmişi
            </div>
          </button>

          {/* Pipelines Orchestrator Icon */}
          <button
            onClick={() => {
              if (activeTab === 'pipelines') {
                setIsDrawerOpen(!isDrawerOpen);
              } else {
                setActiveTab('pipelines');
                setIsDrawerOpen(true);
              }
            }}
            className={`group relative w-11 h-11 rounded-xl flex items-center justify-center transition-all duration-300 cursor-pointer overflow-hidden ${
              activeTab === 'pipelines' && isDrawerOpen
                ? 'bg-cyan-950/80 text-[#22d3ee] border border-[#22d3ee] shadow-[0_0_15px_rgba(34,211,238,0.73)] scale-110'
                : 'text-rose-100 hover:bg-[#002533]/65 hover:text-[#22d3ee] hover:border-[#22d3ee]/40 hover:shadow-[0_0_8px_rgba(34,211,238,0.35)]'
            }`}
          >
            {activeTab === 'pipelines' && isDrawerOpen && (
              <div className="absolute left-0 top-0 bottom-0 w-[3px] bg-[#22d3ee] shadow-[0_0_8px_rgba(34,211,238,0.95)]" />
            )}
            <Cpu className="w-5.5 h-5.5" />
            <div className="absolute left-16 px-3 py-1.5 bg-[#0e1626] text-xs font-semibold text-[#f5f5f5] rounded-md opacity-0 pointer-events-none group-hover:opacity-100 transition-opacity duration-200 whitespace-nowrap shadow-xl border border-slate-700 z-50">
              Entegre İş Akışları (Pipelines)
            </div>
          </button>

          {/* Inspected File Grid tab */}
          <button
            disabled={!uploadedFile}
            onClick={() => {
              if (activeTab === 'inspect') {
                setIsDrawerOpen(!isDrawerOpen);
              } else {
                setActiveTab('inspect');
                setIsDrawerOpen(true);
              }
            }}
            className={`group relative w-11 h-11 rounded-xl flex items-center justify-center transition-all duration-300 overflow-hidden ${
              !uploadedFile ? 'opacity-30 cursor-not-allowed text-rose-300/40' : 'cursor-pointer'
            } ${
              activeTab === 'inspect' && isDrawerOpen
                ? 'bg-cyan-950/80 text-[#22d3ee] border border-[#22d3ee] shadow-[0_0_15px_rgba(34,211,238,0.73)] scale-110'
                : 'text-rose-100 hover:bg-[#002533]/65 hover:text-[#22d3ee] hover:border-[#22d3ee]/40 hover:shadow-[0_0_8px_rgba(34,211,238,0.35)]'
            }`}
          >
            {activeTab === 'inspect' && isDrawerOpen && (
              <div className="absolute left-0 top-0 bottom-0 w-[3px] bg-[#22d3ee] shadow-[0_0_8px_rgba(34,211,238,0.95)]" />
            )}
            {uploadedFile?.xlsxData ? (
              <FileSpreadsheet className="w-5.5 h-5.5" />
            ) : (
              <FileText className="w-5.5 h-5.5" />
            )}
            <div className="absolute left-16 px-3 py-1.5 bg-[#0e1626] text-xs font-semibold text-[#f5f5f5] rounded-md opacity-0 pointer-events-none group-hover:opacity-100 transition-opacity duration-200 whitespace-nowrap shadow-xl border border-slate-700 z-50">
              Excel / Belge Önizleme {!uploadedFile && '(Dosya Yükleyin)'}
            </div>
          </button>

          {/* Secure terminal panel */}
          <button
            onClick={() => {
              if (activeTab === 'terminal') {
                setIsDrawerOpen(!isDrawerOpen);
              } else {
                setActiveTab('terminal');
                setIsDrawerOpen(true);
              }
            }}
            className={`group relative w-11 h-11 rounded-xl flex items-center justify-center transition-all duration-300 cursor-pointer overflow-hidden ${
              activeTab === 'terminal' && isDrawerOpen
                ? 'bg-cyan-950/80 text-[#22d3ee] border border-[#22d3ee] shadow-[0_0_15px_rgba(34,211,238,0.73)] scale-110'
                : 'text-rose-100 hover:bg-[#002533]/65 hover:text-[#22d3ee] hover:border-[#22d3ee]/40 hover:shadow-[0_0_8px_rgba(34,211,238,0.35)]'
            }`}
          >
            {activeTab === 'terminal' && isDrawerOpen && (
              <div className="absolute left-0 top-0 bottom-0 w-[3px] bg-[#22d3ee] shadow-[0_0_8px_rgba(34,211,238,0.95)]" />
            )}
            <Terminal className="w-5.5 h-5.5" />
            <div className="absolute left-16 px-3 py-1.5 bg-[#0e1626] text-xs font-semibold text-[#f5f5f5] rounded-md opacity-0 pointer-events-none group-hover:opacity-100 transition-opacity duration-200 whitespace-nowrap shadow-xl border border-slate-700 z-50">
              Ubuntu Güvenli Kabuk (CLI)
            </div>
          </button>

          {/* Audit Logs */}
          <button
            onClick={() => {
              if (activeTab === 'storage') {
                setIsDrawerOpen(!isDrawerOpen);
              } else {
                setActiveTab('storage');
                setIsDrawerOpen(true);
              }
            }}
            className={`group relative w-11 h-11 rounded-xl flex items-center justify-center transition-all duration-300 cursor-pointer overflow-hidden ${
              activeTab === 'storage' && isDrawerOpen
                ? 'bg-cyan-950/80 text-[#22d3ee] border border-[#22d3ee] shadow-[0_0_15px_rgba(34,211,238,0.73)] scale-110'
                : 'text-rose-100 hover:bg-[#002533]/65 hover:text-[#22d3ee] hover:border-[#22d3ee]/40 hover:shadow-[0_0_8px_rgba(34,211,238,0.35)]'
            }`}
          >
            {activeTab === 'storage' && isDrawerOpen && (
              <div className="absolute left-0 top-0 bottom-0 w-[3px] bg-[#22d3ee] shadow-[0_0_8px_rgba(34,211,238,0.95)]" />
            )}
            <Shield className="w-5.5 h-5.5" />
            <div className="absolute left-16 px-3 py-1.5 bg-[#0e1626] text-xs font-semibold text-[#f5f5f5] rounded-md opacity-0 pointer-events-none group-hover:opacity-100 transition-opacity duration-200 whitespace-nowrap shadow-xl border border-slate-700 z-50">
              Sızıntı Denetim Günlüğü
            </div>
          </button>

          {/* VLC Multimedia Player Tab */}
          <button
            onClick={() => {
              if (activeTab === 'player') {
                setIsDrawerOpen(!isDrawerOpen);
              } else {
                setActiveTab('player');
                setIsDrawerOpen(true);
              }
            }}
            className={`group relative w-11 h-11 rounded-xl flex items-center justify-center transition-all duration-300 cursor-pointer overflow-hidden ${
              activeTab === 'player' && isDrawerOpen
                ? 'bg-cyan-950/80 text-[#22d3ee] border border-[#22d3ee] shadow-[0_0_15px_rgba(34,211,238,0.73)] scale-110'
                : 'text-rose-100 hover:bg-[#002533]/65 hover:text-[#22d3ee] hover:border-[#22d3ee]/40 hover:shadow-[0_0_8px_rgba(34,211,238,0.35)]'
            }`}
          >
            {activeTab === 'player' && isDrawerOpen && (
              <div className="absolute left-0 top-0 bottom-0 w-[3px] bg-[#22d3ee] shadow-[0_0_8px_rgba(34,211,238,0.95)]" />
            )}
            <Film className="w-5.5 h-5.5" />
            <div className="absolute left-16 px-3 py-1.5 bg-[#0e1626] text-xs font-semibold text-[#f5f5f5] rounded-md opacity-0 pointer-events-none group-hover:opacity-100 transition-opacity duration-200 whitespace-nowrap shadow-xl border border-slate-700 z-50">
              Amorfly AI VLC-Benzeri Video Oynatıcı 🎬
            </div>
          </button>

          {/* Desktop & Mobile App hub */}
          <button
            onClick={() => {
              if (activeTab === 'distribution') {
                setIsDrawerOpen(!isDrawerOpen);
              } else {
                setActiveTab('distribution');
                setIsDrawerOpen(true);
              }
            }}
            className={`group relative w-11 h-11 rounded-xl flex items-center justify-center transition-all duration-300 cursor-pointer overflow-hidden ${
              activeTab === 'distribution' && isDrawerOpen
                ? 'bg-cyan-950/80 text-[#22d3ee] border border-[#22d3ee] shadow-[0_0_15px_rgba(34,211,238,0.73)] scale-110'
                : 'text-rose-100 hover:bg-[#002533]/65 hover:text-[#22d3ee] hover:border-[#22d3ee]/40 hover:shadow-[0_0_8px_rgba(34,211,238,0.35)]'
            }`}
          >
            {activeTab === 'distribution' && isDrawerOpen && (
              <div className="absolute left-0 top-0 bottom-0 w-[3px] bg-[#22d3ee] shadow-[0_0_8px_rgba(34,211,238,0.95)]" />
            )}
            <Monitor className="w-5.5 h-5.5" />
            <div className="absolute left-16 px-3 py-1.5 bg-[#0e1626] text-xs font-semibold text-[#f5f5f5] rounded-md opacity-0 pointer-events-none group-hover:opacity-100 transition-opacity duration-200 whitespace-nowrap shadow-xl border border-slate-700 z-50">
              Masaüstü & Mobil Kurulumu
            </div>
          </button>
        </div>

        {/* Bottom Actions */}
        <div className="flex flex-col items-center gap-4">
          <div className="w-8 h-[0.5px] bg-[#22d3ee]/30"></div>
          
          <button
            onClick={wipeAllData}
            className="group relative w-11 h-11 rounded-xl flex items-center justify-center text-rose-200 hover:bg-[#3d000a]/60 hover:text-red-400 transition-all duration-200 cursor-pointer"
            title="Kalıcı Olarak Her Şeyi Sıfırla"
          >
            <Trash2 className="w-5.5 h-5.5" />
            <div className="absolute left-16 px-3 py-1.5 bg-[#0e1626] text-xs font-semibold text-red-400 rounded-md opacity-0 pointer-events-none group-hover:opacity-100 transition-opacity duration-200 whitespace-nowrap shadow-xl border border-red-950/30 z-50">
              Tüm Verileri Temizle
            </div>
          </button>
        </div>
      </div>

      {/* INNER LAYER - SPLIT INTO PREVIEW ENGINE OR RIGHT BAR */}
      <div className="flex-1 flex flex-col overflow-hidden bg-[#090d16]">
        
        {/* TOP STATUS CONTROL BAR (Futuristic GNOME/Spaceship HUD Dock) */}
        <header className="h-[44px] bg-gradient-to-r from-[#060b13] via-[#090f1f] to-[#040810] border-b border-cyan-500/20 px-4 flex items-center justify-between select-none shrink-0 text-xs relative z-10 shadow-[0_4px_25px_rgba(3,7,18,0.5)]">
          <div className="flex items-center gap-3">
            <div className="flex items-center gap-1.5 font-sans">
              <AmorflyLogo className="w-5.5 h-5.5 text-cyan-400" />
              <span className="font-extrabold text-[#eef2f6] tracking-widest uppercase neon-text-cyan">Amorfly AI</span>
            </div>
            <span className="text-[#12284c]">|</span>
            <div className="flex items-center gap-1.5 text-cyan-300 bg-[#0e172a] px-2 py-0.5 rounded border border-cyan-500/15 font-mono text-[10px]">
              <Cpu className="w-3.5 h-3.5 text-cyan-400 animate-pulse" />
              <span>CORE SECURE KERNEL</span>
            </div>
          </div>

          {/* Quick status values */}
          <div className="flex items-center gap-6">
            
            {/* System Ram Widget */}
            <div className="hidden md:flex items-center gap-1.5 text-gray-400">
              <Server className="w-3.5 h-3.5 text-cyan-400" />
              <span className="text-[10px]">Lokal Bellek:</span>
              <span className="font-mono text-[#38bdf8] bg-[#0c1628] px-1.5 py-0.5 rounded border border-cyan-500/15">{systemStatus?.ram.rss || 'Hologram-Sync...'}</span>
            </div>

            {/* Offline Shield Indicator */}
            <div className="flex items-center gap-2 bg-[#0a1e28] border border-cyan-500/30 px-3 py-1 rounded-full shadow-[0_0_12px_rgba(34,211,238,0.2)]">
              <Shield className="w-3.5 h-3.5 text-cyan-400 fill-cyan-400/10" />
              <span className="text-[10px] text-cyan-300 font-bold uppercase tracking-widest font-sans">SIFIR SIZINTI AKTİF</span>
            </div>

            {/* AI Operational Mode Switch */}
            <div className="flex items-center gap-0.5 bg-[#050811] border border-[#0d162d] p-0.5 rounded-lg select-none">
              <button
                onClick={() => {
                  setOnlineMode(false);
                  setTerminalHistory(prev => [...prev, { cmd: 'set_mode --offline', out: 'İnternet bağlantısı kalkanlandı. Çevrimdışı Güvenlik Motoru devrede.', type: 'system' }]);
                }}
                className={`flex items-center gap-1 px-2.5 py-1 rounded-md text-[11px] font-bold transition-all cursor-pointer ${
                  !onlineMode 
                    ? 'bg-orange-500/15 border border-orange-500 text-orange-400 shadow-[0_0_10px_rgba(249,115,22,0.3)]' 
                    : 'text-gray-500 hover:text-gray-300'
                }`}
              >
                <WifiOff className="w-3.5 h-3.5" />
                <span>Offline</span>
              </button>
              <button
                onClick={() => {
                  setOnlineMode(true);
                  setTerminalHistory(prev => [...prev, { cmd: 'set_mode --online', out: 'Güvenli Çevrimiçi Gemini API tüneli oluşturuldu.', type: 'system' }]);
                }}
                className={`flex items-center gap-1 px-2.5 py-1 rounded-md text-[11px] font-bold transition-all cursor-pointer ${
                  onlineMode 
                    ? 'bg-cyan-500/15 border border-cyan-500 text-cyan-400 shadow-[0_0_10px_rgba(6,182,212,0.3)]' 
                    : 'text-gray-500 hover:text-gray-300'
                }`}
              >
                <Wifi className="w-3.5 h-3.5" />
                <span>Online</span>
              </button>
            </div>
          </div>
        </header>

        {/* WORKSPACE AREA: DYNAMIC TAB VIEW CONFIG */}
        <div className="flex-1 flex overflow-hidden relative">
          
          {/* LEFT CHROME CONTROLLER PANEL (Translucent Obsidian Science Panel Drawer with Amorfly OS Red Theme) */}
          <div 
            id="local-control" 
            className={`bg-gradient-to-b from-[#180507] via-[#0b0102] to-[#040001]/95 shadow-[5px_0_25px_rgba(239,68,68,0.12)] flex flex-col shrink-0 overflow-y-auto relative z-10 custom-scrollbar transition-all duration-300 ease-in-out ${
              isDrawerOpen 
                ? 'w-[300px] p-4 opacity-100 border-r border-[#3d0f14]/50' 
                : 'w-0 p-0 opacity-0 pointer-events-none border-r-0'
            }`}
          >
            {showSessions ? (
              <div className="flex flex-col h-full">
                <div className="flex items-center justify-between mb-4 pb-2 border-b border-red-500/20">
                  <div className="flex items-center gap-2">
                    <History className="w-4 h-4 text-red-400" />
                    <h3 className="text-sm font-bold tracking-wider uppercase text-red-200">Geçmiş Yazışmalar</h3>
                  </div>
                  <span className="text-[10px] px-2 py-0.5 bg-red-950/40 text-rose-300 rounded-full font-mono font-bold border border-red-500/20">Oturumlar</span>
                </div>

                {/* + Yeni Sohbet Başlat Button */}
                <button
                  onClick={startNewSession}
                  className="w-full py-2.5 px-4 mb-4 bg-gradient-to-r from-red-600 to-rose-600 hover:from-red-500 hover:to-rose-500 text-xs text-white font-extrabold rounded-xl shadow-[0_0_15px_rgba(239,68,68,0.25)] transition-all duration-300 flex items-center justify-center gap-2 cursor-pointer border border-red-400/30 uppercase tracking-widest"
                >
                  <Plus className="w-4 h-4 text-rose-200 animate-pulse" />
                  <span>Yeni Canlı Bağlantı</span>
                </button>

                {/* Sessions list */}
                <div className="flex-1 space-y-2.5 overflow-y-auto max-h-[480px] custom-scrollbar pr-1">
                  {sessions.length === 0 ? (
                    <p className="text-gray-500 text-xs text-center py-6">Henüz kayıtlı bir sohbet oturumu bulunmuyor.</p>
                  ) : (
                    sessions.map((sess) => {
                      const isActive = sess.id === activeSessionId;
                      return (
                        <div
                           key={sess.id}
                           onClick={() => selectSession(sess.id)}
                           className={`group p-3 rounded-xl border transition-all duration-300 cursor-pointer flex items-center justify-between gap-2.5 relative overflow-hidden ${
                             isActive
                               ? 'bg-red-500/10 border-red-400/40 text-rose-100 shadow-[0_0_15px_rgba(239,68,68,0.15)]'
                               : 'bg-[#090203] border-[#220c0f] text-slate-400 hover:bg-[#120406] hover:text-white hover:border-red-500/35'
                           }`}
                        >
                          {isActive && <div className="absolute left-0 top-0 bottom-0 w-1 bg-red-500 shadow-[0_0_8px_rgba(239,68,68,0.8)]" />}
                          <div className="flex items-center gap-2 overflow-hidden w-full">
                            <MessageSquare className={`w-4 h-4 shrink-0 ${isActive ? 'text-red-400' : 'text-slate-500 group-hover:text-slate-400'}`} />
                            <div className="flex flex-col overflow-hidden">
                              <span className="text-xs font-bold truncate pr-3">{sess.title}</span>
                              <span className="text-[9px] text-[#5e4b4d] font-mono mt-0.5">{sess.messages.length} mesaj • {sess.timestamp}</span>
                            </div>
                          </div>

                          <button
                            onClick={(e) => deleteSession(sess.id, e)}
                            className="text-red-400 opacity-40 hover:opacity-100 p-1 hover:bg-red-950/20 rounded transition-all shrink-0 cursor-pointer"
                            title="Konuşmayı Sil"
                          >
                            <Trash2 className="w-3.5 h-3.5" />
                          </button>
                        </div>
                      );
                    })
                  )}
                </div>

                <div className="mt-auto pt-4 border-t border-red-950 text-[10px] text-red-500/50 leading-normal italic text-center font-mono uppercase tracking-wider">
                  // VERİ GÜVENLİK ZIRHI ETKİN
                </div>
              </div>
            ) : (
              <>
                <div className="flex items-center justify-between mb-4 pb-2 border-b border-red-500/20">
                  <div className="flex items-center gap-2">
                    <FolderOpen className="w-4 h-4 text-red-400" />
                    <h3 className="text-xs font-black tracking-widest uppercase text-[#eef2f6]">Yerel Veri Hücresi</h3>
                  </div>
                  <span className="text-[10px] px-2 py-0.5 bg-red-950/40 text-red-400 rounded-full font-mono font-bold uppercase border border-red-500/20">LOKAL_DISK</span>
                </div>

                {/* DRAG AND DROP TARGET */}
                <div 
                  onDragEnter={handleDrag}
                  onDragOver={handleDrag}
                  onDragLeave={handleDrag}
                  onDrop={handleDrop}
                  className={`p-5 mb-4 rounded-xl border-2 border-dashed transition-all duration-300 flex flex-col items-center justify-center text-center cursor-pointer ${
                    dragActive 
                      ? 'border-red-500 bg-red-500/5 shadow-[0_0_15px_rgba(239,68,68,0.2)]' 
                      : 'border-red-950/60 bg-[#0c0304]/65 hover:border-red-500/40'
                  }`}
                >
                  <Upload className={`w-8 h-8 mb-2 ${isUploading ? 'animate-bounce text-red-400' : 'text-[#f43f5e]/60'}`} />
                  
                  <label className="cursor-pointer text-xs font-semibold block text-slate-300">
                    {isUploading ? (
                      <span className="text-red-400">Analiz Yapılıyor...</span>
                    ) : (
                      <>
                        <span className="text-red-400 hover:underline">Bir dosya seçin</span> veya buraya sürükleyin
                      </>
                    )}
                    <input 
                      type="file" 
                      className="hidden" 
                      onChange={handleFileChange} 
                      accept=".pdf,.docx,.xlsx,.xls,.csv,.png,.jpg,.jpeg,.webp,.gif,.txt" 
                    />
                  </label>
                  <p className="text-[9px] text-gray-500 mt-1.5 leading-relaxed">PDF, WORD, EXCEL veya Görsel dosyalari yerel işleme tabi tutulur.</p>
                </div>

                {/* MOUNTED FILE DATA DISPLAY */}
                {uploadedFile ? (
                  <div className="bg-[#1f1011] rounded-xl p-3 border border-[#3e1b1d] flex flex-col gap-2 shadow-md">
                    <div className="flex items-start justify-between">
                      <div className="flex items-center gap-2 overflow-hidden">
                        {uploadedFile.xlsxData ? (
                          <FileSpreadsheet className="w-5 h-5 text-emerald-400 shrink-0" />
                        ) : uploadedFile.isImage ? (
                          <Eye className="w-5 h-5 text-amber-400 shrink-0" />
                        ) : (
                          <FileText className="w-5 h-5 text-red-400 shrink-0" />
                        )}
                        <span className="text-xs font-bold text-gray-200 truncate" title={uploadedFile.fileName}>
                          {uploadedFile.fileName}
                        </span>
                      </div>
                      <button 
                        onClick={clearUploadedFile}
                        className="p-1 hover:bg-[#321d1e] rounded-md text-red-400 transition-colors"
                        title="Dosyayı sistem arabelleğinden çıkart"
                      >
                        <Trash2 className="w-3.5 h-3.5" />
                      </button>
                    </div>

                    <div className="text-[10px] text-gray-400 font-mono space-y-1 bg-[#120809] p-2 rounded border border-[#2e1d1e]">
                      <div><strong className="text-gray-500">Tür:</strong> {uploadedFile.fileType.toUpperCase()}</div>
                      {uploadedFile.text && (
                        <div><strong className="text-gray-500 text-xxs">Boyut:</strong> {uploadedFile.text.length} Karakter</div>
                      )}
                      {uploadedFile.xlsxData && (
                        <div><strong className="text-gray-500 text-xxs">Sayfalar:</strong> {Object.keys(uploadedFile.xlsxData).join(', ')}</div>
                      )}
                    </div>

                    {uploadedFile.isImage && uploadedFile.base64 && (
                      <div className="mt-1.5 rounded-lg overflow-hidden border border-[#3e1b1d] max-h-32 bg-[#120809] flex items-center justify-center">
                        <img 
                          src={`data:${uploadedFile.mimeType || 'image/png'};base64,${uploadedFile.base64}`} 
                          alt="Parser Image preview" 
                          className="object-contain max-h-32"
                        />
                      </div>
                    )}

                    <div className="flex items-center gap-1.5 mt-1">
                      <span className="w-1.5 h-1.5 bg-green-400 rounded-full animate-pulse"></span>
                      <span className="text-[10px] text-green-400 font-semibold uppercase tracking-wider">Aktif Belge İliştirildi</span>
                    </div>
                    
                    <p className="text-[9.5px] text-gray-500 leading-normal italic mt-1 bg-[#170a0b] p-2 rounded">
                      *Yapay zekaya göndereceğiniz tüm sorular bu dosyanın içeriği ile birlikte analiz edilecektir.*
                    </p>
                  </div>
                ) : (
                  <div className="border border-red-950/60 bg-red-950/10 rounded-xl p-4 text-center text-xs text-gray-500 py-8">
                    <Lock className="w-6 h-6 mx-auto mb-2 opacity-20 text-red-500" />
                    Dizinde aktif yükleme bulunmuyor. Dosya analizleri bu alanda listelenir.
                  </div>
                )}

                {/* SELECTION FOR ONLINE CHAT MODEL */}
                {onlineMode && (
                  <div className="mt-6 pt-4 border-t border-red-950/40">
                    <div className="flex items-center gap-2 mb-2">
                      <Sliders className="w-4 h-4 text-red-400" />
                      <span className="text-xs font-bold text-gray-300">Yapay Zeka Modeli</span>
                    </div>
                    <div className="space-y-1.5">
                      <button 
                        onClick={() => setSelectedModel('gemini-3.5-flash')}
                        className={`w-full text-left text-xs px-2.5 py-1.5 rounded-lg border font-semibold block transition-colors ${
                          selectedModel === 'gemini-3.5-flash'
                            ? 'bg-[#3d1114] border-red-500/50 text-red-400 shadow-[0_0_12px_rgba(239,68,68,0.2)]'
                            : 'bg-[#150709] border-[#2e0d11] text-gray-400 hover:text-white hover:bg-[#250d11]'
                        }`}
                      >
                        🚀 Gemini 3.5 Flash (Önerilen)
                      </button>
                      <button 
                        onClick={() => setSelectedModel('gemini-3.1-pro-preview')}
                        className={`w-full text-left text-xs px-2.5 py-1.5 rounded-lg border font-semibold block transition-colors ${
                          selectedModel === 'gemini-3.1-pro-preview'
                            ? 'bg-[#3d1114] border-red-500/50 text-red-400 shadow-[0_0_12px_rgba(239,68,68,0.2)]'
                            : 'bg-[#150709] border-[#2e0d11] text-gray-400 hover:text-white hover:bg-[#250d11]'
                        }`}
                      >
                        🧠 Gemini 3.1 Pro (Gelişmiş Kod)
                      </button>
                      <button 
                        onClick={() => setSelectedModel('deepseek-chat')}
                        className={`w-full text-left text-xs px-2.5 py-1.5 rounded-lg border font-semibold block transition-colors ${
                          selectedModel === 'deepseek-chat'
                            ? 'bg-[#3d1114] border-red-500/55 text-rose-400 shadow-[0_0_12px_rgba(239,68,68,0.2)]'
                            : 'bg-[#150709] border-[#2e0d11] text-gray-400 hover:text-white hover:bg-[#250d11]'
                        }`}
                      >
                        🐳 DeepSeek V3 (Akıllı & Hızlı)
                      </button>
                      <button 
                        onClick={() => setSelectedModel('deepseek-reasoning')}
                        className={`w-full text-left text-xs px-2.5 py-1.5 rounded-lg border font-semibold block transition-colors ${
                          selectedModel === 'deepseek-reasoning'
                            ? 'bg-[#3d1114] border-red-500/55 text-rose-400 shadow-[0_0_12px_rgba(239,68,68,0.2)]'
                            : 'bg-[#150709] border-[#2e0d11] text-gray-400 hover:text-white hover:bg-[#250d11]'
                        }`}
                      >
                        🧠 DeepSeek R1 (Derin Düşünsel)
                      </button>
                    </div>

                    {/* API Key Configuration for DeepSeek */}
                    {(selectedModel === 'deepseek-chat' || selectedModel === 'deepseek-reasoning') && (
                      <div className="mt-3 bg-[#1e0a0c] p-2.5 rounded-lg border border-red-500/20 animate-fadeIn text-left">
                        <div className="flex items-center gap-1.5 text-[10px] font-bold text-red-400 mb-1.5 uppercase">
                          <Lock className="w-3.5 h-3.5" />
                          <span>DeepSeek API Anahtarı</span>
                        </div>
                        <p className="text-[9px] text-gray-400 leading-relaxed mb-2">
                          DeepSeek modellerini online çalıştırmak için resmi anahtarınızı girin. (Kendi tarayıcınızda güvenli biçimde şifreli saklanır)
                        </p>
                        <input
                          type="password"
                          value={deepseekApiKey}
                          onChange={(e) => {
                            const val = e.target.value;
                            setDeepseekApiKey(val);
                            localStorage.setItem('amorfly_deepseek_api_key', val);
                          }}
                          placeholder="sk-..."
                          className="w-full bg-[#110507] border border-red-950 text-[11px] px-2 py-1 rounded text-red-300 font-mono focus:outline-none focus:border-red-500"
                        />
                        <div className="mt-1 flex items-center justify-between text-[8.5px] text-gray-500">
                          <span>Durum: {deepseekApiKey ? 'Kaydedildi (Lokal)' : 'Girilmedi'}</span>
                          <a 
                            href="https://platform.deepseek.com/" 
                            target="_blank" 
                            rel="noreferrer"
                            className="text-red-400 hover:underline"
                          >
                            Anahtar Edin ↗
                          </a>
                        </div>
                      </div>
                    )}
                  </div>
                )}

                {/* QUICK OS INTEGRATION COMMANDS LIST */}
                <div className="mt-auto pt-6">
                  <div className="bg-[#1a0507] p-3 rounded-xl border border-red-500/15 shadow-[0_0_12px_rgba(239,68,68,0.06)]">
                    <div className="flex items-center gap-2 text-xs font-black text-rose-400 uppercase tracking-widest mb-2 font-mono">
                      <Terminal className="w-3.5 h-3.5 text-red-400 animate-pulse" />
                      <span>Sürüm Kılavuzu</span>
                    </div>
                    <div className="space-y-1 text-[10.5px] leading-relaxed text-slate-400">
                      <div className="flex items-start gap-1">
                        <span className="text-red-400 shrink-0">•</span>
                        <span>Mod değiştirmek üst paneldeki toggle ile yapılır.</span>
                      </div>
                      <div className="flex items-start gap-1">
                        <span className="text-red-400 shrink-0">•</span>
                        <span>Excel sayfaları otomatik tablo gridine dönüştürülür.</span>
                      </div>
                      <div className="flex items-start gap-1">
                        <span className="text-red-400 shrink-0">•</span>
                        <span>Yerel terminal komut listesi için CLI tabında help yazın.</span>
                      </div>
                    </div>
                  </div>
                </div>
              </>
            )}
          </div>

          {/* MAIN COLUMN CONTAINER */}
          <main className="flex-1 flex flex-col overflow-hidden relative">

            {/* SCREEN: CHAT INTERFACE */}
            {activeTab === 'chat' && (
              <div className="flex-1 flex flex-col overflow-hidden relative bg-white text-slate-900 border-l border-slate-100">
                {/* Chat Feed */}
                <div className="flex-1 overflow-y-auto px-4 py-6 md:px-8 space-y-6 bg-slate-50/50">
                  {messages.map((msg) => (
                    <div 
                      key={msg.id}
                      className={`flex gap-4 max-w-4xl mx-auto ${msg.role === 'user' ? 'justify-end' : 'justify-start'}`}
                    >
                      {/* Avatar for assistant */}
                      {msg.role === 'assistant' && (
                        <div className="w-8 h-8 rounded-lg bg-[#0e1626] border border-[#ef4444]/30 text-[#ef4444] font-sans flex items-center justify-center font-extrabold shadow-sm text-sm tracking-tighter shrink-0 select-none drop-shadow-[0_0_6px_rgba(239,68,68,0.7)]">
                          A
                        </div>
                      )}

                      <div className={`flex flex-col max-w-[85%] ${msg.role === 'user' ? 'items-end' : 'items-start'}`}>
                        {/* Meta header */}
                        <span className="text-[10px] text-slate-400 mb-1 font-mono uppercase tracking-wider">
                          {msg.role === 'user' ? 'Soran Kişi // U-SESSION' : 'Amorfly AI // SYS-RESP'} • {msg.timestamp}
                        </span>

                        {/* Content text display */}
                        <div className={`rounded-xl px-4 py-3 text-xs md:text-sm shadow-sm leading-relaxed border ${
                          msg.role === 'user'
                            ? 'bg-red-50 border-red-100 text-red-950 shadow-[0_2px_8px_rgba(239,68,68,0.04)]'
                            : 'bg-white border-slate-200 text-[#1e293b] shadow-[0_2px_8px_rgba(0,0,0,0.03)]'
                        }`}>
                          {/* Rich File attachment pill inside message if any */}
                          {msg.attachedFile && (
                            <div className="flex items-center gap-2 mb-2 p-1.5 bg-slate-100 rounded-lg text-[10px] text-slate-600 font-mono border border-slate-200 select-none">
                              <FileText className="w-3.5 h-3.5" />
                              <span>Analiz Bağlamı: {msg.attachedFile.fileName}</span>
                            </div>
                           )}

                          {/* Markdown parsing styled printer */}
                          <div className="prose max-w-none text-xs md:text-[13.5px]">
                            {msg.content.split('\n').map((line, idx) => {
                              // Treat simple headings
                              if (line.startsWith('### ')) {
                                const headingText = line.replace('### ', '');
                                const isWelcome = headingText.includes('Merhaba, Ben Amorfly AI!');
                                return (
                                  <div key={idx} className={isWelcome ? "flex flex-col items-center text-center w-full" : ""}>
                                    <h3 className="text-sm font-bold text-red-650 mt-3 mb-1 font-sans">{headingText}</h3>
                                    {isWelcome && (
                                      <div className="my-5 flex flex-col items-center justify-center p-5 rounded-2xl bg-white border border-red-200 max-w-sm mx-auto shadow-[0_5px_20px_rgba(239,68,68,0.08)] relative overflow-hidden">
                                        <div className="absolute top-0 left-0 right-0 h-[2px] bg-gradient-to-r from-transparent via-red-500 to-transparent animate-pulse" />
                                        {/* Minimal spinning outer HUD around brand card logo */}
                                        <div className="w-24 h-24 relative flex items-center justify-center">
                                          <div className="absolute inset-0 animate-spin" style={{ animationDuration: '10s' }}>
                                            <svg className="w-full h-full text-red-400/40" viewBox="0 0 100 100">
                                              <circle cx="50" cy="50" r="46" fill="none" stroke="currentColor" strokeWidth="2" strokeDasharray="4 6" />
                                            </svg>
                                          </div>
                                          <span className="text-4xl font-extrabold font-sans text-transparent bg-clip-text bg-gradient-to-br from-red-600 to-rose-500 drop-shadow-[0_0_6px_rgba(220,38,38,0.4)]">A</span>
                                        </div>
                                        <span className="text-[10px] uppercase font-extrabold tracking-widest text-[#ef4444] mt-3 animate-pulse font-mono">Amorfly AI Core Active</span>
                                        
                                        {/* Dynamic Launcher troubleshooting card built right where user operates */}
                                        <div className="mt-4 p-2.5 bg-slate-50 border border-slate-200 rounded-lg text-left text-[10px] text-slate-600 leading-relaxed font-sans">
                                          <div className="flex items-center gap-1 mb-1 font-black uppercase text-red-500">
                                            <AlertCircle className="w-3.5 h-3.5 shrink-0" />
                                            <span>Masaüstü Bağlantı Kılavuzu</span>
                                          </div>
                                          Lokal bilgisayardaki <code className="text-[#ef4444] bg-red-50 px-1 rounded font-mono font-bold">.desktop</code> simgesine çift tıkladığınızda açılmıyorsa:
                                          <div className="space-y-1 mt-1.5 list-none pl-0 text-slate-500">
                                            <div>🌐 <b>Neden:</b> Sanal bulut sunucusu boşta kaldığında uyku moduna geçer ve tarayıcı çerezi yetkilendirmesi ister.</div>
                                            <div>💡 <b>Çözüm 1:</b> Tarayıcınızda bu pencereyi bir kere ziyaret ederek bulut sunucusunu uyandırın.</div>
                                            <div>🚀 <b>Çözüm 2 (Önerilen):</b> Sol menüdeki <b>"Masaüstü & Mobil Kurulumu"</b> sekmesine gidip <b>%100 Çevrimdışı Bağımsız Python</b> programını indirerek internet bağımlılığını tamamen ortadan kaldırın!</div>
                                          </div>
                                        </div>
                                      </div>
                                    )}
                                  </div>
                                );
                              }
                              if (line.startsWith('#### ')) {
                                return <h4 key={idx} className="text-xs font-bold text-red-500 mt-2 mb-1">{line.replace('#### ', '')}</h4>;
                              }
                              if (line.startsWith('**') && line.endsWith('**')) {
                                return <p key={idx} className="font-bold text-slate-900 my-1">{line.replace(/\*\*/g, '')}</p>;
                              }
                              {/* Bullet list */}
                              if (line.startsWith('- ')) {
                                return (
                                  <div key={idx} className="flex items-start gap-1.5 ml-1 my-1">
                                    <span className="text-red-500 shrink-0">•</span>
                                    <span className="text-slate-800">{line.replace('- ', '')}</span>
                                  </div>
                                );
                              }
                              {/* Number list */}
                              if (/^\d+\.\s/.test(line)) {
                                return (
                                  <div key={idx} className="flex items-start gap-1.5 ml-1 my-1">
                                    <span className="text-red-500 shrink-0 font-mono text-xxs font-black">{line.match(/^\d+\./)?.[0]}</span>
                                    <span className="text-slate-800">{line.replace(/^\d+\.\s/, '')}</span>
                                  </div>
                                );
                              }
                              {/* Simple Code block formatting inline or full block */}
                              if (line.startsWith('```')) {
                                return null; // We filter and design it manually downstream or print block
                              }
                              return <p key={idx} className="my-1.5 leading-relaxed text-slate-800">{line}</p>;
                            })}
                          </div>
                        </div>

                        {/* Interactive action icons below message */}
                        <div className="flex items-center gap-2.5 mt-1.5 px-1 opacity-70 hover:opacity-100 transition-opacity">
                          <button 
                            onClick={() => handleCopy(msg.content, msg.id)}
                            className="p-1 hover:bg-slate-150 text-slate-400 hover:text-slate-600 rounded transition-colors flex items-center justify-center border border-slate-200 bg-white shadow-sm"
                            title="Yanıtı Kopyala"
                          >
                            {copiedId === msg.id ? (
                              <Check className="w-3.5 h-3.5 text-green-500" />
                            ) : (
                              <Copy className="w-3.5 h-3.5" />
                            )}
                          </button>

                          {msg.role === 'assistant' && (
                            <>
                              <button 
                                onClick={() => exportMessageToExcel(msg.content, `amorfly-excel-analiz`)}
                                className="flex items-center gap-1 px-2 py-0.5 text-[10px] bg-emerald-50 border border-emerald-200 hover:border-emerald-400 hover:bg-emerald-100 text-emerald-700 rounded transition-all font-mono shadow-sm"
                                title="Excel Tablosu Olarak İndir (.xlsx)"
                              >
                                <FileSpreadsheet className="w-3 h-3 text-emerald-600" />
                                <span className="font-sans font-medium">Excel (.xlsx)</span>
                              </button>

                              <button 
                                onClick={() => exportMessageToWord(msg.content, `amorfly-word-rapor`)}
                                className="flex items-center gap-1 px-2 py-0.5 text-[10px] bg-blue-50 border border-blue-200 hover:border-blue-400 hover:bg-blue-100 text-blue-700 rounded transition-all font-mono shadow-sm"
                                title="Word Belgesi Olarak İndir (.doc)"
                              >
                                <FileText className="w-3 h-3 text-blue-600" />
                                <span className="font-sans font-medium">Word (.doc)</span>
                              </button>

                              <button 
                                onClick={() => exportMessageToPdf(msg.content, `amorfly-pdf-rapor`)}
                                className="flex items-center gap-1 px-2 py-0.5 text-[10px] bg-rose-50 border border-rose-200 hover:border-rose-450 hover:bg-rose-100 text-rose-700 rounded transition-all font-mono shadow-sm"
                                title="PDF Olarak Kaydet / Yazdır"
                              >
                                <Download className="w-3 h-3 text-rose-600" />
                                <span className="font-sans font-medium">PDF Raporu</span>
                              </button>
                            </>
                          )}
                        </div>

                      </div>
                    </div>
                  ))}

                  {/* Loading pulse assistant */}
                  {isGenerating && (
                    <div className="flex gap-4 max-w-4xl mx-auto justify-start">
                      <div className="w-8 h-8 rounded-lg bg-[#0e1626] border border-[#ef4444]/30 text-[#ef4444] font-sans flex items-center justify-center font-extrabold animate-pulse text-sm shrink-0 select-none drop-shadow-[0_0_6px_rgba(239,68,68,0.7)]">
                        A
                      </div>
                      <div className="flex flex-col items-start">
                        <span className="text-[10px] text-slate-400 mb-1 font-mono">Düşünce Çekirdeği Çalışıyor...</span>
                        <div className="bg-slate-100 border border-slate-200/50 rounded-xl px-4 py-3 shadow-sm flex items-center gap-3">
                          <div className="flex space-x-1">
                            <div className="w-2.5 h-2.5 bg-red-500 rounded-full animate-bounce"></div>
                            <div className="w-2.5 h-2.5 bg-rose-400 rounded-full animate-bounce" style={{ animationDelay: '150ms' }}></div>
                            <div className="w-2.5 h-2.5 bg-red-400 rounded-full animate-bounce" style={{ animationDelay: '300ms' }}></div>
                          </div>
                          <span className="text-xs text-slate-600 italic font-mono">Amorfly veri motorunu tarıyor...</span>
                        </div>
                      </div>
                    </div>
                  )}

                  <div ref={chatBottomRef} />
                </div>

                {/* Floating Scroll to Bottom Down Arrow Button */}
                <button
                  type="button"
                  onClick={() => {
                    chatBottomRef.current?.scrollIntoView({ behavior: 'smooth' });
                  }}
                  className="absolute bottom-28 right-6 md:right-8 p-2.5 bg-gradient-to-r from-red-600 to-rose-500 hover:from-red-500 hover:to-rose-400 text-white rounded-full shadow-lg shadow-red-950/45 border border-red-500/30 transition-all hover:scale-110 z-20 cursor-pointer flex items-center justify-center animate-bounce duration-1000"
                  title="En Sona Git (Aşağı Ok)"
                >
                  <ChevronDown className="w-4.5 h-4.5 font-bold" />
                </button>

                {/* BOTTOM CHAT ACTION AREA */}
                <div className="p-4 border-t border-slate-200 bg-white relative z-10 shadow-[0_-4px_15px_rgba(0,0,0,0.03)] text-slate-800">
                  <form onSubmit={handleSendMessage} className="max-w-4xl mx-auto">
                    <div className="relative flex items-center bg-slate-50 border border-slate-200 rounded-xl focus-within:border-red-500/40 focus-within:shadow-[0_0_15px_rgba(239,68,68,0.08)] shadow-inner p-1 transition-all duration-300">
                      
                      {/* Attached File Small visual indicator inside keyboard input */}
                      {uploadedFile && (
                        <div className="absolute left-2.5 bg-red-50 text-[10px] text-red-650 px-2 py-1 rounded-lg flex items-center gap-1.5 border border-red-200 select-none shadow z-10 max-w-[124px] font-mono">
                          <FileText className="w-3 h-3 text-red-600 animate-pulse" />
                          <span className="truncate max-w-[80px] font-bold">{uploadedFile.fileName}</span>
                        </div>
                      )}

                      <input
                        type="text"
                        value={inputValue}
                        onChange={(e) => setInputValue(e.target.value)}
                        placeholder={uploadedFile ? "Belge hakkında bir soru sorun (örn. özetle, satır 4 verileri nedir?)" : "İşletim sistemi, VLC veya kodlama hakkında sesle ya da tuşlarla soru sorun..."}
                        className={`w-full bg-transparent text-slate-800 text-sm focus:outline-none placeholder-slate-400 py-3 block font-sans ${uploadedFile ? 'pl-[138px] pr-20' : 'px-4 pr-20'}`}
                        disabled={isGenerating}
                      />

                      {/* Voice Speech to Text Input with Active Animation */}
                      <button
                        type="button"
                        onClick={handleToggleVoiceCommand}
                        disabled={isGenerating}
                        className={`absolute right-11 p-1.5 rounded-lg transition-all cursor-pointer ${
                          isListeningSpeech 
                            ? 'bg-red-50 text-red-600 border border-red-200 animate-pulse' 
                            : 'hover:bg-slate-100 text-slate-400'
                        }`}
                        title={isListeningSpeech ? "Ses Dinleniyor... (Durdurmak için Tıklayın)" : "Sesle Komut Ver"}
                      >
                        {isListeningSpeech ? (
                          <Mic className="w-4 h-4 text-red-600 animate-ping" />
                        ) : (
                          <Mic className="w-4 h-4 text-slate-400" />
                        )}
                      </button>

                      <button
                        type="submit"
                        disabled={isGenerating || (!inputValue.trim() && !uploadedFile)}
                        className={`absolute right-1.5 p-2 rounded-lg text-white font-bold transition-all shadow-md cursor-pointer ${
                          isGenerating 
                            ? 'bg-slate-300 text-slate-500 opacity-50 cursor-not-allowed' 
                            : 'bg-gradient-to-r from-red-600 to-rose-600 hover:from-red-500 hover:to-rose-500 hover:shadow-[0_0_15px_rgba(239,68,68,0.3)]'
                        }`}
                        title="Talebi Sentezle"
                      >
                        <ArrowRight className="w-4.5 h-4.5 text-white" />
                      </button>

                    </div>
                    
                    <div className="flex items-center justify-between text-[11px] text-slate-500 mt-2 px-1 font-mono uppercase tracking-wider">
                      <div className="flex items-center gap-1">
                        <Lock className="w-3.5 h-3.5 text-red-500" />
                        <span>PROGRAM VERİLERİ LOKALDE MUHAFAZA EDER. DIŞ SIZINTI KALKANLA KİLİTLİDİR.</span>
                      </div>
                      <span className="font-mono text-red-650 font-bold">{onlineMode ? 'MOD: ONLINE (GEMINI)' : 'MOD: AMORFLY OFFLINE-SANDBOX'}</span>
                    </div>
                  </form>
                </div>
              </div>
            )}

            {/* SCREEN: ACTIVE FILE INSPECTOR / SPREADSHEEET TABLE GRID VIEW */}
            {activeTab === 'inspect' && (
              <div className="flex-1 flex flex-col overflow-hidden bg-[#242221]">
                
                {/* Header of Inspector */}
                <div className="h-[48px] border-b border-[#2d2a29] bg-[#1d1b1a] px-6 flex items-center justify-between">
                  <div className="flex items-center gap-2">
                    {uploadedFile?.xlsxData ? (
                      <div className="flex items-center gap-2">
                        <FileSpreadsheet className="w-5 h-5 text-emerald-400" />
                        <span className="text-xs md:text-sm font-bold text-gray-200">Excel Ayrıştırıcı Grid Masası: {uploadedFile.fileName}</span>
                      </div>
                    ) : (
                      <div className="flex items-center gap-2">
                        <FileText className="w-5 h-5 text-sky-400" />
                        <span className="text-xs md:text-sm font-bold text-gray-200">Metin / Belge Gösterici: {uploadedFile?.fileName}</span>
                      </div>
                    )}
                  </div>

                  {/* Excel Sheet buttons selector if multiple */}
                  {uploadedFile?.xlsxData && (
                    <div className="flex items-center gap-1.5 bg-[#252221] p-1 rounded-lg border border-[#3e3937]">
                      {Object.keys(uploadedFile.xlsxData).map((shName) => (
                        <button
                          key={shName}
                          onClick={() => setActiveExcelSheet(shName)}
                          className={`px-3 py-1 rounded-md text-[11.5px] font-bold transition-colors cursor-pointer ${
                            activeExcelSheet === shName
                              ? 'bg-emerald-600 text-white shadow-sm'
                              : 'text-gray-400 hover:text-white hover:bg-[#34302e]'
                          }`}
                        >
                          {shName}
                        </button>
                      ))}
                    </div>
                  )}
                </div>

                {/* Content Area */}
                <div className="flex-1 overflow-auto p-4 md:p-6">
                  
                  {uploadedFile ? (
                    <>
                      {/* Scenario A: EXCEL INTERACTIVE GRID RENDERING */}
                      {uploadedFile.xlsxData && activeExcelSheet && uploadedFile.xlsxData[activeExcelSheet] ? (
                        <div className="rounded-xl border border-[#3e3937] overflow-hidden bg-[#1c1a19] shadow-inner max-w-full">
                          <div className="overflow-x-auto">
                            <table className="w-full text-left text-xs text-gray-300 border-collapse table-auto">
                              <thead>
                                <tr className="bg-[#292523] border-b border-[#3e3937] text-gray-400 font-mono">
                                  <th className="py-2.5 px-3 border-r border-[#3e3937] w-12 text-center bg-[#211e1d]">Row</th>
                                  {uploadedFile.xlsxData[activeExcelSheet][0] && 
                                    (uploadedFile.xlsxData[activeExcelSheet][0] as any[]).map((_, idx) => (
                                      <th key={idx} className="py-2.5 px-4 border-r border-[#3e3937] font-bold">
                                        Kolon {String.fromCharCode(65 + idx)}
                                      </th>
                                    ))
                                  }
                                </tr>
                              </thead>
                              <tbody>
                                {uploadedFile.xlsxData[activeExcelSheet].slice(0, 50).map((row, rowIdx) => (
                                  <tr 
                                    key={rowIdx} 
                                    className={`border-b border-[#312e2d] hover:bg-[#252221] ${
                                      rowIdx === 0 ? 'bg-[#211e1d]/50 font-bold text-purple-300' : ''
                                    }`}
                                  >
                                    <td className="py-2 px-3 border-r border-[#3e3937] text-center font-mono font-bold bg-[#211e1d] text-gray-500">{rowIdx + 1}</td>
                                    {Array.isArray(row) ? (
                                      row.map((cell: any, cellIdx: number) => (
                                        <td key={cellIdx} className="py-2 px-4 border-r border-[#3d3a39] truncate max-w-[200px]">
                                          {cell !== undefined && cell !== null ? String(cell) : ''}
                                        </td>
                                      ))
                                    ) : (
                                      <td colSpan={24} className="py-2 px-4 text-gray-500 italic">Hatalı Satır Biçimi</td>
                                    )}
                                  </tr>
                                ))}
                              </tbody>
                            </table>
                          </div>
                          
                          {uploadedFile.xlsxData[activeExcelSheet].length > 50 && (
                            <div className="p-3 bg-[#1d1b1a] border-t border-[#3e3937] text-xs text-center text-gray-500">
                              ... Toplam {uploadedFile.xlsxData[activeExcelSheet].length} satırdan ilk 50 satır listeleniyor ...
                            </div>
                          )}
                        </div>
                      ) : (
                        /* Scenario B: COMMON TEXT / REGEX PARSING PREVIEW */
                        <div className="bg-[#1c1a19] rounded-xl p-5 border border-[#3e3937] shadow-inner font-mono text-xs text-gray-300 leading-relaxed overflow-y-auto whitespace-pre-wrap max-h-[85vh]">
                          <div className="flex items-center gap-1.5 border-b border-[#3e3937] pb-3 mb-4 font-sans font-bold">
                            <Sparkles className="w-4 h-4 text-orange-400" />
                            <span>İndekslenen Çekirdek Metin İçeriği :</span>
                          </div>
                          {uploadedFile.text || 'Bu dosyanın ayrıştırılmış metin arabelleği boştur.'}
                        </div>
                      )}
                    </>
                  ) : (
                    <div className="flex flex-col items-center justify-center py-20 text-gray-500">
                      <Lock className="w-12 h-12 text-[#e95420] mb-4 opacity-25" />
                      <p className="text-sm font-bold font-sans">Ayrıştırılmış veri bulunamadı.</p>
                      <p className="text-xs text-gray-600 font-sans mt-1">Önizleme yapmak için sol panelden bir Excel veya PDF dosyası sürükleyip yükleyin.</p>
                    </div>
                  )}

                </div>
              </div>
            )}

            {/* SCREEN: SECURE TERMINAL UBUNTU INSPIRED INTERACTION */}
            {activeTab === 'terminal' && (
              <div className="flex-1 flex flex-col overflow-hidden bg-[#100109] text-green-400 font-mono text-sm leading-relaxed p-4 select-text">
                
                {/* Simulated Panel Title */}
                <div className="flex items-center justify-between border-b border-purple-950/40 pb-2 mb-4">
                  <div className="flex items-center gap-2">
                    <span className="w-3.5 h-3.5 rounded-full bg-red-500 block"></span>
                    <span className="w-3.5 h-3.5 rounded-full bg-yellow-500 block"></span>
                    <span className="w-3.5 h-3.5 rounded-full bg-green-500 block"></span>
                    <span className="text-xs text-gray-400 ml-2 font-bold select-none">amorfly@ubuntu-secure-sandbox: ~</span>
                  </div>
                  <span className="text-xs text-purple-300 bg-purple-950/40 px-2 py-0.5 rounded border border-purple-900 select-none font-sans font-semibold">Terminal</span>
                </div>

                {/* History Stream */}
                <div className="flex-1 overflow-y-auto space-y-3 px-2">
                  <div className="text-gray-500 select-none"># Amorfly Yerel Güvenlik Kalkanı Yetkilendirmeli Terminale hoş geldiniz.</div>
                  <div className="text-gray-500 select-none"># Komut listesini görmek için "help" yazıp Enter tuşuna basın.</div>
                  
                  {terminalHistory.map((item, idx) => (
                    <div key={idx} className="space-y-1">
                      <div className="flex items-start gap-1.5">
                        <span className="text-[#e95420] font-black select-none">amorfly-ai$</span>
                        <span className="text-white font-bold">{item.cmd}</span>
                      </div>
                      <div className={`pl-4 whitespace-pre-wrap select-text ${
                        item.type === 'err' 
                          ? 'text-red-400 border-l-2 border-red-950 pl-2' 
                          : item.type === 'system' 
                            ? 'text-purple-300' 
                            : 'text-green-400'
                      }`}>
                        {item.out}
                      </div>
                    </div>
                  ))}

                  <div ref={terminalBottomRef} />
                </div>

                {/* Bottom CLI Form input */}
                <form onSubmit={handleTerminalSubmit} className="mt-4 pt-3 border-t border-purple-950/40 flex items-center gap-1.5 bg-[#1a010f] p-1.5 rounded-lg border border-purple-950">
                  <span className="text-[#e95420] font-black pl-1.5 select-none animate-pulse">amorfly-ai$</span>
                  <input
                    type="text"
                    value={terminalCommand}
                    onChange={(e) => setTerminalCommand(e.target.value)}
                    placeholder="help, sys-info, file-status, security-check, logs..."
                    className="flex-1 bg-transparent text-white focus:outline-none focus:ring-0 font-mono text-sm border-0 py-1.5"
                    autoFocus
                  />
                  <button 
                    type="submit"
                    className="bg-[#e95420] text-black font-extrabold px-3 py-1 rounded text-xs select-none hover:bg-orange-400 transition-colors"
                  >
                    RUN
                  </button>
                </form>

              </div>
            )}

            {/* SCREEN: DEEP LEAKAGE LOG HISTORY AUDITOR (MOCK SIZINTI BLOKAJ TABI) */}
            {activeTab === 'storage' && (
              <div className="flex-1 flex flex-col overflow-hidden p-6 bg-[#21201f]">
                
                <div className="flex items-center gap-1.5 mb-2">
                  <Shield className="w-5.5 h-5.5 text-orange-400" />
                  <h2 className="text-base font-black text-gray-200 uppercase tracking-widest font-sans">Ağ Çekirdeği Güvenlik Günlüğü</h2>
                </div>
                <p className="text-xs text-gray-500 font-sans mb-6">
                  Bu panel, Amorfly AI sunucusundaki yerel işlemlerin sızıntı denetim günlüklerini (Zero-Leakage Protection logs) canlı listeler. 
                  Yüklenen doküman parçalarının nerede çözümlendiğini ve ağ kalkanını buradan doğrulayabilirsiniz.
                </p>

                {/* LOGS GRID STREAM */}
                <div className="flex-1 rounded-xl border border-[#3e3937] bg-[#1a1817] p-4 overflow-y-auto shadow-inner space-y-2 font-mono text-xs">
                  
                  {systemStatus?.activeLogs && systemStatus.activeLogs.length > 0 ? (
                    systemStatus.activeLogs.map((log, index) => (
                      <div 
                        key={index} 
                        className={`p-2.5 rounded-lg border flex flex-col md:flex-row md:items-center justify-between gap-2 transition-all ${
                          log.status === 'SECURE'
                            ? 'bg-emerald-950/20 border-emerald-900/60 text-emerald-300'
                            : log.status === 'WARNING'
                              ? 'bg-amber-950/20 border-amber-900/60 text-amber-300'
                              : 'bg-zinc-900/40 border-[#322f2e] text-[#bfbfbf]'
                        }`}
                      >
                        <div className="flex items-start gap-2 max-w-[80%]">
                          <span className="text-gray-500 font-sans shrink-0">[{log.timestamp.substring(11, 19)}]</span>
                          <div className="space-y-0.5">
                            <span className="font-bold tracking-wider mr-2 uppercase text-[11px] text-[#e95420]">{log.type}</span>
                            <span className="text-xxs block md:inline text-gray-400">{log.details}</span>
                          </div>
                        </div>

                        <span className={`px-2 py-0.5 rounded-full text-[9px] font-bold tracking-widest font-sans self-start md:self-auto ${
                          log.status === 'SECURE'
                            ? 'bg-emerald-950 text-emerald-400 border border-emerald-850'
                            : log.status === 'WARNING'
                              ? 'bg-amber-950 text-amber-400 border border-amber-850'
                              : 'bg-indigo-950 text-indigo-400 border border-indigo-850'
                        }`}>
                          {log.status}
                        </span>
                      </div>
                    ))
                  ) : (
                    <div className="text-center py-20 text-gray-600">
                      Hiç aktif güvenlik günlüğü bulunamadı. Yapay zekaya veri göndererek yeni log tetikleyebilirsiniz.
                    </div>
                  )}

                </div>

                <div className="mt-4 p-4 rounded-xl bg-[#2a171d] border border-[#522533] flex items-center gap-3">
                  <AlertCircle className="w-5 h-5 text-pink-400 shrink-0" />
                  <div className="text-[11.5px] leading-relaxed text-pink-300 font-sans">
                    <strong>Güvenlik Taahhüdü:</strong> Amorfly AI yerel çalışma alanında üretilen tüm sarmal meta veriler, 
                    hiçbir reklam veya dış analitik sunucusuna aktarılmaksızın %100 oranında bu uygulamada saklanır.
                  </div>
                </div>

              </div>
            )}

            {/* SCREEN: ADVANCED MULTIMEDIA & ENGINEERING PIPELINE ORCHESTRATION */}
            {activeTab === 'pipelines' && (
              <div className="flex-1 overflow-y-auto p-4 md:p-6 bg-[#040714] space-y-6 select-text">
                
                {/* Header Section */}
                <div className="flex flex-col md:flex-row md:items-center justify-between gap-4 border-b border-slate-800 pb-5">
                  <div className="space-y-1">
                    <div className="flex items-center gap-2">
                      <Cpu className="w-6 h-6 text-[#38bdf8] animate-pulse" />
                      <h2 className="text-lg font-black text-white uppercase tracking-wider font-sans">
                        Sınır Bilişim Entegre İş Akışları (Orchestrated Pipelines)
                      </h2>
                    </div>
                    <p className="text-xs text-slate-400 font-sans">
                      Gemini 3.5 orkestrasyonu altında Multimedya (A Tipi), Mühendislik (B Tipi) ve Çapraz Platform Masaüstü Derleyici (C Tipi) motoru.
                    </p>
                  </div>

                  {/* Mode Selector Tabs (Blue-Black styled) */}
                  <div className="flex flex-wrap items-center gap-2 bg-[#0d1527] p-1 rounded-xl border border-slate-800 shadow-inner">
                    <button
                      onClick={() => setPipelineMode('multimedia')}
                      className={`px-4 py-2 rounded-lg text-xs font-bold transition-all duration-200 cursor-pointer flex items-center gap-2 ${
                        pipelineMode === 'multimedia'
                          ? 'bg-blue-600/30 text-cyan-400 border border-cyan-400/20 shadow-md'
                          : 'text-slate-400 hover:text-white'
                      }`}
                    >
                      <span className="w-2 h-2 rounded-full bg-red-500 animate-pulse"></span>
                      A Tipi: Multimedya (AI Dublaj)
                    </button>
                    <button
                      onClick={() => setPipelineMode('engineering')}
                      className={`px-4 py-2 rounded-lg text-xs font-bold transition-all duration-200 cursor-pointer flex items-center gap-2 ${
                        pipelineMode === 'engineering'
                          ? 'bg-blue-600/30 text-cyan-400 border border-cyan-400/20 shadow-md'
                          : 'text-slate-400 hover:text-white'
                      }`}
                    >
                      <span className="w-2 h-2 rounded-full bg-emerald-500 animate-pulse"></span>
                      B Tipi: Mühendislik & İnşaat (CAD/Metraj)
                    </button>
                    <button
                      onClick={() => setPipelineMode('desktop')}
                      className={`px-4 py-2 rounded-lg text-xs font-bold transition-all duration-200 cursor-pointer flex items-center gap-2 ${
                        pipelineMode === 'desktop'
                          ? 'bg-blue-600/30 text-cyan-400 border border-cyan-400/20 shadow-md'
                          : 'text-slate-400 hover:text-white'
                      }`}
                    >
                      <span className="w-2 h-2 rounded-full bg-purple-500 animate-pulse"></span>
                      C Tipi: Masaüstü Paketleyici (.EXE / .AppImage)
                    </button>
                  </div>
                </div>

                {pipelineMode === 'multimedia' ? (
                  /* ==========================================================
                     PIPELINE A: MULTIMEDIA AI DUBBING PIPELINE
                     ========================================================== */
                  <div className="grid grid-cols-1 lg:grid-cols-12 gap-6">
                    
                    {/* Input Config Row */}
                    <div className="lg:col-span-5 bg-[#0a0f1d] border border-slate-800 rounded-2xl p-5 md:p-6 space-y-5">
                      <div className="flex items-center gap-2 border-b border-slate-800 pb-3">
                        <span className="text-xs bg-blue-950 text-cyan-400 px-2 py-0.5 rounded font-mono font-bold">1</span>
                        <h3 className="text-xs md:text-sm font-black text-slate-200 uppercase tracking-wider">
                          Girdi ve Sentez Parametreleri
                        </h3>
                      </div>

                      {/* File Source */}
                      <div className="space-y-1.5">
                        <label className="text-[11px] font-bold text-slate-400 tracking-wide block uppercase">
                          Hedef Video / Ses Medya Kaynağı
                        </label>
                        <select
                          value={mediaFileName}
                          onChange={(e) => setMediaFileName(e.target.value)}
                          className="w-full bg-[#0d1527] border border-slate-800 rounded-xl px-3.5 py-2.5 text-xs text-white focus:outline-none focus:border-cyan-400 font-mono"
                        >
                          <option value="film_kesiti_ingilizce.mp4">film_kesiti_ingilizce.mp4 (Sample 1080p Clip)</option>
                          <option value="soylesi_ingilizce.mp3">soylesi_ingilizce.mp3 (Sample Speech)</option>
                          {uploadedFile && (
                            <option value={uploadedFile.fileName}>{uploadedFile.fileName} (Son Yüklenen Dosyanız)</option>
                          )}
                        </select>
                        <p className="text-[10px] text-slate-500 italic">
                          Dosya yükleyerek kendi orijinal sesinizi de pipeline girdisi olarak kullanabilirsiniz.
                        </p>
                      </div>

                      {/* Languages Select */}
                      <div className="grid grid-cols-2 gap-4">
                        <div className="space-y-1.5">
                          <label className="text-[11px] font-bold text-slate-400 block uppercase">Kaynak Dil</label>
                          <select
                            value={mediaSourceLang}
                            onChange={(e) => setMediaSourceLang(e.target.value)}
                            className="w-full bg-[#0d1527] border border-slate-800 rounded-xl p-2.5 text-xs text-white focus:outline-none focus:border-cyan-400"
                          >
                            <option value="en">İngilizce (English)</option>
                            <option value="de">Almanca (Deutsch)</option>
                            <option value="fr">Fransızca (Français)</option>
                            <option value="tr">Türkçe (Turkish)</option>
                          </select>
                        </div>
                        <div className="space-y-1.5">
                          <label className="text-[11px] font-bold text-slate-400 block uppercase">Hedef Dil (Dublaj)</label>
                          <select
                            value={mediaTargetLang}
                            onChange={(e) => setMediaTargetLang(e.target.value)}
                            className="w-full bg-[#0d1527] border border-slate-800 rounded-xl p-2.5 text-xs text-white focus:outline-none focus:border-cyan-400"
                          >
                            <option value="tr">Türkçe (Türkiye)</option>
                            <option value="en">İngilizce (UK/US)</option>
                            <option value="de">Almanca (DE)</option>
                            <option value="ar">Arapça (Middle East)</option>
                          </select>
                        </div>
                      </div>

                      {/* Voice Cloning and Enhancing Toggles */}
                      <div className="space-y-3 pt-2">
                        <div className="flex items-center justify-between p-3 bg-[#0d1527] rounded-xl border border-slate-800/40">
                          <div className="space-y-0.5">
                            <span className="text-xs font-bold text-slate-200 block">F5-TTS Voice Cloning</span>
                            <span className="text-[10px] text-slate-500 block">5 saniyelik orjinal tınıyla zero-shot kopyalama</span>
                          </div>
                          <input
                            type="checkbox"
                            checked={mediaVoiceCloning}
                            onChange={(e) => setMediaVoiceCloning(e.target.checked)}
                            className="w-4 h-4 rounded text-blue-600 bg-slate-900 border-slate-800 focus:ring-blue-500 cursor-pointer"
                          />
                        </div>

                        <div className="flex items-center justify-between p-3 bg-[#0d1527] rounded-xl border border-slate-800/40">
                          <div className="space-y-0.5">
                            <span className="text-xs font-bold text-slate-200 block">Intel HD Audio Noise Filter</span>
                            <span className="text-[10px] text-slate-500 block">Arka plan dipseslerini yapay zeka ile yok et</span>
                          </div>
                          <input
                            type="checkbox"
                            checked={mediaEnhanceAudio}
                            onChange={(e) => setMediaEnhanceAudio(e.target.checked)}
                            className="w-4 h-4 rounded text-blue-600 bg-slate-900 border-slate-800 focus:ring-blue-500 cursor-pointer"
                          />
                        </div>
                      </div>

                      {/* Run Trigger Button */}
                      <button
                        onClick={handleRunMultimediaPipeline}
                        disabled={mediaExecuting}
                        className={`w-full py-3.5 px-4 rounded-xl font-bold text-xs uppercase tracking-wider transition-all duration-200 select-none flex items-center justify-center gap-2 cursor-pointer ${
                          mediaExecuting
                            ? 'bg-slate-800 text-slate-500 cursor-not-allowed'
                            : 'bg-gradient-to-r from-blue-600 to-cyan-500 hover:from-blue-500 hover:to-cyan-400 text-white shadow-lg shadow-blue-500/10'
                        }`}
                      >
                        {mediaExecuting ? (
                          <>
                            <RefreshCw className="w-4 h-4 animate-spin text-cyan-400" />
                            Ses ve Dudak Sentezleniyor...
                          </>
                        ) : (
                          <>
                            <Play className="w-4 h-4 text-white fill-current" />
                            Cihaz Üzerinde Sentezlemeyi Başlat (Start Pipeline)
                          </>
                        )}
                      </button>

                    </div>

                    {/* Operational Flow Graph & Shell Logger Row */}
                    <div className="lg:col-span-7 space-y-6">
                      
                      {/* Interactive Visual Graph Nodes */}
                      <div className="bg-[#0a0f1d] border border-slate-800 rounded-2xl p-5 md:p-6 space-y-4">
                        <div className="flex items-center justify-between border-b border-slate-800 pb-3">
                          <div className="flex items-center gap-2">
                            <span className="text-xs bg-blue-950 text-cyan-400 px-2 py-0.5 rounded font-mono font-bold">2</span>
                            <h3 className="text-xs md:text-sm font-black text-slate-200 uppercase tracking-wider">
                              Yapay Zeka Motorları Akış Çizgesi (Flow Nodes)
                            </h3>
                          </div>
                          <span className="text-[10px] text-cyan-400 font-mono bg-blue-950/40 px-2 py-0.5 rounded border border-cyan-950/60">
                            Durum: {mediaExecuting ? 'Aktif' : mediaResultUrl ? 'Hazır' : 'Beklemede'}
                          </span>
                        </div>

                        {/* Staggered visual pipelines nodes */}
                        <div className="grid grid-cols-2 gap-3 md:grid-cols-3">
                          {[
                            { id: 1, title: 'Meta Demucs v4', desc: 'Vocal/BGM Splitter' },
                            { id: 2, title: 'WhisperX Aligner', desc: 'Kelime Zaman Damgaları' },
                            { id: 3, title: 'Gemini 3.5 Core', desc: 'Çeviri ve Süre Sentezi' },
                            { id: 4, title: 'F5-TTS Engine', desc: '5s Zero Shot Klonlayıcı' },
                            { id: 5, title: 'LatentSync HD', desc: 'Mouth Lip-Synchronizer' },
                            { id: 6, title: 'FFmpeg Core', desc: 'Medya Birleştirici' }
                          ].map((step) => {
                            const isPast = mediaCurrentStep > step.id;
                            const isCurrent = mediaCurrentStep === step.id;
                            return (
                              <div
                                key={step.id}
                                className={`p-3.5 rounded-xl border transition-all duration-300 relative overflow-hidden flex flex-col justify-between h-[84px] ${
                                  isCurrent
                                    ? 'bg-blue-950/30 border-cyan-400/80 shadow-md shadow-blue-500/10'
                                    : isPast
                                      ? 'bg-emerald-950/15 border-emerald-500/40 text-emerald-300'
                                      : 'bg-[#0d1527] border-slate-800 opacity-60 text-slate-400'
                                }`}
                              >
                                {isCurrent && (
                                  <div className="absolute top-0 left-0 right-0 h-0.5 bg-gradient-to-r from-blue-500 to-cyan-400 animate-pulse"></div>
                                )}
                                <div className="flex items-center justify-between">
                                  <span className="text-[10px] font-mono font-bold">#Node 0{step.id}</span>
                                  {isPast ? (
                                    <span className="text-[9px] bg-emerald-900/30 text-emerald-400 px-1.5 py-0.5 rounded font-black">OK</span>
                                  ) : isCurrent ? (
                                    <RefreshCw className="w-3 h-3 text-cyan-400 animate-spin" />
                                  ) : (
                                    <span className="text-[9px] bg-slate-900 text-slate-500 px-1.5 py-0.5 rounded">WAIT</span>
                                  )}
                                </div>
                                <div className="space-y-0.5 mt-2">
                                  <span className="text-xs font-bold text-slate-200 block truncate">{step.title}</span>
                                  <span className="text-[9px] text-slate-500 block truncate">{step.desc}</span>
                                </div>
                              </div>
                            );
                          })}
                        </div>
                      </div>

                      {/* Raw Terminal Splay Logs */}
                      <div className="bg-[#02050c] border border-slate-800 rounded-2xl p-5 text-gray-300 font-mono text-[11px] leading-relaxed space-y-3 shadow-inner">
                        <div className="flex items-center justify-between border-b border-slate-900 pb-2.5 text-gray-400 font-sans">
                          <span className="text-xxs font-bold tracking-widest uppercase">Canlı İşlem Log Terminali (AI Orchestrator logs)</span>
                          <span className="w-2.5 h-2.5 rounded-full bg-blue-500 block animate-pulse"></span>
                        </div>
                        
                        <div className="h-44 overflow-y-auto space-y-2 select-text px-1 custom-scrollbar">
                          {mediaLogs.length === 0 ? (
                            <span className="text-slate-500 block italic">Motor henüz tetiklenmedi. Başlatmak için parametreleri seçip "Sentezlemeyi Başlat" butonuna tıklayınız...</span>
                          ) : (
                            mediaLogs.map((log, idx) => (
                              <div key={idx} className="flex gap-2">
                                <span className="text-blue-500 shrink-0 font-bold select-none">[09:54:{30 + idx * 4}]</span>
                                <span className={idx === mediaLogs.length - 1 ? 'text-cyan-300 font-bold' : 'text-slate-300'}>
                                  {log.text}
                                </span>
                              </div>
                            ))
                          )}
                        </div>

                        {mediaResultUrl && (
                          <div className="p-3 bg-emerald-950/20 border border-emerald-900/50 rounded-xl space-y-2 mt-3 font-sans">
                            <div className="flex items-center gap-2 text-emerald-400 font-bold text-xs">
                              <span className="w-2 h-2 rounded-full bg-emerald-500"></span>
                              <span>Tüm Entegre Pipeline Başarıyla Sonuçlandı!</span>
                            </div>
                            <p className="text-[11px] text-slate-300">
                              Orijinal ses tonu ve karakteristiği korunarak %100 oranında Türkçe lokal dublör sesli ve dudak hareketli video dosyası üretildi. 
                            </p>
                            <div className="pt-2 flex flex-wrap gap-2">
                              <a
                                href={mediaResultUrl}
                                download
                                className="bg-emerald-600 hover:bg-emerald-500 text-white font-extrabold px-3 py-1.5 rounded-lg text-[10px] uppercase transition-all duration-200 cursor-pointer block"
                              >
                                📥 Dublajlı Mp4 Videoyu İndir
                              </a>
                              <span className="bg-slate-900 text-slate-400 px-3 py-1.5 rounded-lg text-[10px] border border-slate-800 font-mono">
                                Süre: 00:04:12 • Format: h264_AAC
                              </span>
                            </div>
                          </div>
                        )}
                      </div>

                    </div>

                  </div>
                ) : pipelineMode === 'engineering' ? (
                  /* ==========================================================
                     PIPELINE B: ENGINEERING CAD CONVERT METRAJ PIPELINE
                     ========================================================== */
                  <div className="grid grid-cols-1 lg:grid-cols-12 gap-6">
                    
                    {/* Setup block left span */}
                    <div className="lg:col-span-5 bg-[#0a0f1d] border border-slate-800 rounded-2xl p-5 md:p-6 space-y-5">
                      <div className="flex items-center gap-2 border-b border-slate-800 pb-3">
                        <span className="text-xs bg-blue-950 text-cyan-400 px-2 py-0.5 rounded font-mono font-bold">1</span>
                        <h3 className="text-xs md:text-sm font-black text-slate-200 uppercase tracking-wider">
                          Mühendislik & Metraj Girdileri
                        </h3>
                      </div>

                      {/* CAD File selection */}
                      <div className="space-y-1.5">
                        <label className="text-[11px] font-bold text-slate-400 tracking-wide block uppercase">
                          Mimari / Statik Proje Çizimi (CAD plan)
                        </label>
                        <select
                          value={uploadedFile ? uploadedFile.fileName : engFileName}
                          onChange={(e) => setEngFileName(e.target.value)}
                          className="w-full bg-[#0d1527] border border-slate-800 rounded-xl px-3.5 py-2.5 text-xs text-white focus:outline-none focus:border-cyan-400 font-mono"
                        >
                          <option value="zemin_kat_mimari_proje.dxf">zemin_kat_mimari_proje.dxf (Detaylı Apartman Kat Planı)</option>
                          <option value="daire_ornek_statik.dwg">daire_ornek_statik.dwg (Kolon-Kiriş Donatı Şeması)</option>
                          {uploadedFile && (
                            <option value={uploadedFile.fileName}>{uploadedFile.fileName} (Yüklediğiniz Dosya)</option>
                          )}
                        </select>
                        <p className="text-[10px] text-slate-500">
                          {uploadedFile 
                            ? `Yüklediğiniz "${uploadedFile.fileName}" belgesi çizim tablosunda metraj motorumuz tarafından doğrudan işlenebilecek.` 
                            : 'Kendi AutoCAD projenizi soldaki yükleme kutusuna sürükleyerek anında entegre edebilirsiniz.'}
                        </p>
                      </div>

                      {/* Base Height input (h) */}
                      <div className="space-y-1.5">
                        <label className="text-[11px] font-bold text-slate-400 block uppercase">
                          Varsayılan Kat Yüksekliği (h)
                        </label>
                        <div className="relative">
                          <input
                            type="number"
                            step="0.05"
                            value={engHeight}
                            onChange={(e) => setEngHeight(parseFloat(e.target.value) || 0)}
                            className="w-full bg-[#0d1527] border border-slate-800 rounded-xl pl-3.5 pr-10 py-2.5 text-xs text-white focus:outline-none focus:border-cyan-400 font-mono"
                          />
                          <span className="absolute right-3.5 top-2.5 text-[10px] text-slate-500 font-bold">METRE</span>
                        </div>
                        <p className="text-[10px] text-slate-500 italic">
                          Duvar hacmi (m³) hesaplanırken duvar çizgi uzunlukları bu değer ile çarpılır.
                        </p>
                      </div>

                      {/* Birim Fiyat Kaynağı */}
                      <div className="space-y-1.5">
                        <label className="text-[11px] font-bold text-slate-400 block uppercase">
                          Resmi Birim Fiyat Poz Kataloğu
                        </label>
                        <select
                          value={engPriceCatalog}
                          onChange={(e) => setEngPriceCatalog(e.target.value)}
                          className="w-full bg-[#0d1527] border border-slate-800 rounded-xl px-3.5 py-2.5 text-xs text-white focus:outline-none focus:border-cyan-400"
                        >
                          <option value="csb">Çevre ve Şehircilik Bakanlığı Resmi Poz Kataloğu (YTL - En Güncel)</option>
                          <option value="private">Özel Müteahhit ve Piyasa Ortalaması Alt Birim Fiyatları</option>
                        </select>
                      </div>

                      {/* Execution Trigger Button */}
                      <button
                        onClick={handleRunEngineeringPipeline}
                        disabled={engExecuting}
                        className={`w-full py-3.5 px-4 rounded-xl font-bold text-xs uppercase tracking-wider transition-all duration-200 select-none flex items-center justify-center gap-2 cursor-pointer ${
                          engExecuting
                            ? 'bg-slate-800 text-slate-500 cursor-not-allowed'
                            : 'bg-gradient-to-r from-blue-600 to-cyan-500 hover:from-blue-500 hover:to-cyan-400 text-white shadow-lg shadow-blue-500/10'
                        }`}
                      >
                        {engExecuting ? (
                          <>
                            <RefreshCw className="w-4 h-4 animate-spin text-cyan-400" />
                            ezdxf Katman Geometrisi Çözümleniyor...
                          </>
                        ) : (
                          <>
                            <Play className="w-4 h-4 text-white fill-current" />
                            Metraji ve Poz Analizini Başlat (Run Quantity Engine)
                          </>
                        )}
                      </button>

                    </div>

                    {/* Operational Flow Graph & Shell Logger Row */}
                    <div className="lg:col-span-7 space-y-6">
                      
                      {/* Flowchart step nodes */}
                      <div className="bg-[#0a0f1d] border border-slate-800 rounded-2xl p-5 md:p-6 space-y-4">
                        <div className="flex items-center justify-between border-b border-slate-800 pb-3">
                          <div className="flex items-center gap-2">
                            <span className="text-xs bg-blue-950 text-cyan-400 px-2 py-0.5 rounded font-mono font-bold">2</span>
                            <h3 className="text-xs md:text-sm font-black text-slate-200 uppercase tracking-wider">
                              CAD-to-Excel Entegre Dönüşüm Adımları
                            </h3>
                          </div>
                          <span className="text-[10px] text-emerald-400 font-mono bg-blue-950/40 px-2 py-0.5 rounded border border-emerald-950/60 font-black">
                            Durum: {engExecuting ? 'Hesaplanıyor' : engFinished ? 'Tamamlandı' : 'Beklemede'}
                          </span>
                        </div>

                        {/* Staggered visual pipelines nodes */}
                        <div className="grid grid-cols-2 gap-3 md:grid-cols-5">
                          {[
                            { id: 1, title: 'OdaFileConverter', desc: 'DWG / DXF' },
                            { id: 2, title: 'ezdxf Reader', desc: 'Katman Detektörü' },
                            { id: 3, title: 'Takeoff Python', desc: 'Hacim Hesaplama' },
                            { id: 4, title: 'Gemini 3.5 AI', desc: 'Semantik Poz Eşleme' },
                            { id: 5, title: 'OpenPyXL Excel', desc: 'Keşif Şablonlama' }
                          ].map((step) => {
                            const isPast = engCurrentStep > step.id;
                            const isCurrent = engCurrentStep === step.id;
                            return (
                              <div
                                key={step.id}
                                className={`p-2 py-3 rounded-xl border transition-all duration-300 relative overflow-hidden flex flex-col justify-between h-[80px] ${
                                  isCurrent
                                    ? 'bg-blue-950/30 border-cyan-400/80 shadow-md shadow-blue-500/10'
                                    : isPast
                                      ? 'bg-emerald-950/15 border-emerald-500/40 text-emerald-300'
                                      : 'bg-[#0d1527] border-slate-800 opacity-65 text-slate-400'
                                }`}
                              >
                                <span className="text-[8px] font-mono font-bold">#Node 0{step.id}</span>
                                <div className="space-y-0.5 mt-1.5">
                                  <span className="text-[11px] font-bold text-slate-200 block truncate">{step.title}</span>
                                  <span className="text-[8px] text-slate-500 block truncate">{step.desc}</span>
                                </div>
                              </div>
                            );
                          })}
                        </div>
                      </div>

                      {/* Log Area */}
                      {engLogs.length > 0 && (
                        <div className="bg-[#02050c] border border-slate-800 rounded-2xl p-4 text-gray-300 font-mono text-[10.5px] leading-relaxed max-h-36 overflow-y-auto">
                          {engLogs.map((log, idx) => (
                            <div key={idx} className="flex gap-2">
                              <span className="text-emerald-500 shrink-0 font-bold select-none">[QUANT-ENGINE]</span>
                              <span className="text-slate-300">{log}</span>
                            </div>
                          ))}
                        </div>
                      )}

                      {/* Real output table & Excel download */}
                      {engFinished && engLayers.length > 0 && (
                        <div className="bg-[#0a0f1d] border border-slate-800 rounded-2xl p-5 md:p-6 space-y-4">
                          <div className="flex items-center justify-between border-b border-slate-800 pb-3">
                            <h3 className="text-xs md:text-sm font-black text-slate-200 uppercase tracking-widest">
                              Yapay Zeka Destekli Metraj Listesi & Metraj Tutarları
                            </h3>
                            <button
                              onClick={handleDownloadExcel}
                              className="bg-emerald-600 hover:bg-emerald-500 text-white text-[11px] font-extrabold px-3 py-1.5 rounded-lg flex items-center gap-1.5 transition-colors cursor-pointer"
                            >
                              <FileSpreadsheet className="w-4 h-4 animate-bounce" />
                              Profesyonel Excel (.xlsx) Keşif Özetini İndir
                            </button>
                          </div>

                          <div className="overflow-x-auto rounded-xl border border-slate-800 bg-[#0d1527]">
                            <table className="w-full text-left text-xs border-collapse">
                              <thead>
                                <tr className="bg-[#11192e] border-b border-slate-800 text-slate-400 font-mono text-[10px]">
                                  <th className="p-2.5">Bakanlık Poz No</th>
                                  <th className="p-2.5">Metraj Elemanı İmalatı</th>
                                  <th className="p-2.5 text-center">Birim</th>
                                  <th className="p-2.5 text-right">Ölçülen Miktar</th>
                                  <th className="p-2.5 text-right">Birim Fiyat</th>
                                  <th className="p-2.5 text-right">Tutar (KDV Haric)</th>
                                </tr>
                              </thead>
                              <tbody>
                                {engLayers.map((lay: any, idx: number) => {
                                  const total = lay.quantity * lay.unitPrice;
                                  return (
                                    <tr key={idx} className="border-b border-slate-800/65 hover:bg-slate-900/45 text-[11px] text-slate-300">
                                      <td className="p-2.5 font-mono text-cyan-400 font-bold">{lay.pozNo}</td>
                                      <td className="p-2.5">{lay.name} ({lay.layer})</td>
                                      <td className="p-2.5 text-center font-bold text-slate-400">{lay.unit}</td>
                                      <td className="p-2.5 text-right font-mono font-bold text-slate-200">{lay.quantity.toLocaleString('tr-TR', { minimumFractionDigits: 1, maximumFractionDigits: 2 })}</td>
                                      <td className="p-2.5 text-right font-mono font-bold text-slate-200">{lay.unitPrice.toLocaleString('tr-TR')} TL</td>
                                      <td className="p-2.5 text-right font-mono font-black text-white">{total.toLocaleString('tr-TR')} TL</td>
                                    </tr>
                                  );
                                })}
                                <tr className="bg-[#11192e] font-bold">
                                  <td colSpan={5} className="p-3 text-right text-slate-400 font-sans uppercase">Açık Kaynak Sentezlenmiş Genel Toplam:</td>
                                  <td className="p-3 text-right font-mono font-black text-[#38bdf8] text-sm">{engGrandTotal.toLocaleString('tr-TR')} TL</td>
                                </tr>
                              </tbody>
                            </table>
                          </div>

                        </div>
                      )}

                    </div>

                  </div>
                ) : (
                  /* ==========================================================
                     PIPELINE C: STANDALONE DESKTOP WRAPPER PACKAGER (.EXE / .APPIMAGE)
                     ========================================================== */
                  <div className="grid grid-cols-1 lg:grid-cols-12 gap-6">
                    {/* Setup Config Block */}
                    <div className="lg:col-span-5 bg-[#0a0f1d] border border-slate-800 rounded-2xl p-5 md:p-6 space-y-5">
                      <div className="flex items-center gap-2 border-b border-slate-800 pb-3">
                        <span className="text-xs bg-purple-950 text-purple-400 px-2 py-0.5 rounded font-mono font-bold">1</span>
                        <h3 className="text-xs md:text-sm font-black text-slate-200 uppercase tracking-wider">
                          Paketleme & Derleme Kurulumu
                        </h3>
                      </div>

                      {/* App Name input */}
                      <div className="space-y-1.5">
                        <label className="text-[11px] font-bold text-slate-400 tracking-wide block uppercase">
                          Masaüstü Program Adı
                        </label>
                        <input
                          type="text"
                          value={desktopAppName}
                          onChange={(e) => setDesktopAppName(e.target.value)}
                          className="w-full bg-[#0d1527] border border-slate-800 rounded-xl px-3.5 py-2.5 text-xs text-white focus:outline-none focus:border-purple-400 font-bold font-sans"
                          placeholder="Örn: Amorfly Metraj Sentezleyici Pro"
                        />
                      </div>

                      {/* App Source Core Selector */}
                      <div className="space-y-1.5">
                        <label className="text-[11px] font-bold text-slate-400 tracking-wide block uppercase">
                          Arayüz ve Kod Şablon Türü
                        </label>
                        <select
                          value={desktopAppType}
                          onChange={(e) => setDesktopAppType(e.target.value)}
                          className="w-full bg-[#0d1527] border border-slate-800 rounded-xl p-2.5 text-xs text-white focus:outline-none focus:border-purple-400 font-sans"
                        >
                          <option value="engineering">B Tipi: Metraj & CAD Hesaplama Programı (CustomTkinter)</option>
                          <option value="multimedia">A Tipi: Ses Klonlama & AI Dublaj Player (CustomTkinter)</option>
                        </select>
                        <p className="text-[10px] text-slate-500 italic">
                          Seçilen modülün Python (CustomTkinter) grafiksel ve mantıksal kodları Gemini 3.5 tarafından otomatik olarak yazılır.
                        </p>
                      </div>

                      {/* Target Platform Segmented Toggle */}
                      <div className="space-y-1.5">
                        <label className="text-[11px] font-bold text-slate-400 tracking-wide block uppercase">
                          Hedef İşletim Sistemi (Target OS)
                        </label>
                        <div className="grid grid-cols-3 gap-2 bg-[#0d1527] p-1 rounded-xl border border-slate-800/60 font-sans">
                          <button
                            type="button"
                            onClick={() => setDesktopTargetOS('linux')}
                            className={`py-2 text-[10px] font-bold rounded-lg cursor-pointer transition-colors ${
                              desktopTargetOS === 'linux' ? 'bg-purple-600/30 text-white border border-purple-500/20' : 'text-slate-400 hover:text-white'
                            }`}
                          >
                            🐧 Linux (.AppImage)
                          </button>
                          <button
                            type="button"
                            onClick={() => setDesktopTargetOS('deb')}
                            className={`py-2 text-[10px] font-bold rounded-lg cursor-pointer transition-colors ${
                              desktopTargetOS === 'deb' ? 'bg-purple-600/30 text-white border border-purple-500/20' : 'text-slate-400 hover:text-white'
                            }`}
                          >
                            📦 Debian / Ubuntu (.DEB)
                          </button>
                          <button
                            type="button"
                            onClick={() => setDesktopTargetOS('windows')}
                            className={`py-2 text-[10px] font-bold rounded-lg cursor-pointer transition-colors ${
                              desktopTargetOS === 'windows' ? 'bg-purple-600/30 text-white border border-purple-500/20' : 'text-slate-400 hover:text-white'
                            }`}
                          >
                            🪟 Windows (.EXE)
                          </button>
                        </div>
                      </div>

                      {/* Package Trigger Button */}
                      <button
                        onClick={handleRunDesktopPipeline}
                        disabled={desktopExecuting}
                        className={`w-full py-3.5 px-4 rounded-xl font-bold text-xs uppercase tracking-wider transition-all duration-200 flex items-center justify-center gap-2 cursor-pointer font-sans ${
                          desktopExecuting
                            ? 'bg-slate-800 text-slate-500 cursor-not-allowed'
                            : 'bg-gradient-to-r from-purple-600 to-indigo-500 hover:from-purple-500 hover:to-indigo-400 text-white shadow-lg shadow-purple-500/10'
                        }`}
                      >
                        {desktopExecuting ? (
                          <>
                            <RefreshCw className="w-4 h-4 animate-spin text-purple-400 bg-transparent inline" />
                            PyInstaller Standalone Paket Yapılıyor...
                          </>
                        ) : (
                          <>
                            <Sliders className="w-4 h-4 text-white" />
                            Bağımsız Masaüstü Programını Sentezle
                          </>
                        )}
                      </button>

                    </div>

                    {/* Operational Flow Graph & Shell Logger Row */}
                    <div className="lg:col-span-7 space-y-6">
                      
                      {/* Flowchart step nodes */}
                      <div className="bg-[#0a0f1d] border border-slate-800 rounded-2xl p-5 md:p-6 space-y-4 font-sans">
                        <div className="flex items-center justify-between border-b border-slate-800 pb-3">
                          <div className="flex items-center gap-2">
                            <span className="text-xs bg-purple-950 text-purple-400 px-2 py-0.5 rounded font-mono font-bold">2</span>
                            <h3 className="text-xs md:text-sm font-black text-slate-200 uppercase tracking-wider">
                              Yapay Zeka Sentezi & Derleme Akışı
                            </h3>
                          </div>
                          <span className="text-[10px] text-purple-400 font-mono bg-purple-950/40 px-2 py-0.5 rounded border border-purple-950/60 font-black">
                            Durum: {desktopExecuting ? 'Derleniyor' : desktopFinished ? 'Başarılı' : 'Beklemede'}
                          </span>
                        </div>

                        {/* Staggered visual pipelines nodes */}
                        <div className="grid grid-cols-2 gap-3 md:grid-cols-5">
                          {[
                            { id: 1, title: 'Gemini Python', desc: 'CustomTkinter yazımı' },
                            { id: 2, title: 'Platform Analizi', desc: 'Bağımlılık tespiti' },
                            { id: 3, title: 'PyInstaller Engine', desc: '--onefile modülü' },
                            { id: 4, title: 'UPX Sıkıştırma', desc: 'Gömülü CPython' },
                            { id: 5, title: 'Binary Dağıtım', desc: 'VLC Tarzı Launcher' }
                          ].map((step) => {
                            const isPast = desktopCurrentStep > step.id;
                            const isCurrent = desktopCurrentStep === step.id;
                            return (
                              <div
                                key={step.id}
                                className={`p-2 py-3 rounded-xl border transition-all duration-300 relative overflow-hidden flex flex-col justify-between h-[80px] ${
                                  isCurrent
                                    ? 'bg-purple-950/30 border-purple-400/80 shadow-md shadow-purple-500/10'
                                    : isPast
                                      ? 'bg-emerald-950/15 border-emerald-500/40 text-emerald-300'
                                      : 'bg-[#0d1527] border-slate-800 opacity-65 text-slate-400'
                                }`}
                              >
                                <span className="text-[8px] font-mono font-bold font-mono text-[8px]">#Node 0{step.id}</span>
                                <div className="space-y-0.5 mt-1.5">
                                  <span className="text-[10px] font-semibold text-slate-200 block truncate leading-tight">{step.title}</span>
                                  <span className="text-[8px] text-slate-500 block truncate leading-tight">{step.desc}</span>
                                </div>
                              </div>
                            );
                          })}
                        </div>
                      </div>

                      {/* Log Area */}
                      {desktopLogs.length > 0 && (
                        <div className="bg-[#02050c] border border-slate-800 rounded-2xl p-4 text-gray-300 font-mono text-[10.5px] leading-relaxed max-h-36 overflow-y-auto">
                          {desktopLogs.map((log, idx) => (
                            <div key={idx} className="flex gap-2">
                              <span className="text-purple-500 shrink-0 font-bold select-none">[PYINSTALLER-ENGINE]</span>
                              <span className="text-slate-300">{log}</span>
                            </div>
                          ))}
                        </div>
                      )}

                      {/* Output section upon finished */}
                      {desktopFinished && (
                        <div className="space-y-6">
                          
                          {/* Code and Bash panels spacer tab */}
                          <div className="bg-[#0a0f1d] border border-slate-800 rounded-2xl p-5 md:p-6 space-y-4">
                            <div className="flex items-center justify-between border-b border-slate-800 pb-3">
                              <h3 className="text-xs md:text-sm font-black text-slate-200 uppercase tracking-widest font-sans">
                                🧠 Gemini 3.5 Tarafından Yazılan Yerel Python Kodu
                              </h3>
                              <button
                                onClick={() => {
                                  navigator.clipboard.writeText(desktopPythonSource);
                                  setCopiedId('py_src');
                                  setTimeout(() => setCopiedId(null), 2000);
                                }}
                                className="bg-[#121b2e] hover:bg-slate-800 text-slate-300 text-[10px] font-extrabold px-3 py-1.5 rounded-lg border border-slate-800 cursor-pointer font-sans"
                              >
                                {copiedId === 'py_src' ? 'Kod Kopyalandı! ✓' : 'Kodu Kopyala'}
                              </button>
                            </div>
                            <pre className="p-4 bg-black/60 border border-slate-800 text-[10.5px] text-slate-300 font-mono rounded-xl overflow-x-auto max-h-56">
                              {desktopPythonSource}
                            </pre>
                          </div>

                          {/* Bash or PowerShell installer script instruction */}
                          <div className="bg-[#0a0f1d] border border-slate-800 rounded-2xl p-5 md:p-6 space-y-4">
                            <div className="flex flex-col md:flex-row md:items-center justify-between border-b border-slate-800 pb-3 gap-2">
                              <div>
                                <h3 className="text-xs md:text-sm font-black text-slate-200 uppercase tracking-widest font-sans">
                                  {desktopTargetOS === 'windows' ? '🪟 Windows PowerShell Kurulum Betiği' : desktopTargetOS === 'deb' ? '📦 Debian / Ubuntu .DEB Paket Derleme Betiği' : '💻 Zorin OS / Ubuntu Terminal Kurulum Betiği (Bash Script)'}
                                </h3>
                                <p className="text-[10px] text-slate-500 mt-0.5 font-sans">
                                  {desktopTargetOS === 'windows' ? 'Windows PowerShell ortamı için optimize edilmiş, Python ve CustomTkinter bağımlılıklarını kurup masaüstü kısayolu oluşturan betik.' : desktopTargetOS === 'deb' ? 'Sisteminizde standart bir .deb paketi inşa etmek için gereken talimatları ve kontrol dosyalarını otomatik yapılandırır.' : 'Uygulamayı doğrudan bilgisayara kaydeder, simgesini oluşturur ve başlatıcıya entegre eder.'}
                                </p>
                              </div>
                              <div className="flex items-center gap-2 shrink-0">
                                <a
                                  href={`/api/download-installer?targetOS=${desktopTargetOS}`}
                                  download={desktopTargetOS === 'windows' ? 'install-amorfly.ps1' : 'install-amorfly.sh'}
                                  className="bg-indigo-900/60 hover:bg-indigo-800 text-indigo-200 text-[10px] font-extrabold px-3 py-1.5 rounded-lg border border-indigo-800/40 cursor-pointer text-center font-sans block"
                                >
                                  📥 Betiği İndir
                                </a>
                                <button
                                  onClick={() => {
                                    navigator.clipboard.writeText(desktopBashScript);
                                    setCopiedId('bash_src');
                                    setTimeout(() => setCopiedId(null), 2000);
                                  }}
                                  className="bg-purple-900/60 hover:bg-purple-800 text-purple-200 text-[10px] font-extrabold px-3 py-1.5 rounded-lg border border-purple-800/40 cursor-pointer font-sans"
                                >
                                  {copiedId === 'bash_src' ? 'Betiği Kopyaladı! ✓' : '📋 Betiği Kopyala'}
                                </button>
                              </div>
                            </div>

                            <div className="p-3 bg-[#131f37] border border-purple-500/15 text-pink-300 text-xxs font-mono rounded-xl leading-relaxed">
                              {desktopTargetOS === 'windows' ? (
                                <>
                                  💡 <b>Windows'ta Kolayca Kurun:</b>
                                  <div className="mt-2 space-y-1 text-[11px] text-slate-300 font-sans list-none">
                                    <li>1. Sağ üstteki <b>"Betiği Kopyala"</b> butonuna tıklayarak kurulum komutlarını kopyalayın.</li>
                                    <li>2. Masaüstünüzde boş bir yere sağ tıklayıp <b>Yeni → Metin Belgesi</b> oluşturun.</li>
                                    <li>3. Belgeyi açın, kopyaladığınız kodları yapıştırın ve <b>Dosya → Farklı Kaydet</b> diyerek adını <code className="text-yellow-300 bg-black/40 px-1 py-0.5 rounded font-mono">install.ps1</code> yapın (Kayıt Türü: Tüm Dosyalar seçilmelidir).</li>
                                    <li>4. <code className="text-yellow-300 bg-black/40 px-1 py-0.5 rounded font-mono">install.ps1</code> dosyasına sağ tıklayıp <b>PowerShell ile Çalıştır</b> (Run with PowerShell) seçeneğine basın. Kurulum otomatik tamamlanacaktır!</li>
                                  </div>
                                </>
                              ) : desktopTargetOS === 'deb' ? (
                                <>
                                  💡 <b>Hemen Çalıştırın:</b> Zorin OS terminalinizde <code className="text-yellow-300 bg-black/40 px-1 py-0.5 rounded">nano build_deb_{desktopAppName.toLowerCase().replace(/\s/g, "_")}.sh</code> yazıp kopyaladığınız betiği yapıştırın ve kaydedin. Ardından alttaki komutla paketi otomatik derleyip VLC gibi kurun:
                                  <div className="bg-black/50 p-2 text-yellow-250 rounded mt-2 select-all font-bold">
                                    chmod +x build_deb_{desktopAppName.toLowerCase().replace(/\s/g, "_")}.sh && ./build_deb_{desktopAppName.toLowerCase().replace(/\s/g, "_")}.sh
                                  </div>
                                </>
                              ) : (
                                <>
                                  💡 <b>Hemen Çalıştırın:</b> Zorin OS terminalinizde <code className="text-yellow-300 bg-black/40 px-1 py-0.5 rounded">nano install_{desktopAppName.toLowerCase().replace(/\s/g, "_")}.sh</code> yazıp kopyaladığınız betiği yapıştırın ve kaydedin. Ardından alttaki komutla VLC gibi menüye ekleyin:
                                  <div className="bg-black/50 p-2 text-yellow-250 rounded mt-2 select-all font-bold">
                                    chmod +x install_{desktopAppName.toLowerCase().replace(/\s/g, "_")}.sh && ./install_{desktopAppName.toLowerCase().replace(/\s/g, "_")}.sh
                                  </div>
                                </>
                              )}
                            </div>

                            <pre className="p-4 bg-black/60 border border-slate-800 text-[10.5px] text-slate-300 font-mono rounded-xl overflow-x-auto max-h-56">
                              {desktopBashScript}
                            </pre>
                          </div>

                          {/* Download executable button */}
                          <div className="bg-[#0a0f1d] border border-slate-800 rounded-2xl p-5 md:p-6 flex flex-col sm:flex-row items-center justify-between gap-4 font-sans">
                            <div className="space-y-1">
                              <h4 className="text-xs font-black text-white uppercase">Derlenmiş Tekil Program Paket Dosyası</h4>
                              <p className="text-[11px] text-slate-400">Üretilen standalone ikili dosya, arka şebekede gizli ajanlar veya servisler olmadan tamamen lokal hafızada çalışır.</p>
                            </div>
                            <a
                              href={desktopDownloadUrl}
                              download={`amorfly_${desktopAppName.toLowerCase().replace(/\s/g, "_")}_standalone.${desktopTargetOS === 'windows' ? 'exe' : desktopTargetOS === 'deb' ? 'deb' : 'AppImage'}`}
                              className="w-full sm:w-auto bg-purple-600 hover:bg-purple-500 text-white font-extrabold text-xs px-5 py-3 rounded-xl shadow-md transition-all flex items-center justify-center gap-2 cursor-pointer shrink-0"
                            >
                              <Download className="w-4 h-4" />
                              <span>{desktopTargetOS === 'windows' ? 'Windows için Bağımsız Programı İndir (.EXE)' : desktopTargetOS === 'deb' ? 'Debian / Ubuntu için Kurulum Paketini İndir (.DEB)' : 'Linux için Bağımsız Programı İndir (.AppImage)'}</span>
                            </a>
                          </div>

                        </div>
                      )}

                    </div>
                  </div>
                )}

              </div>
            )}

            {/* SCREEN: AMORFLY VLC INTEGRATED CYBER MULTIMEDIA PLAYER */}
            {activeTab === 'player' && (() => {
              const themeColorMap: Record<string, { themeGlow: string, accentHex: string, brandText: string, gradient: string, btnBg: string, accentBorder: string, badgeBg: string }> = {
                'vlc-amber': {
                  themeGlow: 'shadow-amber-500/10',
                  accentHex: '#e95420',
                  brandText: 'text-amber-400',
                  gradient: 'from-amber-600 via-yellow-500 to-orange-500',
                  btnBg: 'bg-amber-600 hover:bg-amber-500',
                  accentBorder: 'border-amber-500/30',
                  badgeBg: 'bg-amber-500/10 text-amber-400 border-amber-500/20'
                },
                'cyber-pink': {
                  themeGlow: 'shadow-pink-500/12',
                  accentHex: '#ff007f',
                  brandText: 'text-pink-400',
                  gradient: 'from-pink-600 via-fuchsia-500 to-purple-600',
                  btnBg: 'bg-pink-600 hover:bg-pink-500',
                  accentBorder: 'border-pink-500/30',
                  badgeBg: 'bg-pink-500/10 text-pink-400 border-pink-500/20'
                },
                'matrix-green': {
                  themeGlow: 'shadow-emerald-500/10',
                  accentHex: '#39ff14',
                  brandText: 'text-emerald-400',
                  gradient: 'from-[#00ff66] via-emerald-500 to-teal-600',
                  btnBg: 'bg-emerald-600 hover:bg-emerald-500',
                  accentBorder: 'border-emerald-500/30',
                  badgeBg: 'bg-emerald-500/10 text-emerald-400 border-emerald-500/20'
                },
                'neon-blue': {
                  themeGlow: 'shadow-sky-500/10',
                  accentHex: '#00f0ff',
                  brandText: 'text-sky-400',
                  gradient: 'from-sky-500 via-blue-500 to-indigo-600',
                  btnBg: 'bg-sky-600 hover:bg-sky-550',
                  accentBorder: 'border-sky-500/30',
                  badgeBg: 'bg-sky-500/10 text-sky-400 border-sky-500/20'
                }
              };

              const curTheme = themeColorMap[vlcCompiledTheme] || themeColorMap['vlc-amber'];

              const generatedPythonCode = `#!/usr/bin/env python3
# ==============================================================================
#             AMORFLY AI - GENERATED VLC MULTIMEDIA PLAYER CODE
#               (Target System: Zorin OS, Ubuntu, Debian Linux)
# ==============================================================================

import os
import sys
import tkinter as tk
from tkinter import ttk, messagebox, filedialog
import vlc # python-vlc

class AmorflyVLCDynamicPlayer(tk.Tk):
    def __init__(self):
        super().__init__()
        self.title("Amorfly AI - VLC Player (Custom Build)")
        self.geometry("900x650")
        self.configure(bg="#080c18")
        
        # Sentezlenen Değişkenler
        self.theme_accent = "${curTheme.accentHex}"
        self.has_equalizer = ${vlcCompiledEq ? "True" : "False"}
        self.has_subtitles = ${vlcCompiledSub ? "True" : "False"}
        self.volume_boost = ${vlcCompiledEffect ? "True" : "False"}

        # VLC Instance
        self.instance = vlc.Instance("--no-xlib")
        self.player = self.instance.media_player_new()
        
        self.setup_ui()
        
    def setup_ui(self):
        # Header, Video Frame, Controls Bar, Equalizer Panel
        print("[Amorfly Engine] VLC Player başarıyla başlatıldı. Sentezlenen Tema: ${vlcCompiledTheme.toUpperCase()}")

    def load_media(self, file_path):
        media = self.instance.media_new(file_path)
        self.player.set_media(media)
        self.player.play()

if __name__ == "__main__":
    app = AmorflyVLCDynamicPlayer()
    app.mainloop()
`;

              return (
                <div className="flex-1 overflow-y-auto p-6 bg-[#080d1a] space-y-8 select-text">
                  <style>{`
                    @keyframes bounceEqualizer {
                      0% { height: 4px; }
                      15% { height: 18px; }
                      30% { height: 35px; }
                      41% { height: 12px; }
                      58% { height: 48px; }
                      72% { height: 22px; }
                      87% { height: 40px; }
                      100% { height: 6px; }
                    }
                  `}</style>

                  {/* Header Section */}
                  <div className="flex flex-col md:flex-row md:items-center justify-between gap-4 border-b border-[#1e293b] pb-6">
                    <div className="space-y-1">
                      <div className="flex items-center gap-2">
                        <Cpu className={`w-6 h-6 ${curTheme.brandText} animate-pulse`} />
                        <h2 className="text-lg font-black text-gray-100 uppercase tracking-widest font-sans">Amorfly AI Oynatıcı Kod Sentezleyicisi ve Derleme Laboratuvarı 🚀</h2>
                      </div>
                      <p className="text-xs text-gray-400 font-sans">
                        Seçtiğiniz donanım, grafik teması ve ek katman parametrelerine göre VLC benzeri çift tıklanabilir yerel medya oynatıcı tasarlatın, simüle edin ve kod kütüphanesini indirin.
                      </p>
                    </div>
                    <span className={`text-[10px] px-3 py-1 ${curTheme.badgeBg} rounded-full font-mono font-bold shadow-md shrink-0`}>
                      ● Yapay Zeka Tabanlı VLC Kod Motoru
                    </span>
                  </div>

                  {/* Compilation Setup Deck */}
                  <div className="bg-[#0c1224] border border-[#1e293b] rounded-2xl p-5 md:p-6 shadow-xl space-y-5 font-sans">
                    <div className="flex items-center gap-2 pb-2 border-b border-slate-800">
                      <Sparkles className={`w-4 h-4 ${curTheme.brandText}`} />
                      <h3 className="text-xs font-black text-white uppercase tracking-wider">1. Oynatıcı Yapay Zeka Tasarım Kriterleri</h3>
                    </div>

                    <div className="grid grid-cols-1 md:grid-cols-3 gap-5">
                      {/* Left: Prompt entry */}
                      <div className="md:col-span-2 space-y-2">
                        <label className="text-xxs text-gray-400 font-bold block uppercase tracking-wider">Tasarım Prompt Açıklaması</label>
                        <textarea
                          rows={3}
                          value={vlcCompilerPrompt}
                          onChange={(e) => setVlcCompilerPrompt(e.target.value)}
                          placeholder="Örn: Bana cyberneon pembesi renklerinde, akıllı altyazı desteği olan, %200 ses artırma özellikli bir VLC alternatifi oynatıcı tasarla..."
                          className="w-full bg-[#030612] border border-slate-800 rounded-xl p-3 text-xs text-gray-200 outline-none focus:border-blue-500/50 resize-none font-sans leading-relaxed"
                        />
                      </div>

                      {/* Right: Theme Selector and Presets */}
                      <div className="space-y-2">
                        <label className="text-xxs text-gray-400 font-bold block uppercase tracking-wider">Arayüz Grafik Teması</label>
                        <div className="grid grid-cols-2 gap-2">
                          {[
                            { id: 'vlc-amber', label: 'VLC Amber 🍊', color: '#e95420' },
                            { id: 'cyber-pink', label: 'Cyber Pink 🌸', color: '#ff007f' },
                            { id: 'matrix-green', label: 'Matrix Green 🟩', color: '#39ff14' },
                            { id: 'neon-blue', label: 'Neon Blue 🟦', color: '#00f0ff' }
                          ].map((themeOpt) => (
                            <button
                              key={themeOpt.id}
                              onClick={() => setVlcCompiledTheme(themeOpt.id)}
                              className={`py-2 px-3 border rounded-xl font-bold text-xxs transition-all text-left flex items-center gap-1.5 cursor-pointer ${
                                vlcCompiledTheme === themeOpt.id
                                  ? 'bg-[#0e162d] text-white border-blue-500/40 shadow-inner'
                                  : 'bg-[#030612] border-slate-800 text-slate-400 hover:text-white hover:border-slate-700'
                              }`}
                            >
                              <span className="w-2 h-2 rounded-full shrink-0" style={{ backgroundColor: themeOpt.color }}></span>
                              <span>{themeOpt.label}</span>
                            </button>
                          ))}
                        </div>
                      </div>
                    </div>

                    {/* Checkboxes selection */}
                    <div className="grid grid-cols-2 md:grid-cols-4 gap-3 pt-2">
                      <label className="flex items-center gap-2 bg-[#030612] border border-slate-800/80 p-3 rounded-xl cursor-pointer hover:border-slate-700 transition-all select-none">
                        <input
                          type="checkbox"
                          checked={vlcCompiledEq}
                          onChange={(e) => setVlcCompiledEq(e.target.checked)}
                          className="w-4 h-4 text-blue-600 border-gray-350 rounded focus:ring-blue-500 cursor-pointer"
                        />
                        <div className="leading-tight">
                          <span className="text-xxs font-black text-gray-200 block">Grafik Ekolayzer</span>
                          <span className="text-[9px] text-slate-500 block">Frekans ses filtreleri</span>
                        </div>
                      </label>

                      <label className="flex items-center gap-2 bg-[#030612] border border-slate-800/80 p-3 rounded-xl cursor-pointer hover:border-slate-700 transition-all select-none">
                        <input
                          type="checkbox"
                          checked={vlcCompiledSub}
                          onChange={(e) => setVlcCompiledSub(e.target.checked)}
                          className="w-4 h-4 text-blue-600 border-gray-350 rounded focus:ring-blue-500 cursor-pointer"
                        />
                        <div className="leading-tight">
                          <span className="text-xxs font-black text-gray-200 block">Akıllı Altyazı Düzeni</span>
                          <span className="text-[9px] text-slate-500 block">Canlı çeviri & overlay</span>
                        </div>
                      </label>

                      <label className="flex items-center gap-2 bg-[#030612] border border-slate-800/80 p-3 rounded-xl cursor-pointer hover:border-slate-700 transition-all select-none">
                        <input
                          type="checkbox"
                          checked={vlcCompiledEffect}
                          onChange={(e) => setVlcCompiledEffect(e.target.checked)}
                          className="w-4 h-4 text-blue-600 border-gray-350 rounded focus:ring-blue-500 cursor-pointer"
                        />
                        <div className="leading-tight">
                          <span className="text-xxs font-black text-gray-200 block">%200 Ses Kuvvetlendirme</span>
                          <span className="text-[9px] text-slate-500 block">Amplifikatör kazancı</span>
                        </div>
                      </label>

                      <button
                        onClick={handleVlcCompile}
                        disabled={vlcIsCompiling}
                        className={`w-full text-white font-extrabold text-xs px-5 py-3 rounded-xl shadow-md transition-all flex items-center justify-center gap-2 cursor-pointer shrink-0 bg-gradient-to-r ${curTheme.gradient} ${vlcIsCompiling ? 'opacity-50 cursor-not-allowed animate-pulse' : 'hover:scale-[1.02]'}`}
                      >
                        <RefreshCw className={`w-4 h-4 ${vlcIsCompiling ? 'animate-spin' : ''}`} />
                        <span>{vlcIsCompiling ? 'Oynatıcı Derleniyor...' : 'Özel VLC Oynatıcıyı Derle'}</span>
                      </button>
                    </div>

                    {/* Compilation Console output */}
                    {(vlcIsCompiling || vlcCompilationLogs.length > 0) && (
                      <div className="mt-4 p-4 bg-black/60 border border-slate-800/80 rounded-xl space-y-2">
                        <div className="flex items-center justify-between">
                          <span className="text-[10px] font-black uppercase text-gray-400 font-mono tracking-wider animate-pulse">⚙️ Amorfly AI Kod Sentezleme Çıktıları:</span>
                          <span className="text-[9px] font-mono font-black text-slate-500 leading-none">Aşama {vlcCurrentStep + 1}/4</span>
                        </div>
                        <div className="space-y-1 font-mono text-[10.5px] text-slate-350 leading-relaxed max-h-40 overflow-y-auto">
                          {vlcCompilationLogs.map((log, index) => (
                            <div key={index} className="border-l-2 border-slate-800 pl-2 py-0.5 whitespace-pre-wrap">{log}</div>
                          ))}
                        </div>
                      </div>
                    )}
                  </div>

                  {/* Generated Dynamic VLC Player Core Simulator & Testing Frame */}
                  <div className="grid grid-cols-1 lg:grid-cols-3 gap-6">
                  
                  {/* Left Column (2/3 width) - Cinematic Player View & Scrubbing Elements */}
                  <div className="lg:col-span-2 space-y-4">
                    
                    {/* Media Screen Container Frame */}
                    <div className="relative rounded-2xl border border-slate-800 bg-[#02050c] overflow-hidden shadow-2xl flex flex-col justify-center items-center">
                      
                      {/* Visual Filter overlay mapping using standard tailwind filter filters */}
                      <div className={`w-full flex items-center justify-center transition-all duration-300 ${
                        playerVisualFilter === 'sepia' ? 'sepia contrast-95 saturate-110 brightness-95' :
                        playerVisualFilter === 'grayscale' ? 'grayscale contrast-125' :
                        playerVisualFilter === 'contrast' ? 'contrast-150 saturate-125 brightness-105' :
                        playerVisualFilter === 'hue' ? 'hue-rotate-90 saturate-150' : ''
                      }`}>
                        
                        {playerTrack.type === 'video' ? (
                          <video
                            ref={playerVideoRef}
                            src={playerTrack.url}
                            className={`w-full ${playerAspectRatio} object-contain transition-all duration-300 max-h-[460px] bg-black`}
                            onTimeUpdate={(e) => setPlayerCurrentTime(e.currentTarget.currentTime)}
                            onLoadedMetadata={(e) => setPlayerDuration(e.currentTarget.duration)}
                            onEnded={() => setPlayerIsPlaying(false)}
                            autoPlay={playerIsPlaying}
                            onClick={() => {
                              if (playerVideoRef.current) {
                                if (playerIsPlaying) {
                                  playerVideoRef.current.pause();
                                  setPlayerIsPlaying(false);
                                } else {
                                  playerVideoRef.current.play();
                                  setPlayerIsPlaying(true);
                                }
                              }
                            }}
                          />
                        ) : (
                          /* Render Audio visual screen with animated equalizer */
                          <div className="w-full h-[360px] bg-gradient-to-br from-[#0a1128] via-[#02050c] to-[#12041b] flex flex-col items-center justify-center relative p-6">
                            <audio
                              ref={playerVideoRef}
                              src={playerTrack.url}
                              onTimeUpdate={(e) => setPlayerCurrentTime(e.currentTarget.currentTime)}
                              onLoadedMetadata={(e) => setPlayerDuration(e.currentTarget.duration)}
                              onEnded={() => setPlayerIsPlaying(false)}
                              autoPlay={playerIsPlaying}
                            />
                            
                            {/* Retro Tape visualization */}
                            <div className="w-44 h-44 rounded-full bg-gradient-to-r from-amber-500 via-pink-600 to-purple-600 p-1 flex items-center justify-center shadow-lg" style={{ animation: playerIsPlaying ? 'spin 12s linear infinite' : 'none' }}>
                              <div className="w-full h-full rounded-full bg-[#02050c] flex items-center justify-center border-4 border-black border-dashed">
                                <Music className="w-12 h-12 text-amber-500 animate-pulse" />
                              </div>
                            </div>
                            
                            <p className="text-yellow-400 text-xs font-mono font-bold mt-4 animate-pulse">
                              {playerIsPlaying ? "AMORFLY AKILLI SES AKTİF ●" : "SES PARÇASI HAZIR • OYNATIN"}
                            </p>
                            <span className="text-gray-400 text-[11px] font-sans mt-1 text-center max-w-sm truncate">{playerTrack.title}</span>

                            {/* Simulated Animated Equalizer waves */}
                            <div className="absolute bottom-4 left-0 right-0 flex items-end justify-center gap-1 h-12 px-4 opacity-75">
                              {Array.from({ length: 24 }).map((_, idx) => {
                                const heightVal = Math.floor(Math.random() * 40) + 12;
                                return (
                                  <span 
                                    key={idx} 
                                    className="w-1.5 bg-gradient-to-t from-purple-600 via-amber-500 to-emerald-400 rounded-t"
                                    style={{ 
                                      height: playerIsPlaying ? `${heightVal}px` : '4px',
                                      transition: 'height 0.15s ease-in-out',
                                      animation: playerIsPlaying ? `bounceEqualizer 0.8s infinite ease-in-out alternate` : 'none',
                                      animationDelay: `${idx * 0.04}s`
                                    }}
                                  />
                                );
                              })}
                            </div>
                          </div>
                        )}
                      </div>

                      {/* Subtitles Overlay Bar */}
                      {playerSubtitleText && (
                        <div className="absolute bottom-16 bg-black/75 backdrop-blur-md border border-slate-700/50 text-white rounded-lg px-4 py-1.5 text-center text-xs shadow-md z-10 left-1/2 -translate-x-1/2 pointer-events-none transition-all">
                          <p className="font-semibold text-amber-400 select-all">{playerSubtitleText}</p>
                        </div>
                      )}
                    </div>

                    {/* Custom Controls Deck Interface (Classic VLC Styling inside Amorfly layout) */}
                    <div className="bg-[#0c1224] border border-[#1e293b] rounded-2xl p-4 md:p-5 shadow-lg space-y-4 select-text">
                      {/* Timeline scrubbing area */}
                      <div className="flex items-center justify-between gap-3 text-xs font-mono">
                        <span className="text-slate-400 text-xxs bg-[#02050c] px-2 py-1 rounded border border-slate-900 leading-none">
                          {new Date(playerCurrentTime * 1000).toISOString().substr(11, 8)}
                        </span>
                        
                        {/* Scrub timeline range slider */}
                        <input
                          type="range"
                          min={0}
                          max={playerDuration || 100}
                          step={0.1}
                          value={playerCurrentTime}
                          onChange={(e) => {
                            const val = parseFloat(e.target.value);
                            setPlayerCurrentTime(val);
                            if (playerVideoRef.current) {
                              playerVideoRef.current.currentTime = val;
                            }
                          }}
                          className="flex-1 h-1.5 bg-[#1e293b] rounded-lg appearance-none cursor-pointer accent-amber-500"
                        />

                        <span className="text-slate-400 text-xxs bg-[#02050c] px-2 py-1 rounded border border-slate-900 leading-none">
                          {new Date(playerDuration * 1000).toISOString().substr(11, 8)}
                        </span>
                      </div>

                      {/* Quick Access Control Buttons Wrapper */}
                      <div className="flex flex-wrap items-center justify-between gap-4 pt-1 bg-black/10 p-2.5 rounded-xl border border-[#1e293b]/50">
                        
                        {/* Playback Buttons (Play, Pause, Stop, fastrewind, fastforward) */}
                        <div className="flex items-center gap-2">
                          <button
                            onClick={() => {
                              if (playerVideoRef.current) {
                                if (playerIsPlaying) {
                                  playerVideoRef.current.pause();
                                  setPlayerIsPlaying(false);
                                } else {
                                  playerVideoRef.current.play();
                                  setPlayerIsPlaying(true);
                                }
                              }
                            }}
                            className={`w-10 h-10 rounded-lg flex items-center justify-center transition-all border shadow-sm ${
                              playerIsPlaying
                                ? 'bg-amber-500/15 text-amber-400 border-amber-500/30 hover:bg-amber-500/25'
                                : 'bg-emerald-600/15 text-emerald-400 border-emerald-500/30 hover:bg-emerald-600/25'
                            } cursor-pointer`}
                            title={playerIsPlaying ? "Duraklat" : "Oynat"}
                          >
                            {playerIsPlaying ? (
                              <span className="text-xs font-black">⏸</span>
                            ) : (
                              <Play className="w-4 h-4" />
                            )}
                          </button>

                          <button
                            onClick={() => {
                              if (playerVideoRef.current) {
                                playerVideoRef.current.pause();
                                playerVideoRef.current.currentTime = 0;
                                setPlayerIsPlaying(false);
                                setPlayerCurrentTime(0);
                              }
                            }}
                            className="w-10 h-10 bg-[#02050c] border border-slate-800 hover:bg-slate-950 rounded-lg flex items-center justify-center text-red-400 transition-all cursor-pointer hover:border-red-500/35"
                            title="Durdur"
                          >
                            <span className="text-xs font-black">⏹</span>
                          </button>

                          <div className="w-[1px] h-6 bg-slate-800 mx-1"></div>

                          <button
                            onClick={() => {
                              if (playerVideoRef.current) {
                                playerVideoRef.current.currentTime = Math.max(0, playerVideoRef.current.currentTime - 10);
                              }
                            }}
                            className="p-2 text-slate-400 hover:text-white transition-all cursor-pointer"
                            title="10 Saniye Geri"
                          >
                            <Rewind className="w-4 h-4" />
                          </button>

                          <button
                            onClick={() => {
                              if (playerVideoRef.current) {
                                playerVideoRef.current.currentTime = Math.min(playerDuration, playerVideoRef.current.currentTime + 10);
                              }
                            }}
                            className="p-2 text-slate-400 hover:text-white transition-all cursor-pointer"
                            title="10 Saniye İleri"
                          >
                            <FastForward className="w-4 h-4" />
                          </button>

                          <button
                            onClick={() => {
                              if (playerVideoRef.current) {
                                playerVideoRef.current.currentTime = 0;
                              }
                            }}
                            className="p-2 text-slate-400 hover:text-white transition-all cursor-pointer"
                            title="Yeniden Başlat"
                          >
                            <RotateCcw className="w-4 h-4" />
                          </button>
                        </div>

                        {/* Playback speed presets dropdown */}
                        <div className="flex items-center gap-2">
                          <span className="text-[10px] text-gray-400 font-mono">Hız:</span>
                          <select
                            value={playerPlaybackRate}
                            onChange={(e) => setPlayerPlaybackRate(parseFloat(e.target.value))}
                            className="bg-slate-950 text-gray-200 text-xxs py-1 px-2 rounded-lg border border-slate-800 cursor-pointer outline-none focus:border-amber-500 font-mono"
                          >
                            <option value="0.25">0.25x</option>
                            <option value="0.50">0.50x</option>
                            <option value="0.75">0.75x</option>
                            <option value="1.00">1.00x</option>
                            <option value="1.25">1.25x</option>
                            <option value="1.50">1.50x</option>
                            <option value="1.75">1.75x</option>
                            <option value="2.00">2.00x</option>
                            <option value="3.00">3.00x</option>
                          </select>
                        </div>

                        {/* Dynamic Aspect Ratio aspect-ratio switcher like VLC */}
                        <div className="flex items-center gap-2">
                          <span className="text-[10px] text-gray-400 font-mono">Ekran:</span>
                          <select
                            value={playerAspectRatio}
                            onChange={(e) => setPlayerAspectRatio(e.target.value)}
                            className="bg-slate-950 text-gray-200 text-xxs py-1 px-2 rounded-lg border border-slate-800 cursor-pointer outline-none focus:border-amber-500"
                          >
                            <option value="aspect-video">16:9 Geniş Ekran</option>
                            <option value="aspect-auto">Doğal Boyut (Oto)</option>
                            <option value="aspect-square">1:1 Kare Kareş</option>
                            <option value="h-[320px] w-full">4:3 TV Formatı</option>
                            <option value="h-[460px] w-full object-fill scale-x-125">21:9 Ultra Cinema</option>
                          </select>
                        </div>

                        {/* Sound Controls Section */}
                        <div className="flex items-center gap-2 bg-[#02050c]/80 px-3 py-1.5 rounded-xl border border-slate-900 border-slate-800/40">
                          <button
                            onClick={() => setPlayerIsMuted(!playerIsMuted)}
                            className="text-amber-500 hover:text-amber-400 transition-colors cursor-pointer"
                            title={playerIsMuted ? "Sesi Aç" : "Sesi Kapat"}
                          >
                            {playerIsMuted || playerVolume === 0 ? (
                              <VolumeX className="w-4 h-4 text-red-400 animate-pulse" />
                            ) : (
                              <Volume2 className="w-4 h-4" />
                            )}
                          </button>
                          
                          <input
                            type="range"
                            min={0}
                            max={1}
                            step={0.05}
                            value={playerVolume}
                            onChange={(e) => {
                              const v = parseFloat(e.target.value);
                              setPlayerVolume(v);
                              if (v > 0) setPlayerIsMuted(false);
                            }}
                            className="w-16 h-1 bg-slate-800 rounded-lg cursor-pointer accent-amber-500"
                            title={`Ses Seviyesi: %${Math.round(playerVolume * 100)}`}
                          />
                          <span className="text-[9px] font-mono text-slate-400 w-6 text-right">%{Math.round(playerVolume * 100)}</span>
                        </div>
                      </div>
                    </div>

                    {/* V2.0 Direct VLC Player Deep Integration & Local Daemon Deck */}
                    <div className="bg-[#050914] border border-[#ff6a00]/30 rounded-2xl p-4 md:p-5 shadow-lg space-y-3">
                      <div className="flex items-center justify-between">
                        <div className="flex items-center gap-2">
                          <span className="w-2.5 h-2.5 bg-orange-500 rounded-full animate-ping"></span>
                          <span className="text-[11px] font-black uppercase text-amber-400 font-mono tracking-wider">
                            AMORFLY DIRECT VLC DAEMON SYSTEM (V2.0)
                          </span>
                        </div>
                        <span className="text-[9.5px] bg-[#e95420]/10 border border-[#e95420]/20 text-orange-400 px-2.5 py-0.5 rounded font-mono font-bold">
                          ZORIN / GNOME NATIVE
                        </span>
                      </div>
                      
                      <p className="text-[10.5px] text-gray-400 leading-normal">
                        Film oynatıcıyı tarayıcı penceresinde sınırlı izlemek yerine; tek tıkla <b>%100 donanım ivmeli, yapay zeka dublaj sarmalayıcılı ve otomatik senkronize altyazılı</b> olarak doğrudan kurulu sisteminizdeki <b>VLC Player</b> programına yönlendirin:
                      </p>

                      <div className="flex flex-col sm:flex-row gap-3 pt-1">
                        <button
                          onClick={() => handlePlayInVlc(playerTrack.url, playerTrack.title)}
                          disabled={vlcLaunchingLocal}
                          className="flex-1 bg-gradient-to-r from-orange-600 to-amber-500 hover:from-orange-500 hover:to-amber-400 text-white font-extrabold text-xs px-4 py-3 rounded-xl shadow-lg shadow-orange-950/20 transition-all flex items-center justify-center gap-2 cursor-pointer disabled:opacity-50"
                        >
                          <svg className="w-4 h-4 fill-current shrink-0" viewBox="0 0 24 24">
                            <path d="M12 2L2 22h20L12 2zm0 3.99L18.44 19H5.56L12 5.99zM11 10v4h2v-4h-2zm0 6v2h2v-2h-2z" />
                          </svg>
                          <span>{vlcLaunchingLocal ? 'VLC Soketi Tetikleniyor...' : 'Videoyu Doğrudan VLC\'de Aç (Altyazılı)'}</span>
                        </button>
                        
                        <a
                          href={`data:text/plain;charset=utf-8,${encodeURIComponent(
                            `#EXTM3U\n#EXTINF:-1,${playerTrack.title}\n${playerTrack.url}`
                          )}`}
                          download={`${playerTrack.title.replace(/\s+/g, "_")}.m3u8`}
                          className="px-3.5 py-3 bg-zinc-900 hover:bg-zinc-800 text-slate-300 font-bold text-xs rounded-xl border border-zinc-800 text-center flex items-center justify-center gap-1.5 transition-colors"
                          title="VLC M3U Oynatma Listesi İndir"
                        >
                          M3U Listesini İndir
                        </a>
                      </div>

                      {/* Live Local connection status monitor */}
                      {vlcLaunchDetails && (
                        <div className="p-3 bg-black/65 border border-amber-950/40 rounded-xl space-y-1 font-mono text-[10px] text-gray-300 leading-normal select-all">
                          <div className="flex items-center gap-1.5 border-b border-zinc-900 pb-1 mb-1.5">
                            <span className="w-1.5 h-1.5 bg-green-500 rounded-full animate-pulse"></span>
                            <span className="font-extrabold text-[9px] text-[#e95420]">YEREL VLC KOMUT SATIRI INTEGRATION:</span>
                          </div>
                          <pre className="whitespace-pre-wrap">{vlcLaunchDetails}</pre>
                        </div>
                      )}
                    </div>

                    {/* Quick informative status */}
                    <div className="bg-[#0b0c10] border border-slate-900 rounded-xl p-4 flex flex-col md:flex-row items-center justify-between text-xs text-slate-400 font-mono gap-4 select-text">
                      <div className="flex items-center gap-2">
                        <span className="w-2 h-2 bg-emerald-400 rounded-full animate-pulse"></span>
                        <span><b>Hızlandırılmış Oynatım:</b> WebGL tabanlı video renderlama motoru devrede.</span>
                      </div>
                      <div className="text-[10px] text-amber-400 bg-amber-950/20 border border-amber-500/20 px-2.5 py-1 rounded">
                        AMORFLY SECURE MEDIA DECODER ACTIVE
                      </div>
                    </div>

                  </div>

                  {/* Right Column (1/3 width) - Tracks, Audio Equalizer & Interactive Filters */}
                  <div className="space-y-6 select-text">
                    
                    {/* Media Tracks Selection */}
                    <div className="bg-[#0c1224] border border-[#1e293b] rounded-2xl p-5 shadow-lg space-y-4">
                      <div className="flex items-center justify-between pb-2 border-b border-slate-800">
                        <div className="flex items-center gap-2">
                          <Film className="w-4 h-4 text-amber-500" />
                          <h3 className="text-xs font-black text-gray-200 uppercase tracking-widest font-sans">Ortam Parçaları</h3>
                        </div>
                        <span className="text-[9px] bg-[#02050c] text-gray-400 font-bold px-2.5 py-0.5 rounded-full border border-slate-900">VOD</span>
                      </div>

                      {/* Tracks mapping */}
                      <div className="space-y-2 max-h-[220px] overflow-y-auto pr-1">
                        
                        {/* Track 1: Sintel */}
                        <div
                          onClick={() => {
                            setPlayerTrack({
                              title: "Sintel Açık Sinema Fragmanı (Action Animation)",
                              url: "https://commondatastorage.googleapis.com/gtv-videos-bucket/sample/Sintel.mp4",
                              type: "video",
                              category: "Video"
                            });
                            setPlayerIsPlaying(true);
                          }}
                          className={`p-2.5 rounded-lg border transition-all duration-200 cursor-pointer flex items-center gap-2.5 ${
                            playerTrack.url === "https://commondatastorage.googleapis.com/gtv-videos-bucket/sample/Sintel.mp4"
                              ? 'bg-amber-600/15 border-amber-500/30 text-amber-300 shadow-md'
                              : 'bg-[#02050c] border-[#1e293b]/50 text-gray-400 hover:text-white hover:border-[#38bdf8]/40'
                          }`}
                        >
                          <Tv className="w-4 h-4 shrink-0 text-amber-505" />
                          <div className="flex flex-col text-left overflow-hidden">
                            <span className="text-xs font-bold truncate">Sintel Film Fragmanı 🎬</span>
                            <span className="text-[9px] text-gray-500 mt-0.5">MP4 • 1080p • 11.2 MB</span>
                          </div>
                        </div>

                        {/* Track 2: Big Buck Bunny */}
                        <div
                          onClick={() => {
                            setPlayerTrack({
                              title: "Big Buck Bunny Klasik Animasyon",
                              url: "https://commondatastorage.googleapis.com/gtv-videos-bucket/sample/BigBuckBunny.mp4",
                              type: "video",
                              category: "Video"
                            });
                            setPlayerIsPlaying(true);
                          }}
                          className={`p-2.5 rounded-lg border transition-all duration-200 cursor-pointer flex items-center gap-2.5 ${
                            playerTrack.url === "https://commondatastorage.googleapis.com/gtv-videos-bucket/sample/BigBuckBunny.mp4"
                              ? 'bg-amber-600/15 border-amber-500/30 text-amber-300 shadow-md'
                              : 'bg-[#02050c] border-[#1e293b]/50 text-gray-400 hover:text-white hover:border-[#38bdf8]/40'
                          }`}
                        >
                          <Tv className="w-4 h-4 shrink-0 text-emerald-500" />
                          <div className="flex flex-col text-left overflow-hidden">
                            <span className="text-xs font-bold truncate">Big Buck Bunny Klasik 🐰</span>
                            <span className="text-[9px] text-gray-500 mt-0.5">MP4 • 720p • 22.0 MB</span>
                          </div>
                        </div>

                        {/* Track 3: Tears of Steel */}
                        <div
                          onClick={() => {
                            setPlayerTrack({
                              title: "Tears of Steel Bilim Kurgu Fragmanı (Cyberpunk 4K Test)",
                              url: "https://commondatastorage.googleapis.com/gtv-videos-bucket/sample/TearsOfSteel.mp4",
                              type: "video",
                              category: "Video"
                            });
                            setPlayerIsPlaying(true);
                          }}
                          className={`p-2.5 rounded-lg border transition-all duration-200 cursor-pointer flex items-center gap-2.5 ${
                            playerTrack.url === "https://commondatastorage.googleapis.com/gtv-videos-bucket/sample/TearsOfSteel.mp4"
                              ? 'bg-amber-600/15 border-amber-500/30 text-amber-300 shadow-md'
                              : 'bg-[#02050c] border-[#1e293b]/50 text-gray-400 hover:text-white hover:border-[#38bdf8]/40'
                          }`}
                        >
                          <Tv className="w-4 h-4 shrink-0 text-cyan-400" />
                          <div className="flex flex-col text-left overflow-hidden">
                            <span className="text-xs font-bold truncate">Tears Of Steel Cyberpunk 👾</span>
                            <span className="text-[9px] text-gray-500 mt-0.5">MP4 • 1080p • 14.5 MB</span>
                          </div>
                        </div>

                        {/* Audio Track 1: Ambient Lofi */}
                        <div
                          onClick={() => {
                            setPlayerTrack({
                              title: "Amorfly Ambient Lo-Fi Yoğunlaşma Ritmi (Synth Beat 1)",
                              url: "https://www.soundhelix.com/examples/mp3/SoundHelix-Song-1.mp3",
                              type: "audio",
                              category: "Ses"
                            });
                            setPlayerIsPlaying(true);
                          }}
                          className={`p-2.5 rounded-lg border transition-all duration-200 cursor-pointer flex items-center gap-2.5 ${
                            playerTrack.url === "https://www.soundhelix.com/examples/mp3/SoundHelix-Song-1.mp3"
                              ? 'bg-amber-600/15 border-amber-500/30 text-amber-300 shadow-md'
                              : 'bg-[#02050c] border-[#1e293b]/50 text-gray-400 hover:text-white hover:border-[#38bdf8]/40'
                          }`}
                        >
                          <Music className="w-4 h-4 shrink-0 text-pink-400" />
                          <div className="flex flex-col text-left overflow-hidden">
                            <span className="text-xs font-bold truncate">Ambient Synth Music 🎹</span>
                            <span className="text-[9px] text-gray-500 mt-0.5">MP3 • Standart • 6.1 MB</span>
                          </div>
                        </div>

                        {/* Audio Track 2: Deep Cyber Synth */}
                        <div
                          onClick={() => {
                            setPlayerTrack({
                              title: "Deep Cyber-Synth Dalgaları (Equalizer Test Song 4)",
                              url: "https://www.soundhelix.com/examples/mp3/SoundHelix-Song-4.mp3",
                              type: "audio",
                              category: "Ses"
                            });
                            setPlayerIsPlaying(true);
                          }}
                          className={`p-2.5 rounded-lg border transition-all duration-200 cursor-pointer flex items-center gap-2.5 ${
                            playerTrack.url === "https://www.soundhelix.com/examples/mp3/SoundHelix-Song-4.mp3"
                              ? 'bg-amber-600/15 border-amber-500/30 text-amber-300 shadow-md'
                              : 'bg-[#02050c] border-[#1e293b]/50 text-gray-400 hover:text-white hover:border-[#38bdf8]/40'
                          }`}
                        >
                          <Music className="w-4 h-4 shrink-0 text-purple-400" />
                          <div className="flex flex-col text-left overflow-hidden">
                            <span className="text-xs font-bold truncate">Deep Cyber-Synth 🌌</span>
                            <span className="text-[9px] text-gray-500 mt-0.5">MP3 • Standart • 7.3 MB</span>
                          </div>
                        </div>

                        {/* Rendering uploaded Custom Media */}
                        {playerCustomMediaList.map((item, idx) => (
                          <div
                            key={idx}
                            onClick={() => {
                              setPlayerTrack(item);
                              setPlayerIsPlaying(true);
                            }}
                            className={`p-2.5 rounded-lg border transition-all duration-200 cursor-pointer flex items-center gap-2.5 ${
                              playerTrack.url === item.url
                                ? 'bg-amber-600/15 border-amber-500/30 text-amber-300 shadow-md'
                                : 'bg-[#02050c] border-[#1e293b]/50 text-gray-400 hover:text-white hover:border-[#38bdf8]/40'
                            }`}
                          >
                            {item.type === 'video' ? (
                              <Tv className="w-4 h-4 shrink-0 text-yellow-400" />
                            ) : (
                              <Music className="w-4 h-4 shrink-0 text-pink-400" />
                            )}
                            <div className="flex flex-col text-left overflow-hidden w-full">
                              <span className="text-xs font-bold truncate">{item.title}</span>
                              <span className="text-[9px] text-emerald-400 mt-0.5">{item.category} • Yerel Disk</span>
                            </div>
                          </div>
                        ))}
                      </div>

                      {/* Improved File Dropper with 2 GB limit indicator for v2.0 */}
                      <div className="border border-dashed border-[#e95420]/50 bg-black/40 p-4 rounded-xl flex flex-col items-center justify-center text-center transition-all hover:border-amber-500/60">
                        <Upload className="w-6 h-6 mb-2 text-orange-400 animate-pulse" />
                        <label className="cursor-pointer text-xxs font-bold block text-gray-300">
                          <span className="text-amber-500 hover:underline">Sürükleyin veya Bilgisayardan Büyük Video Seçin</span>
                          <input
                            type="file"
                            className="hidden"
                            accept="video/*,audio/*"
                            onChange={(e) => {
                              const file = e.target.files?.[0];
                              if (file) {
                                // Dynamic file size checking up to 2.1 GB
                                const sizeInGB = file.size / (1024 * 1024 * 1024);
                                if (sizeInGB > 2.05) {
                                  alert("Uyarı: Dosya boyutu 2 GB limitini aşıyor (" + sizeInGB.toFixed(2) + " GB). Lütfen daha küçük bir video seçin.");
                                }
                                const objectUrl = URL.createObjectURL(file);
                                const isVideo = file.type.startsWith('video');
                                const customTrack = {
                                  title: file.name,
                                  url: objectUrl,
                                  type: isVideo ? 'video' as const : 'audio' as const,
                                  category: file.type.split('/')[0].toUpperCase() + ` (${(file.size / (1024 * 1024)).toFixed(1)} MB)`
                                };
                                setPlayerCustomMediaList(prev => [customTrack, ...prev]);
                                setPlayerTrack(customTrack);
                                setPlayerIsPlaying(true);
                                
                                // Trigger user OS-habit notification rule
                                setOsHabitSuggestion({
                                  title: "Medya Tarandısı & Ağır Dosya Tespit Edildi",
                                  desc: `Entegre VLC oynatımı için '${file.name}' hazırlandı. Bu büyük video (${(file.size / (1024*1024)).toFixed(1)} MB) için donanım deşifresini ve CUDA/Vulkan donanım ivmesini devreye sokmanızı öneririz.`,
                                  actionLabel: "Vulkan Shader Modunu Aç",
                                  cmd: "nvidia-settings -a GPUOverclockingState=1"
                                });
                              }
                            }}
                          />
                        </label>
                        <p className="text-[9px] text-slate-400 mt-1.5 leading-relaxed font-mono">
                          ⚡ v2.0 Motoru: Maksimum <b>2 GB</b> boyutunda MP4, MKV, AVI, MOV dosyalarını sıfır sızıntı ile yerel çözümler.
                        </p>
                      </div>

                      {/* AI v2.0 Multi-Sub & Dub Sentezleyici Kontrolleri Panel */}
                      <div className="bg-[#030611] border border-slate-900 rounded-xl p-3.5 space-y-3">
                        <div className="flex items-center justify-between border-b border-slate-900 pb-2">
                          <span className="text-[10px] text-[#e95420] font-extrabold uppercase font-mono tracking-wider">
                            🎙️ AI v2.0 Dublaj &amp; Çift Dil Altyazı Düzenleyici
                          </span>
                          <span className="text-[8px] bg-emerald-950 text-emerald-400 px-1.5 py-0.5 rounded font-bold font-mono">AKTİF</span>
                        </div>

                        {/* Scanner File Size Limit Range */}
                        <div className="space-y-1">
                          <div className="flex justify-between text-[9px] text-gray-400">
                            <span>Video Tarama Sınırı:</span>
                            <span className="text-amber-400 font-bold">{selectedScanSizeGB.toFixed(1)} GB</span>
                          </div>
                          <input
                            type="range"
                            min={0.1}
                            max={2.0}
                            step={0.1}
                            value={selectedScanSizeGB}
                            onChange={(e) => setSelectedScanSizeGB(parseFloat(e.target.value))}
                            className="w-full accent-amber-500 cursor-pointer h-1 rounded bg-[#101424]"
                          />
                        </div>

                        <div className="grid grid-cols-2 gap-2">
                          {/* Target Dub Language */}
                          <div className="space-y-1">
                            <span className="text-[9px] text-gray-400 block">Dublaj Dili:</span>
                            <select
                              value={selectedDubLang}
                              onChange={(e) => setSelectedDubLang(e.target.value)}
                              className="w-full bg-[#0e1224] text-gray-300 text-[10px] py-1 px-1.5 rounded border border-slate-800 outline-none focus:border-amber-500"
                            >
                              <option value="tr">Türkçe (AI Seslendirme) 🇹🇷</option>
                              <option value="en">İngilizce (AI Voice) 🇬🇧</option>
                              <option value="de">Almanca (AI Stimme) 🇩🇪</option>
                              <option value="es">İspanyolca (Voice AI) 🇪🇸</option>
                            </select>
                          </div>

                          {/* Subtitle style selection */}
                          <div className="space-y-1">
                            <span className="text-[9px] text-gray-400 block">Altyazı Stili:</span>
                            <select
                              value={subtitleTranslationStyle}
                              onChange={(e) => setSubtitleTranslationStyle(e.target.value)}
                              className="w-full bg-[#0e1224] text-gray-300 text-[10px] py-1 px-1.5 rounded border border-slate-800 outline-none focus:border-amber-500"
                            >
                              <option value="dual">Türkçe + Orijinal (Çift Dil)</option>
                              <option value="only-tr">Sadece Türkçe Altyazı</option>
                              <option value="only-target">Sadece Çeviri Dili</option>
                            </select>
                          </div>
                        </div>

                        {/* Speaker Voice Cloning */}
                        <div className="flex items-center justify-between pt-1 text-[9.5px]">
                          <span className="text-gray-400 block">Karakter Ses Klonlama (Orijinal Ses Koruma):</span>
                          <button
                            onClick={() => setSelectedVoiceClone(!selectedVoiceClone)}
                            className={`px-2 py-0.5 rounded text-[8.5px] font-bold ${
                              selectedVoiceClone ? 'bg-indigo-950 text-indigo-300 border border-indigo-900' : 'bg-zinc-800 text-zinc-400'
                            }`}
                          >
                            {selectedVoiceClone ? 'ETKİN (v2.0)' : 'DEVRE DIŞI'}
                          </button>
                        </div>

                        {/* Dubbing trigger button */}
                        <button
                          onClick={() => handleProcess2GBVideo(playerTrack.title)}
                          disabled={isMediaProcessing2GB}
                          className="w-full bg-indigo-650 hover:bg-indigo-600 text-white font-extrabold text-[10.5px] py-2 rounded-lg transition-all flex items-center justify-center gap-1.5 cursor-pointer disabled:opacity-50"
                        >
                          {isMediaProcessing2GB ? 'Sentez İşleniyor...' : 'AI Dublaj ve Altyazı Dosyasını Sentezle ⚡'}
                        </button>

                        {/* Processing Progress Status */}
                        {isMediaProcessing2GB && (
                          <div className="space-y-1.5 p-2 bg-black/50 rounded-lg">
                            <div className="flex items-center justify-between text-[8px] font-mono">
                              <span className="text-indigo-400 font-extrabold animate-pulse">● {mediaProcessingStep}</span>
                              <span className="text-gray-400">%{mediaProcessingProgress}</span>
                            </div>
                            <div className="w-full bg-slate-900 h-1 rounded-full overflow-hidden">
                              <div
                                className="bg-gradient-to-r from-indigo-500 via-pink-500 to-amber-500 h-full transition-all duration-300"
                                style={{ width: `${mediaProcessingProgress}%` }}
                              ></div>
                            </div>
                          </div>
                        )}
                      </div>
                    </div>

                    {/* Image Effect Filters */}
                    <div className="bg-[#0b0c10] border border-slate-900 rounded-2xl p-5 shadow-lg space-y-4">
                      <div className="flex items-center gap-2 pb-2 border-b border-slate-850">
                        <SlidersHorizontal className="w-4 h-4 text-amber-500" />
                        <span className="text-xs font-black text-gray-200 uppercase tracking-widest font-sans">Görüntü Filtreleri</span>
                      </div>
                      
                      <div className="grid grid-cols-2 gap-2 text-xxs">
                        {[
                          { id: 'none', label: 'Doğal (Filtresiz)' },
                          { id: 'sepia', label: 'Sıcak Sinema 🍿' },
                          { id: 'grayscale', label: 'Siyah Beyaz (Retro)' },
                          { id: 'contrast', label: 'Yüksek Kontrast' }
                        ].map((filterOption) => (
                          <button
                            key={filterOption.id}
                            onClick={() => setPlayerVisualFilter(filterOption.id)}
                            className={`py-2 px-3 border rounded-xl font-bold transition-all text-center ${
                              playerVisualFilter === filterOption.id
                                ? 'bg-amber-600/15 border-amber-550/40 text-amber-300'
                                : 'bg-slate-950 border-slate-800 text-slate-400 hover:text-white'
                            }`}
                          >
                            {filterOption.label}
                          </button>
                        ))}
                      </div>
                    </div>

                    {/* Advanced Equalizer sliders */}
                    <div className="bg-[#0c1224] border border-[#1e293b] rounded-2xl p-5 shadow-lg space-y-4">
                      <div className="flex items-center gap-2 pb-2 border-b border-slate-850">
                        <SlidersHorizontal className="w-4 h-4 text-amber-500" />
                        <span className="text-xs font-black text-gray-200 uppercase tracking-widest font-sans">VLC Grafik Ekolayzer</span>
                      </div>

                      <div className="space-y-4 text-xxs font-mono">
                        
                        {/* Bass Slider */}
                        <div className="space-y-1">
                          <div className="flex justify-between text-slate-400">
                            <span>🔊 Bass (60Hz):</span>
                            <span className="text-amber-400 font-bold">{playerEqBass > 50 ? `+${(playerEqBass - 50) / 4} dB` : `${(playerEqBass - 50) / 4} dB`}</span>
                          </div>
                          <input
                            type="range"
                            min={0}
                            max={100}
                            value={playerEqBass}
                            onChange={(e) => setPlayerEqBass(parseInt(e.target.value))}
                            className="w-full accent-amber-500 cursor-pointer"
                          />
                        </div>

                        {/* Mid Slider */}
                        <div className="space-y-1">
                          <div className="flex justify-between text-slate-400">
                            <span>🗣 Ses / Mid (1kHz):</span>
                            <span className="text-amber-400 font-bold">{playerEqMid > 50 ? `+${(playerEqMid - 50) / 4} dB` : `${(playerEqMid - 50) / 4} dB`}</span>
                          </div>
                          <input
                            type="range"
                            min={0}
                            max={100}
                            value={playerEqMid}
                            onChange={(e) => setPlayerEqMid(parseInt(e.target.value))}
                            className="w-full accent-amber-500 cursor-pointer"
                          />
                        </div>

                        {/* Treble Slider */}
                        <div className="space-y-1">
                          <div className="flex justify-between text-slate-400">
                            <span>⚡ Tiz / Netlik (15kHz):</span>
                            <span className="text-amber-400 font-bold">{playerEqTreble > 50 ? `+${(playerEqTreble - 50) / 4} dB` : `${(playerEqTreble - 50) / 4} dB`}</span>
                          </div>
                          <input
                            type="range"
                            min={0}
                            max={100}
                            value={playerEqTreble}
                            onChange={(e) => setPlayerEqTreble(parseInt(e.target.value))}
                            className="w-full accent-amber-500 cursor-pointer"
                          />
                        </div>

                      </div>
                    </div>

                    {/* Subtitles Overlay Overlay Manager */}
                    <div className="bg-[#0b0c10] border border-slate-900 rounded-2xl p-5 shadow-lg space-y-4">
                      <div className="flex items-center gap-2 pb-2 border-b border-slate-850">
                        <SlidersHorizontal className="w-4 h-4 text-amber-500" />
                        <span className="text-xs font-black text-gray-200 uppercase tracking-widest font-sans">Altyazı & Canlı Gösterge</span>
                      </div>

                      <div className="space-y-3">
                        <p className="text-[10px] text-gray-400 leading-normal">
                          Ekran üzerinde anlık belirmesini istediğiniz alt bilgi veya çeviriyi el ile düzenleyin:
                        </p>
                        <textarea
                          rows={2}
                          value={playerSubtitleText || ''}
                          onChange={(e) => setPlayerSubtitleText(e.target.value || null)}
                          placeholder="Canlı altyazı metnini buraya yazın..."
                          className="w-full bg-[#02050c] text-white p-2.5 text-xxs border border-slate-800 rounded-lg select-text focus:outline-none focus:border-amber-500 font-sans leading-relaxed"
                        />

                        <div className="flex flex-wrap gap-1.5">
                          <button
                            onClick={() => setPlayerSubtitleText("Türkçe Yapay Zeka Altyazı Düzeni (Simüle Sinyal)")}
                            className="text-[10px] bg-[#02050c] border border-slate-800 px-2 py-1 text-slate-400 rounded hover:text-white"
                          >
                            Demo Çeviri
                          </button>
                          <button
                            onClick={() => setPlayerSubtitleText("[Arka Fon Ses Analizi: Retro Synth Ritim Ritmi]")}
                            className="text-[10px] bg-[#02050c] border border-slate-800 px-2 py-1 text-slate-400 rounded hover:text-white"
                          >
                            Demo Ses Efekti
                          </button>
                          {playerSubtitleText && (
                            <button
                              onClick={() => setPlayerSubtitleText(null)}
                              className="text-[10px] ml-auto text-red-400 hover:text-red-300 font-bold"
                            >
                              Kaldır
                            </button>
                          )}
                        </div>
                      </div>
                    </div>

                  </div>

                </div>
              </div>
            );
            })()}

            {/* SCREEN: DESKTOP & MOBILE INTEGRATION CENTER */}
            {activeTab === 'distribution' && (
              <div className="flex-1 overflow-y-auto p-6 bg-[#21201f] space-y-8 select-text">
                
                {/* Header Section */}
                <div className="flex flex-col md:flex-row md:items-center justify-between gap-4 border-b border-[#322f2e] pb-6">
                  <div className="space-y-1">
                    <div className="flex items-center gap-2">
                      <Monitor className="w-6 h-6 text-[#e95420]" />
                      <h2 className="text-lg font-black text-gray-100 uppercase tracking-widest font-sans">Masaüstü & Mobil Kurulum Merkezi</h2>
                    </div>
                    <p className="text-xs text-gray-400 font-sans">
                      Amorfly AI'yi tarayıcıdan çıkarıp yerel bir bilgisayar programı veya Android mobil uygulamasına (.apk) dönüştürme sihirbazı.
                    </p>
                  </div>
                  
                  {/* Status Indicator */}
                  <div className="flex items-center gap-2.5 bg-[#1a1716] px-4 py-2 rounded-xl border border-[#3e3937] self-start">
                    <div className="w-2.5 h-2.5 rounded-full bg-emerald-500 animate-pulse"></div>
                    <span className="text-[11px] text-gray-300 font-mono font-bold">Kanal: Dağıtıma Hazır v1.0.0</span>
                  </div>
                </div>

                {/* 1-CLICK EASY PROGRESS INDICATOR */}
                <div className="bg-gradient-to-r from-[#2c102a] to-[#3a1523] border border-[#ff6be3]/20 rounded-2xl p-6 shadow-xl flex flex-col md:flex-row items-center justify-between gap-6 relative overflow-hidden">
                  <div className="space-y-2 max-w-2xl">
                    <div className="flex items-center gap-2 text-[#ff75fb]">
                      <Sparkles className="w-5 h-5 animate-pulse" />
                      <span className="text-xs font-black uppercase tracking-widest">En Kolay 1-Tıklama Yükleme</span>
                    </div>
                    <h3 className="text-base font-black text-white font-sans">Amorfly'yi Tarayıcı Adres Çubuğundan "Uygulama Olarak" İndirin!</h3>
                    <p className="text-xs text-gray-300 leading-relaxed font-sans">
                      Amorfly AI artık tam uyumlu bir <b>Güvenli Masaüstü Uygulaması (PWA)</b> olarak paketlendi! Ubuntu'da Chrome, Chromium veya Edge kullanıyorsanız, tarayıcınızın sağ üst köşesindeki (adres çubuğunun hemen sağındaki) <b>"Uygulamayı Yükle" 📥</b> butonuna tıklayarak saniyeler içinde bilgisayarınıza kurabilirsiniz.
                    </p>
                    <div className="flex flex-wrap gap-2 pt-1 font-mono text-[10px] text-purple-300">
                      <span className="bg-[#241323] px-2 py-1 rounded border border-[#5c1c5a]">• Ayrı bir program penceresi gibi açılır</span>
                      <span className="bg-[#241323] px-2 py-1 rounded border border-[#5c1c5a]">• Ubuntu menüsüne fütüristik logomuz eklenir</span>
                      <span className="bg-[#241323] px-2 py-1 rounded border border-[#5c1c5a]">• Sıfır harici sızıntı kalkanını tam sürdürür</span>
                    </div>
                  </div>
                  <div className="shrink-0 bg-[#211120] border border-[#5e1c56] p-4 rounded-xl flex flex-col items-center justify-center text-center max-w-[200px] shadow-inner select-none">
                    <span className="text-4xl">📥</span>
                    <span className="text-xs font-black text-white mt-1.5 block font-sans font-extrabold text-[#e95420]">Uygulamayı Yükle</span>
                    <span className="text-[10px] text-gray-500 mt-1 block leading-normal leading-relaxed">Adres çubuğundaki ikona tıklayarak tarayıcıdan bütünüyle bağımsızlaştırın.</span>
                  </div>
                </div>

                {/* Subgrid: Ubuntu and Android options */}
                <div className="grid grid-cols-1 lg:grid-cols-2 gap-8">
                  
                  {/* LEFT: Complete desktop program installation selector (Windows & Linux) */}
                  <div className="bg-[#1a1817] rounded-2xl border border-[#3c3836] p-5 flex flex-col justify-between shadow-lg relative overflow-hidden">
                    <div className="absolute top-0 right-0 w-24 h-24 bg-[#e95420]/5 rounded-bl-full pointer-events-none"></div>
                    
                    <div className="space-y-4">
                      {/* OS Switcher Slider tabs */}
                      <div className="flex bg-[#121110] border border-[#2e2b2a] rounded-xl p-0.5 w-full shrink-0">
                        <button
                          type="button"
                          onClick={() => setDistOS('windows')}
                          className={`flex-1 py-2 text-center text-xs font-black transition-all rounded-lg cursor-pointer ${
                            distOS === 'windows' ? 'bg-purple-600/30 text-white border border-purple-500/20' : 'text-slate-400 hover:text-white'
                          }`}
                        >
                          🪟 Windows (.BAT / .PS1)
                        </button>
                        <button
                          type="button"
                          onClick={() => setDistOS('linux')}
                          className={`flex-1 py-1.5 text-center text-xs font-black transition-all rounded-lg cursor-pointer ${
                            distOS === 'linux' ? 'bg-[#e95420]/30 text-white border border-[#e95420]/20' : 'text-slate-400 hover:text-white'
                          }`}
                        >
                          🐧 Linux (Debian / Zorin)
                        </button>
                      </div>

                      {distOS === 'windows' ? (
                        /* WINDOWS OS INSTALLATION CARD DETAILS */
                        <div className="space-y-4">
                          <div className="flex items-center gap-4">
                            <div className="w-16 h-16 rounded-2xl bg-[#090e1a] border border-cyan-500/20 shadow-inner flex items-center justify-center shrink-0">
                              <Laptop className="w-8 h-8 text-cyan-400" />
                            </div>
                            <div>
                              <span className="text-[10px] uppercase font-extrabold px-2.5 py-0.5 bg-cyan-500/15 text-cyan-400 rounded-full border border-cyan-500/20">Masaüstü Entegrasyonu</span>
                              <h3 className="text-sm font-bold text-gray-200 font-sans mt-1">Windows Özel Masaüstü Programı</h3>
                            </div>
                          </div>

                          <p className="text-xs text-gray-400 leading-relaxed">
                            Amorfly'yi Windows 10 & 11 bilgisayarınıza kurun ve tam şık bağımsız bir Windows programı haline getirin. 
                            Geliştirdiğimiz otomatik kod derleyici, sisteminizde hiçbir harici ağ sızıntısı olmadan yerel motoru kurar ve masaüstünüze <b>Özgün Amorfly AI Kisayol Simgesini</b> yerleştirir!
                          </p>

                          <div className="space-y-2 pt-1">
                            <label className="text-[10.5px] text-cyan-400 font-black uppercase tracking-wider block">Yönetici PowerShell Komutu</label>
                            <div className="bg-[#121110] border border-[#2e2b2a] rounded-xl p-3 font-mono text-xs text-gray-300 relative group flex items-center justify-between gap-3">
                              <span className="truncate pr-12 text-emerald-400">
                                powershell -NoProfile -ExecutionPolicy Bypass -Command "iwr -useb '{window.location.origin}/api/download-installer?targetOS=windows' | iex"
                              </span>
                              <button
                                onClick={() => {
                                  navigator.clipboard.writeText(`powershell -NoProfile -ExecutionPolicy Bypass -Command "iwr -useb '${window.location.origin}/api/download-installer?targetOS=windows' | iex"`);
                                  setCopiedId('windows_cmd');
                                  setTimeout(() => setCopiedId(null), 2000);
                                }}
                                className="bg-[#2a2726] hover:bg-[#3d3937] px-2.5 py-1.5 rounded-lg text-xs font-bold shrink-0 transition-colors cursor-pointer"
                              >
                                {copiedId === 'windows_cmd' ? 'Kopyalandı! ✓' : 'Kopyala'}
                              </button>
                            </div>

                            <span className="text-[10.5px] text-gray-300 block leading-relaxed bg-[#141b27] border border-cyan-500/20 p-3 rounded-lg mt-1 space-y-2">
                              <div>
                                🚀 <b>Yöntem A — PowerShell Otomatik Terminal Kurulumu (Hızlı & Kolay):</b>
                                <br />1. Sol alttaki Windows başlat simgesine sağ tıklayın, <b>"Terminal (Yönetici)"</b> veya <b>"PowerShell (Yönetici)"</b> seçeneğine basın.
                                <br />2. Yukarıda kopyaladığınız mavi komutu yapıştırıp enter tuşuna basın. Node.js ve Python'u otomatik kurar, masaüstünüze logomuzla kısayol yerleştirir.
                              </div>
                              <div className="border-t border-[#1e2a3b] pt-2">
                                💡 <b>Yöntem B — Çift Tıklayarak Klasik Kurulum (.bat veya .ps1):</b>
                                <br />Aşağıdaki koyu mavi butonlardan <b>"Betiği İndir (.BAT)"</b> seçeneğine tıklayarak indirilen dosyayı yönetici yetkisi ile bir kez çalıştırmanız yeterlidir.
                              </div>
                            </span>
                          </div>
                        </div>
                      ) : (
                        /* LINUX OS INSTALLATION CARD DETAILS (EXISTING INTEGRATION) */
                        <div className="space-y-4">
                          <div className="flex items-center gap-4">
                            <div className="w-16 h-16 rounded-2xl bg-[#090e1a] border border-purple-500/20 shadow-inner flex items-center justify-center shrink-0">
                              <AmorflyLogo className="w-13 h-13" />
                            </div>
                            <div>
                              <span className="text-[10px] uppercase font-extrabold px-2.5 py-0.5 bg-[#e95420]/15 text-[#e95420] rounded-full border border-[#e95420]/20">Masaüstü Entegrasyonu</span>
                              <h3 className="text-sm font-bold text-gray-200 font-sans mt-1">Ubuntu Özel Masaüstü Programı</h3>
                            </div>
                          </div>

                          <p className="text-xs text-gray-400 leading-relaxed">
                            Amorfly'yi doğrudan bilgisayarınızın uygulamalar menüsüne (veya kısayol dock paneline) ekleyin. 
                            Aşağıdaki otomatik bash betiği, bizim tasarladığımız <b>Resmi Işıltılı Fütüristik Ok ve Parantez Marka Görselini</b> ikon olarak bilgisayarınıza kaydeder ve çift tıklayarak tarayıcı çubuğu olmadan çalışabilen izole bir programa dönüştürür.
                          </p>

                          {/* Commands block */}
                          <div className="space-y-2 pt-2">
                            <label className="text-[10.5px] text-[#e95420] font-black uppercase tracking-wider block">Terminal Kısayol Komutu</label>
                            <div className="bg-[#121110] border border-[#2e2b2a] rounded-xl p-3 font-mono text-xs text-gray-300 relative group flex items-center justify-between gap-3">
                              <span className="truncate pr-12 text-emerald-400">
                                curl -sSL "{window.location.origin}/api/download-installer" | bash
                              </span>
                              <button
                                onClick={() => {
                                  navigator.clipboard.writeText(`curl -sSL "${window.location.origin}/api/download-installer" | bash`);
                                  setCopiedId('ubuntu_cmd');
                                  setTimeout(() => setCopiedId(null), 2000);
                                }}
                                className="bg-[#2a2726] hover:bg-[#3d3937] px-2.5 py-1.5 rounded-lg text-xs font-bold shrink-0 transition-colors cursor-pointer"
                              >
                                {copiedId === 'ubuntu_cmd' ? 'Kopyalandı! ✓' : 'Kopyala'}
                              </button>
                            </div>
                            <span className="text-[10.5px] text-gray-300 block leading-relaxed bg-[#201511] border border-[#a65626]/30 p-3 rounded-lg mt-1 space-y-2">
                              <div>
                                ⚠️ <b>Önemli Ubuntu/Linux Güvenlik Uyarısı (Kırmızı Çarpı veya TXT İkonu):</b> 
                                Ubuntu, Zorin OS veya Debian tabanlı sistemlerde internet tarayıcısından (Chrome/Firefox) indirilen tüm <code className="text-orange-400">.desktop</code> kısayolları güvenlik gereği varsayılan olarak <b>engellenir</b>. Bu yüzden dosya ilk indiğinde masaüstünde <b>"kırmızı çarpılı bir metin dosyası (txt)"</b> gibi görünür ve simge yüklenmez.
                              </div>
                              <div className="border-t border-[#3d271c] pt-2">
                                <strong className="text-emerald-400 block mb-1">🚀 Dosyayı Güvenli Program Haline Getirme Adımları:</strong>
                                1. İndirdiğiniz <b>amorfly.desktop</b> dosyasını Masaüstüne (<code className="text-yellow-300">~/Masaüstü</code>) taşıyın.
                                <br />2. Dosyaya sağ tıklayın ve en alttaki <b>"Başlatılmasına İzin Ver"</b> (<strong className="text-yellow-400">Allow Launching</strong>) seçeneğine tıklayın.
                                <br />3. Bunu yaptığınız anda kırmızı çarpılı simge anında kaybolacak ve yerini çizdiğimiz <b>fütüristik şık Amorfly AI amblemimize</b> bırakacaktır! Artık çift tıklayarak doğrudan bağımsız çalıştırabilirsiniz.
                                <br />4. <i>Alternatif olarak Terminal açıp şu tek satır komutu da yazabilirsiniz:</i>
                                <code className="text-[#38bdf8] block mt-1 bg-[#121110] p-1.5 rounded text-xs px-2 font-mono">
                                  chmod +x ~/Masaüstü/amorfly.desktop
                                </code>
                              </div>
                              <div className="border-t border-[#3d271c] pt-2">
                                <strong className="text-cyan-400 block mb-1">💡 Yöntem A — Tam Otomatik Kurulum Betiği (Önerilen En Güvenli Yol):</strong>
                                1. Aşağıdaki turuncu <b>"Yükleme Kodunu (.sh) İndir"</b> butonuna tıklayın. Dosya tarayıcınız aracılığıyla güvenli şekilde <b>İndirilenler</b> klasörüne kaydedilir.
                                <br />2. Terminali açarak sırasıyla şu komutları yazıp Enter'a basın:
                                <code className="text-yellow-300 block mt-1.5 bg-[#121110] p-2 rounded text-xs font-mono select-all">
                                  chmod +x ~/İndirilenler/install-amorfly.sh<br />
                                  bash ~/İndirilenler/install-amorfly.sh
                                </code>
                              </div>
                            </span>
                          </div>
                        </div>
                      )}
                    </div>

                    <div className="mt-6 pt-5 border-t border-[#2d2a29]">
                      {distOS === 'windows' ? (
                        <div className="flex flex-col sm:flex-row items-center gap-3">
                          <a 
                            href={`/api/download-installer?targetOS=bat&origin=${encodeURIComponent(window.location.origin)}`}
                            download="install-amorfly.bat"
                            className="w-full sm:w-auto flex items-center justify-center gap-2 bg-[#0284c7] hover:bg-[#0369a1] text-white font-bold text-xs px-5 py-3 rounded-xl shadow-md transition-all cursor-pointer"
                          >
                            <Download className="w-4 h-4" />
                            <span>Betiği İndir (.BAT - CMD)</span>
                          </a>
                          <a 
                            href={`/api/download-installer?targetOS=windows&origin=${encodeURIComponent(window.location.origin)}`}
                            download="install-amorfly.ps1"
                            className="w-full sm:w-auto flex items-center justify-center gap-2 bg-[#4f46e5] hover:bg-[#4338ca] text-white font-bold text-xs px-5 py-3 rounded-xl shadow-md transition-all cursor-pointer"
                          >
                            <Laptop className="w-4 h-4 text-cyan-300" />
                            <span>Betiği İndir (.PS1 - PowerShell)</span>
                          </a>
                        </div>
                      ) : (
                        <div className="flex flex-col sm:flex-row items-center gap-3">
                          <a 
                            href={`/api/download-installer?origin=${encodeURIComponent(window.location.origin)}`}
                            download="install-amorfly.sh"
                            className="w-full sm:w-auto flex items-center justify-center gap-2 bg-[#e95420] hover:bg-[#ff622a] text-white font-bold text-xs px-5 py-3 rounded-xl shadow-md transition-all cursor-pointer"
                          >
                            <Download className="w-4 h-4" />
                            <span>Yükleme Kodunu (.sh) İndir</span>
                          </a>
                          <a 
                            href={`/api/download-launcher?origin=${encodeURIComponent(window.location.origin)}`}
                            download="amorfly.desktop"
                            className="w-full sm:w-auto flex items-center justify-center gap-2 bg-[#2d2928] hover:bg-[#3f3a38] text-gray-300 font-semibold text-xs px-5 py-3 rounded-xl border border-[#3d3937] transition-all cursor-pointer"
                          >
                            <Laptop className="w-4 h-4 text-orange-400" />
                            <span>Doğrudan Başlatıcıyı (.desktop) Al</span>
                          </a>
                        </div>
                      )}
                    </div>

                  </div>

                  {/* RIGHT: Mobile APK installation via Capacitor */}
                  <div className="bg-[#1a1817] rounded-2xl border border-[#3c3836] p-5 flex flex-col justify-between shadow-lg relative overflow-hidden">
                    <div className="absolute top-0 right-0 w-24 h-24 bg-purple-950/5 rounded-bl-full pointer-events-none"></div>

                    <div className="space-y-4">
                      
                      <div className="flex items-center gap-4">
                        <div className="w-16 h-16 rounded-2xl bg-[#262423] border border-[#3d3836] p-1 shadow-inner flex items-center justify-center shrink-0">
                          <Smartphone className="w-8 h-8 text-purple-400" />
                        </div>
                        <div>
                          <span className="text-[10px] uppercase font-extrabold px-2.5 py-0.5 bg-purple-950/40 text-purple-300 rounded-full border border-purple-900/30">Android APK Paketleyici</span>
                          <h3 className="text-sm font-bold text-gray-200 font-sans mt-1">Mobil Uygulama & APK Yapılandırması</h3>
                        </div>
                      </div>

                      <p className="text-xs text-gray-400 leading-relaxed">
                        Amorfly AI tasarımı, <b>mobil ekranlar ve dokunmatik jestlerle %100 uyumlu</b> tasarlanmıştır. 
                        Uygulamayı telefonunuza native bir APK dosyası olarak paketleyip yüklemek için en kararlı hibrit paketleyici olan <b>Capacitor</b> motorunu kullanın.
                      </p>

                      {/* Commands list */}
                      <div className="space-y-2 bg-[#141212] p-3.5 rounded-xl border border-[#2e2a28] font-mono text-[11px] leading-relaxed text-gray-300">
                        <div className="text-purple-400 select-none font-sans font-black text-xs border-b border-[#242120] pb-1.5 mb-1.5 uppercase">1 Dakikada APK Sentezi :</div>
                        <div><span className="text-gray-500"># 1. Projeyi masaüstüne indirin ve bağımlılıkları ekleyin:</span></div>
                        <div className="text-white">npm install @capacitor/core @capacitor/cli</div>
                        <div><span className="text-gray-500"># 2. Mobil motoru kurun (Uygulama Adı: Amorfly AI):</span></div>
                        <div className="text-white">npx cap init "Amorfly AI" "com.amorfly.ai" --web-dir=dist</div>
                        <div><span className="text-gray-500"># 3. Android platformunu ekleyin ve kodları senkronize edin:</span></div>
                        <div className="text-white">npx cap add android && npm run build && npx cap sync</div>
                        <div><span className="text-gray-500"># 4. Android Studio'yu açıp APK'yı oluşturun:</span></div>
                        <div className="text-white">npx cap open android</div>
                      </div>

                    </div>

                    <div className="mt-6 pt-5 border-t border-[#2d2a29] flex items-center gap-2">
                      <span className="w-2 h-2 rounded-full bg-purple-400 block shrink-0"></span>
                      <span className="text-[10.5px] text-gray-500 italic">
                        *Android Studio üzerinde 'Build &gt; Build Bundle(s) / APK(s) &gt; Build APK' adımını izleyerek cep telefonunuza kurabilirsiniz.*
                      </span>
                    </div>

                  </div>

                </div>

                {/* AMORFLY PRIVACY-FIRST AI OPERATING ENVIRONMENT INTERACTIVE CONTROL CENTER (11 HARDWARE & LOGIC SUB-SYSTEMS) */}
                <OSCompanionDashboard />

                {/* Footnote Warning */}
                <div className="bg-[#241a14] rounded-xl border border-[#402a1a] p-4 flex gap-3 text-xs text-orange-300">
                  <AlertCircle className="w-5 h-5 shrink-0 text-[#e95420]" />
                  <div className="space-y-1">
                    <p className="font-bold">Neden Tarayıcı Sınırlarını Kaldırıyoruz?</p>
                    <p className="leading-relaxed">
                      Masaüstü uygulamamız tarayıcı çerçevelerini (Arama kutusu, Sekmeler, Eklentiler vb.) bütünüyle temizleyerek size tam bir **yerel işletim sistemi konsolu** deneyimi sunar. 
                      Amorfly AI penceresi, bilgisayarınızda bir Chrome/Firefox penceresinden bağımsız şekilde ayrı bir program olarak çalışarak bellek kullanımını minimize eder ve işlem hızınızı iki katına çıkartır.
                    </p>
                  </div>
                </div>

                {/* System Reset & Uninstaller Section */}
                <div className="bg-[#181110] rounded-xl border border-[#3a1d1a] p-4 flex flex-col lm:flex-row items-center justify-between gap-4 text-xs">
                  <div className="flex gap-3 text-red-350">
                    <Trash2 className="w-5 h-5 shrink-0 text-red-500 mt-1" />
                    <div className="space-y-1 text-left">
                      <p className="font-bold text-red-400">Sistem Sıfırlama ve Temizlik Aracı (Uninstaller)</p>
                      <p className="leading-relaxed text-gray-400">
                        Oluşturulan tüm yerel dizinleri, log dosyalarını, arka plan süreçlerini, masaüstü simgelerini ve kısayolları tek komutla temizleyip bilgisayarınızı eski haline döndürebilirsiniz.
                      </p>
                    </div>
                  </div>
                  <div className="w-full sm:w-auto flex flex-wrap shrink-0 gap-2">
                    <a
                      href={`/api/download-uninstaller`}
                      download="uninstall-amorfly.sh"
                      className="w-full sm:w-auto flex items-center justify-center gap-1.5 bg-red-950/60 hover:bg-red-900 text-red-300 font-bold px-4 py-2.5 rounded-xl border border-red-900/60 transition-colors cursor-pointer"
                    >
                      <Download className="w-3.5 h-3.5" />
                      <span>Kaldırıcıyı İndir</span>
                    </a>
                    <button
                      onClick={() => {
                        navigator.clipboard.writeText(`curl -sSL "${window.location.origin}/api/download-uninstaller" | bash`);
                        setCopiedId('uninstall_cmd');
                        setTimeout(() => setCopiedId(null), 2000);
                      }}
                      className="w-full sm:w-auto flex items-center justify-center gap-1.5 bg-[#242120] hover:bg-[#34302e] text-gray-300 font-bold px-4 py-2.5 rounded-xl transition-colors cursor-pointer"
                    >
                      {copiedId === 'uninstall_cmd' ? 'Kopyalandı! ✓' : 'Sıfırlama Komutunu Kopyala'}
                    </button>
                  </div>
                </div>

              </div>
            )}

          </main>
        </div>

      </div>

    </div>
  );
}
