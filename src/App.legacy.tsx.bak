        <path d="M 67,35 C 75,42 75,48 67,55" fill="none" stroke="#c084fc" strokeWidth="1.2" strokeDasharray="2 2" opacity="0.7" />

        {/* Sleek Central Flight Core Caret */}
        <path 
          d="M 50,20 L 75,58 L 50,49 L 25,58 Z" 
          fill="none" 
          stroke="url(#cyberPurple)" 
          strokeWidth="2.8" 
          strokeLinejoin="round" 
