        <line x1="50" y1="89" x2="50" y2="95" stroke="#22d3ee" strokeWidth="0.8" opacity="0.5" />
        <line x1="5" y1="50" x2="11" y2="50" stroke="#22d3ee" strokeWidth="0.8" opacity="0.5" />
        <line x1="89" y1="50" x2="95" y2="50" stroke="#22d3ee" strokeWidth="0.8" opacity="0.5" />

        {/* HUD Corner Framing Brackets */}
        <path d="M 12,23 L 12,12 L 23,12" fill="none" stroke="#22d3ee" strokeWidth="0.8" opacity="0.4" />
        <path d="M 88,23 L 88,12 L 77,12" fill="none" stroke="#22d3ee" strokeWidth="0.8" opacity="0.4" />
        <path d="M 12,77 L 12,88 L 23,88" fill="none" stroke="#22d3ee" strokeWidth="0.8" opacity="0.4" />
        <path d="M 88,77 L 88,88 L 77,88" fill="none" stroke="#22d3ee" strokeWidth="0.8" opacity="0.4" />

        {/* Left Wing Construct */}
        <path 
          d="M 32,24 C 18,36 12,54 29,71 L 37,63 C 24,50 28,37 37,29 Z" 
          fill="url(#cyberCyan)" 
          opacity="0.85" 
          filter="url(#neonGlowCyan)" 
        />
        <path d="M 33,35 C 25,42 25,48 33,55" fill="none" stroke="#c084fc" strokeWidth="1.2" strokeDasharray="2 2" opacity="0.7" />

        {/* Right Wing Construct */}
        <path 
          d="M 68,24 C 82,36 88,54 71,71 L 63,63 C 76,50 72,37 63,29 Z" 
