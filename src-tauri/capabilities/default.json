{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Amorfly AI için varsayılan pencere izinleri",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "notification:default",
    "dialog:default",
    "fs:default",
    "fs:allow-read-file",
    "fs:allow-write-file",
    "shell:allow-open",
    "opener:default",
    {
      "identifier": "opener:allow-open-path",
      "allow": [{ "path": "**" }]
    },
    {
      "identifier": "opener:allow-open-url",
      "allow": [{ "url": "https://**" }, { "url": "http://**" }]
    }
  ]
}
